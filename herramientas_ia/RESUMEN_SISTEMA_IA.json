{
  "sistema": "Validación y Corrección con IA - EVARISIS Gestor HUV",
  "version": "1.0.0",
  "fecha_creacion": "2025-10-05",
  "autor": "Sistema EVARISIS + Claude Code",

  "resumen_ejecutivo": {
    "objetivo": "Agregar validación inteligente con LLM local para mejorar calidad de datos extraídos",
    "tecnologia": "LM Studio (modelo local openai/gpt-oss-20b)",
    "privacidad": "100% local - sin envío de datos a internet",
    "impacto_esperado": "Reducción 80%+ en errores de extracción automática"
  },

  "componentes_creados": [
    {
      "nombre": "detectar_lm_studio.py",
      "ubicacion": "herramientas_ia/detectar_lm_studio.py",
      "funcion": "Detecta y valida LM Studio local",
      "uso": "python herramientas_ia/detectar_lm_studio.py --probar",
      "salida": "Información de servidor, modelo y capacidades"
    },
    {
      "nombre": "debug_mapper.py",
      "ubicacion": "core/debug_mapper.py",
      "funcion": "Genera mapeo JSON completo del procesamiento",
      "salida": "data/debug_maps/debug_map_IHQ*.json",
      "campos_capturados": [
        "Texto OCR original y consolidado",
        "Datos de cada extractor (patient, medical, biomarker, unified)",
        "Datos guardados en BD",
        "Métricas de rendimiento",
        "Warnings y errores"
      ]
    },
    {
      "nombre": "llm_client.py",
      "ubicacion": "core/llm_client.py",
      "funcion": "Cliente para comunicación con LM Studio",
      "metodos_principales": [
        "completar() - Generación de texto",
        "validar_campo_medico() - Validar campo específico",
        "validar_multiple_campos() - Validar varios campos",
        "sugerir_correcciones_lote() - Correcciones en batch"
      ]
    },
    {
      "nombre": "validador_ia.py",
      "ubicacion": "herramientas_ia/validador_ia.py",
      "funcion": "Orquesta validación completa con IA",
      "uso": "python herramientas_ia/validador_ia.py --ihq IHQ250001",
      "salida": "herramientas_ia/resultados/validaciones_ia/validacion_IHQ*.json",
      "caracteristicas": [
        "Clasificación por criticidad (CRITICA, IMPORTANTE, OPCIONAL)",
        "Cálculo de similitud entre valores",
        "Dry-run mode para pruebas seguras",
        "Aplicación automática de correcciones (opcional)"
      ]
    },
    {
      "nombre": "procesamiento_con_ia.py",
      "ubicacion": "core/procesamiento_con_ia.py",
      "funcion": "Wrapper del procesamiento normal con IA integrada",
      "uso": "python core/procesamiento_con_ia.py --pdf archivo.pdf --debug --validar-ia",
      "modos": [
        "Solo debug (genera mapas sin validar)",
        "Debug + Validación IA (sugiere correcciones)",
        "Debug + Validación + Correcciones automáticas"
      ]
    }
  ],

  "flujo_procesamiento": {
    "paso_1": {
      "nombre": "OCR y Consolidación",
      "entrada": "PDF médico",
      "salida": "Texto consolidado por caso IHQ",
      "tiempo_estimado": "2-5 segundos"
    },
    "paso_2": {
      "nombre": "Extracción de Datos",
      "entrada": "Texto consolidado",
      "salida": "Datos estructurados (patient, medical, biomarker, unified)",
      "tiempo_estimado": "0.5-1 segundo"
    },
    "paso_3": {
      "nombre": "Generación Debug Map (NUEVO)",
      "entrada": "Texto + Datos extraídos",
      "salida": "debug_map_IHQ*.json",
      "tiempo_estimado": "< 0.1 segundos",
      "overhead": "Mínimo"
    },
    "paso_4": {
      "nombre": "Validación con IA (NUEVO - OPCIONAL)",
      "entrada": "Debug map + Texto original",
      "salida": "Validaciones y sugerencias de corrección",
      "tiempo_estimado": "10-30 segundos (7 campos críticos)",
      "requiere": "LM Studio activo"
    },
    "paso_5": {
      "nombre": "Aplicación de Correcciones (OPCIONAL)",
      "entrada": "Validaciones IA",
      "salida": "Datos corregidos en BD",
      "umbral_confianza": 0.8,
      "requiere_confirmacion": true
    },
    "paso_6": {
      "nombre": "Guardado en BD",
      "entrada": "Datos finales (corregidos o no)",
      "salida": "Registro en huv_oncologia_NUEVO.db",
      "tiempo_estimado": "< 0.5 segundos"
    }
  },

  "archivos_json_generados": {
    "debug_maps": {
      "ubicacion": "data/debug_maps/",
      "patron_nombre": "debug_map_IHQ{numero}_{timestamp}.json",
      "proposito": "Mapeo completo del procesamiento para trazabilidad",
      "estructura": {
        "session_id": "ID único de la sesión",
        "numero_peticion": "Número IHQ",
        "timestamp": "Fecha/hora procesamiento",
        "ocr": "Texto original y consolidado + hash MD5",
        "extraccion": "Datos de cada extractor",
        "base_datos": "Datos guardados en BD",
        "validacion": "Campos vacíos/llenos, warnings, errores",
        "metricas": "Tiempos de procesamiento"
      },
      "ejemplo": "Ver data/debug_maps/debug_map_IHQ250001_20251005_143022.json"
    },
    "validaciones_ia": {
      "ubicacion": "herramientas_ia/resultados/validaciones_ia/",
      "patron_nombre": "validacion_IHQ{numero}_{timestamp}.json",
      "proposito": "Resultados de validación con IA y correcciones sugeridas",
      "estructura": {
        "numero_peticion": "Número IHQ",
        "resumen": "Estadísticas de validación",
        "discrepancias": "Lista de campos con problemas",
        "correcciones_sugeridas": {
          "criticas": "Correcciones de campos esenciales",
          "importantes": "Correcciones recomendadas",
          "opcionales": "Mejoras menores"
        },
        "campos_correctos": "Lista de campos validados OK"
      },
      "ejemplo": "Ver herramientas_ia/resultados/validaciones_ia/validacion_IHQ250001_20251005_143500.json"
    },
    "correcciones_aplicadas": {
      "ubicacion": "herramientas_ia/resultados/validaciones_ia/",
      "patron_nombre": "correcciones_aplicadas_IHQ{numero}_{timestamp}.json",
      "proposito": "Log de correcciones efectivamente aplicadas a BD",
      "cuando_se_genera": "Solo cuando se ejecuta con --aplicar-correcciones (sin --dry-run)",
      "estructura": {
        "numero_peticion": "Número IHQ",
        "dry_run": false,
        "correcciones_aplicadas": "Número de cambios",
        "cambios": [
          {
            "campo": "nombre_campo",
            "valor_anterior": "valor viejo",
            "valor_nuevo": "valor corregido",
            "criticidad": "CRITICA|IMPORTANTE|OPCIONAL",
            "confianza": 0.95
          }
        ]
      }
    }
  },

  "comandos_principales": {
    "detectar_lm_studio": {
      "comando": "python herramientas_ia/detectar_lm_studio.py --probar",
      "descripcion": "Verifica que LM Studio esté activo y funcionando",
      "salida_esperada": "✅ LM Studio DETECTADO en http://127.0.0.1:1234"
    },
    "procesar_con_debug": {
      "comando": "python core/procesamiento_con_ia.py --pdf pdfs_patologia/caso.pdf --debug",
      "descripcion": "Procesa PDF generando debug maps (sin validar con IA)",
      "archivos_generados": ["debug_map_*.json por cada caso"],
      "tiempo_estimado": "Similar al procesamiento normal (~3-5s por caso)"
    },
    "procesar_con_ia": {
      "comando": "python core/procesamiento_con_ia.py --pdf pdfs_patologia/caso.pdf --debug --validar-ia",
      "descripcion": "Procesa PDF con validación IA completa",
      "archivos_generados": ["debug_map_*.json", "validacion_*.json por cada caso"],
      "tiempo_estimado": "~30-60 segundos adicionales por caso",
      "requiere": "LM Studio activo"
    },
    "validar_caso_existente": {
      "comando": "python herramientas_ia/validador_ia.py --ihq IHQ250001 --criticos-solo",
      "descripcion": "Valida un caso ya procesado (requiere debug_map existente)",
      "archivos_generados": ["validacion_IHQ250001_*.json"],
      "tiempo_estimado": "10-30 segundos"
    },
    "aplicar_correcciones_dry_run": {
      "comando": "python herramientas_ia/validador_ia.py --ihq IHQ250001 --aplicar-correcciones --dry-run",
      "descripcion": "Simula aplicación de correcciones SIN modificar BD",
      "seguro": true,
      "recomendado": "Siempre ejecutar primero antes de aplicar de verdad"
    },
    "aplicar_correcciones_real": {
      "comando": "python herramientas_ia/validador_ia.py --ihq IHQ250001 --aplicar-correcciones",
      "descripcion": "APLICA correcciones a la BD (USAR CON PRECAUCIÓN)",
      "seguro": false,
      "requiere_confirmacion": true,
      "archivos_generados": ["correcciones_aplicadas_IHQ250001_*.json"]
    }
  },

  "casos_uso_recomendados": {
    "caso_1_nuevo_pdf": {
      "nombre": "Procesar PDF nuevo con validación IA",
      "pasos": [
        "1. Verificar LM Studio activo: python herramientas_ia/detectar_lm_studio.py --probar",
        "2. Procesar PDF: python core/procesamiento_con_ia.py --pdf nuevo.pdf --debug --validar-ia",
        "3. Revisar archivos JSON generados en data/debug_maps/ y herramientas_ia/resultados/validaciones_ia/",
        "4. Si hay correcciones sugeridas, revisarlas manualmente",
        "5. Aplicar correcciones aprobadas (dry-run primero)"
      ]
    },
    "caso_2_validar_existente": {
      "nombre": "Validar caso ya procesado",
      "pasos": [
        "1. Buscar caso en BD: python herramientas_ia/consulta_base_datos.py -b IHQ250001",
        "2. Generar debug map (si no existe): python herramientas_ia/cli_herramientas.py pdf -f original.pdf -i 250001",
        "3. Validar con IA: python herramientas_ia/validador_ia.py --ihq IHQ250001",
        "4. Revisar validacion_*.json",
        "5. Aplicar correcciones si necesario"
      ]
    },
    "caso_3_auditoria_calidad": {
      "nombre": "Auditoría de calidad de extracción",
      "pasos": [
        "1. Procesar batch de PDFs con --debug",
        "2. Validar cada caso con IA",
        "3. Consolidar reportes de validación",
        "4. Identificar patrones de error",
        "5. Mejorar patrones regex según hallazgos"
      ]
    }
  },

  "metricas_rendimiento": {
    "overhead_debug_map": "< 0.1 segundos por caso (despreciable)",
    "validacion_ia_campo": "2-5 segundos por campo",
    "validacion_ia_7_campos": "10-30 segundos",
    "validacion_ia_completa": "30-60 segundos (30+ campos)",
    "tokens_por_campo": "300-500 tokens",
    "tokens_7_campos": "2000-3000 tokens",
    "recomendacion": "Validar solo campos críticos en producción, completo en auditoría"
  },

  "ventajas_sistema": [
    "✅ 100% local - Privacidad médica garantizada",
    "✅ Trazabilidad completa - Todos los pasos en JSON",
    "✅ Validación contextual - IA entiende jerga médica",
    "✅ Correcciones inteligentes - No solo regex",
    "✅ Clasificación por criticidad - Priorizas lo importante",
    "✅ Dry-run mode - Seguridad antes de modificar BD",
    "✅ Formato JSON - Fácil integración con otros sistemas",
    "✅ Auditoría completa - Sabes exactamente qué se cambió y por qué"
  ],

  "limitaciones_conocidas": [
    "⚠️ Requiere LM Studio corriendo (overhead de RAM/CPU)",
    "⚠️ Validación IA es lenta (~30s por caso con 7 campos)",
    "⚠️ Calidad depende del modelo LLM usado",
    "⚠️ Modelo puede alucinar - revisar correcciones manualmente",
    "⚠️ No reemplaza revisión médica humana - es asistencia"
  ],

  "proximos_pasos": [
    {
      "prioridad": "ALTA",
      "tarea": "Probar con 10-20 casos reales",
      "objetivo": "Validar precisión de correcciones sugeridas"
    },
    {
      "prioridad": "ALTA",
      "tarea": "Ajustar prompts del sistema",
      "ubicacion": "core/llm_client.py - system_prompt de cada método",
      "objetivo": "Mejorar precisión médica"
    },
    {
      "prioridad": "MEDIA",
      "tarea": "Crear dashboard de validación en UI",
      "objetivo": "Visualizar correcciones y aprobar/rechazar desde interfaz"
    },
    {
      "prioridad": "MEDIA",
      "tarea": "Implementar batch processing",
      "objetivo": "Procesar múltiples PDFs con un comando"
    },
    {
      "prioridad": "BAJA",
      "tarea": "Generar reportes HTML visuales",
      "objetivo": "Reportes más amigables que JSON"
    },
    {
      "prioridad": "BAJA",
      "tarea": "Integrar con sistema de notificaciones",
      "objetivo": "Alertar cuando hay correcciones críticas"
    }
  ],

  "script_prueba_rapida": {
    "archivo": "PRUEBA_SISTEMA_IA.bat",
    "ubicacion": "raíz del proyecto",
    "descripcion": "Script interactivo para probar todo el flujo",
    "uso": "Doble click en PRUEBA_SISTEMA_IA.bat y seguir instrucciones",
    "pasos": [
      "1. Detecta LM Studio",
      "2. Permite seleccionar PDF",
      "3. Procesa con debug",
      "4. Solicita número IHQ a validar",
      "5. Valida con IA",
      "6. Muestra ubicación de archivos generados"
    ]
  },

  "soporte": {
    "documentacion_completa": "herramientas_ia/README_SISTEMA_IA.md",
    "guia_tecnica": "herramientas_ia/GUIA_TECNICA_COMPLETA.md",
    "issues": "Reportar en GitHub Issues del proyecto",
    "consultas": "Revisar archivos JSON generados primero"
  }
}
