        return 'IHQ_CK5_6'

    if 'CALPONINA' in nombre_upper:
        return 'IHQ_CALPONINA'

    # Ki-67 variantes - V5.2: CON prefijo IHQ_
    if re.match(r'KI[\s-]?67', nombre_upper):
        return 'IHQ_KI-67'

    # TTF-1 variantes - V5.2: CON prefijo IHQ_
    if re.match(r'TTF[\s-]?1', nombre_upper):
