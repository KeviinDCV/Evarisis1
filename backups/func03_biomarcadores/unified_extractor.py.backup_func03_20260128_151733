                        if ('(NUCLEAR' in valor_biomarker and '(NUCLEAR' not in (valor_existente or '')) or \
                           (tiene_porcentaje_nuevo and not tiene_porcentaje_existente):
                            es_mas_descriptivo = True
                            logger.info(f"рҹ“Ҡ V6.5.50: {new_name} biomarker_data mГЎs descriptivo: '{valor_biomarker}' vs '{valor_existente}'")
                    
                    # V6.3.87 FIX IHQ250112: Preferir valores con contexto (BLOQUE, MOSAICO, ESPESOR)
                    keywords_contexto = ['BLOQUE', 'MOSAICO', 'ESPESOR']
                    if any(kw in valor_biomarker for kw in keywords_contexto) and not any(kw in (valor_existente or '') for kw in keywords_contexto):
                        es_mas_descriptivo = True
                        logger.info(f"рҹ“Ҡ V6.3.87: {new_name} tiene contexto descriptivo: '{valor_biomarker}'")

                    # V6.4.66 FIX IHQ250204: Preferir valores con scores (parГ©ntesis con nГәmeros/+)
                    # "NEGATIVO (0)" es mГЎs descriptivo que "NEGATIVO"
                    # "EQUIVOCO (2+)" es mГЎs descriptivo que "EQUIVOCO"
                    tiene_score_nuevo = bool(re.search(r'\((?:score\s+)?[0-9]+\+?\)', valor_biomarker, re.IGNORECASE))
                    tiene_score_existente = bool(re.search(r'\((?:score\s+)?[0-9]+\+?\)', valor_existente or '', re.IGNORECASE))
                    if tiene_score_nuevo and not tiene_score_existente:
                        es_mas_descriptivo = True
                        logger.info(f"рҹ“Ҡ V6.4.66: {new_name} tiene score: '{valor_biomarker}' vs '{valor_existente}'")

                    # Solo usar si el campo no fue llenado por sistema avanzado O es mГЎs descriptivo
                    if ihq_field not in combined_data or not combined_data[ihq_field] or es_mas_descriptivo:
                        combined_data[ihq_field] = valor_biomarker
                        logger.debug(f"рҹ”¬ Refactorizado: {new_name} -> {ihq_field} = {valor_biomarker}")
            
            # V6.0.14: CORREGIDO - Mantener compatibilidad con nombres en minГәsculas
            # PERO usando valores CORRECTOS de combined_data (IHQ_*), NO de biomarker_data
            # Esto evita que valores incorrectos de extractores legacy sobrescriban valores correctos
            for new_name, old_name in biomarker_mapping.items():
                old_field = old_name.lower().replace('ihq_', '').replace('_estado', '')
                # CRГҚTICO: Usar el valor YA GUARDADO en combined_data (con prefijo IHQ_)
                # NO usar biomarker_data[new_name] que puede tener valores legacy incorrectos
                if old_name in combined_data and combined_data[old_name]:
                    combined_data[old_field] = combined_data[old_name]

            # V6.0.10: FALLBACK - Construir Factor PronГіstico desde columnas individuales si estГЎ vacГӯo
            # V6.0.12: MEJORADO - TambiГ©n detecta si estГЎ INCOMPLETO (le faltan biomarcadores)
            # V6.X.X FIX IHQ251007: NO ejecutar FALLBACK si Factor PronГіstico tiene valor narrativo vГЎlido
            # SoluciГіn para casos donde biomarcadores se extrajeron a columnas IHQ_* pero Factor PronГіstico
            # quedГі vacГӯo/NO APLICA/INCOMPLETO por problemas de formato en PDF
            factor_actual = combined_data.get('Factor pronostico', '').strip()

            # V6.X.X FIX IHQ251007: Detectar valores narrativos vГЎlidos
            # Estos NO deben ser considerados incompletos ni sobrescritos
            es_narrativo_valido = False
            if factor_actual:
                keywords_narrativo = ['inmunorreactividad', 'positividad', 'marcaciГіn', 'tinciГіn']
                es_narrativo_valido = any(kw in factor_actual.lower() for kw in keywords_narrativo)
                if es_narrativo_valido:
                    logger.info(f"вң“ Factor PronГіstico narrativo vГЎlido detectado: '{factor_actual[:50]}...'")

            # Detectar si Factor PronГіstico estГЎ incompleto
            # (le faltan biomarcadores que SГҚ estГЎn en columnas individuales)
            factor_incompleto = False
            if factor_actual and factor_actual not in ['NO APLICA', 'N/A', 'SIN DATO'] and not es_narrativo_valido:
                # Verificar si hay biomarcadores en columnas que NO estГЎn en Factor PronГіstico
                biomarcadores_en_columnas = {
                    'HER2': combined_data.get('IHQ_HER2', '').strip(),
                    'Ki-67': combined_data.get('IHQ_KI-67', '').strip(),
                    'Receptor de EstrГіgeno': combined_data.get('IHQ_RECEPTOR_ESTROGENOS', '').strip(),
                    'Receptor de Progesterona': combined_data.get('IHQ_RECEPTOR_PROGESTERONA', '').strip()
                }

                for nombre_bio, valor in biomarcadores_en_columnas.items():
                    if valor and valor not in ['', 'SIN DATO', 'NO ENCONTRADO', '.']:
                        # Biomarcador tiene valor en columna, verificar si estГЎ en Factor PronГіstico
                        if nombre_bio.upper() not in factor_actual.upper():
                            factor_incompleto = True
                            logger.info(f"рҹ”Қ FALLBACK FP: {nombre_bio} existe en columna ('{valor}') pero NO en Factor PronГіstico")
            
            if not factor_actual or factor_actual in ['NO APLICA', 'N/A', 'SIN DATO'] or factor_incompleto:
                try:
                    from core.extractors.medical_extractor import build_factor_pronostico_from_columns

                    factor_desde_columnas = build_factor_pronostico_from_columns(combined_data)

                    if factor_desde_columnas and factor_desde_columnas != 'NO APLICA':
                        if factor_incompleto:
                            logger.info(
                                f"рҹ”„ FALLBACK FP: Factor PronГіstico INCOMPLETO, reconstruyendo desde columnas individuales"
                            )
                        else:
                            logger.info(
                                f"рҹ”„ FALLBACK FP: Factor PronГіstico vacГӯo, construyendo desde columnas individuales"
                            )
                        combined_data['Factor pronostico'] = factor_desde_columnas
                        logger.info(f"вң… FALLBACK FP: Factor PronГіstico = '{factor_desde_columnas}'")

                except Exception as e:
                    logger.warning(f"вҡ пёҸ FALLBACK FP: Error al construir Factor PronГіstico desde columnas: {e}")

            # V6.0.19: REGLA 2 - Sincronizar columnas individuales con Factor PronГіstico
            # Parsear biomarcadores desde Factor PronГіstico (fuente de verdad)
            # y sobrescribir valores simplificados en columnas IHQ_*
            # V6.3.36 FIX IHQ250031: EXCEPCIГ“N para HER2 - preservar valor de biomarker_extractor
            # cuando contiene "EQUIVOCO" (valor correcto del diagnГіstico)
            if combined_data.get('Factor pronostico'):
                try:
                    from core.extractors.medical_extractor import parse_biomarkers_from_factor_pronostico

                    biomarkers_from_fp = parse_biomarkers_from_factor_pronostico(
                        combined_data['Factor pronostico']
                    )

                    # SOBRESCRIBIR valores simplificados con valores completos
                    for col_name, valor_completo in biomarkers_from_fp.items():
                        if valor_completo:
                            # V6.3.36 FIX IHQ250031: NO sobrescribir IHQ_HER2 si ya tiene valor correcto
                            # El valor correcto viene de biomarker_extractor que prioriza secciГіn DIAGNГ“STICO
                            # El Factor PronГіstico puede tener texto descriptivo de DESCRIPCIГ“N MICROSCГ“PICA
                            if col_name == 'IHQ_HER2':
                                valor_actual = combined_data.get(col_name, '').upper()
                                # Si el valor actual contiene EQUIVOCO, POSITIVO, NEGATIVO вҶ’ es correcto
                                # Si el valor de FP contiene "TINCIГ“N" o "SCORE:" вҶ’ es descripciГіn, NO sobrescribir
                                if any(kw in valor_actual for kw in ['EQUIVOCO', 'POSITIVO', 'NEGATIVO']):
                                    logger.info(
                                        f"REGLA 2: Preservando {col_name}: '{combined_data[col_name]}' "
                                        f"(valor correcto de DIAGNГ“STICO)"
                                    )
                                    continue
                                if 'TINCIГ“N' in valor_completo.upper() or ': TINCIГ“N' in valor_completo.upper():
                                    logger.info(
                                        f"REGLA 2: Ignorando valor descriptivo para {col_name}: '{valor_completo[:50]}...'"
                                    )
                                    continue

                            # V6.3.52 FIX IHQ250060: NO sobrescribir receptores hormonales si ya tienen valor normalizado
                            # El valor normalizado 'POSITIVO'/'NEGATIVO' viene de biomarker_extractor
                            # El Factor PronГіstico puede tener texto descriptivo que NO queremos
                            if col_name in ['IHQ_RECEPTOR_ESTROGENOS', 'IHQ_RECEPTOR_PROGESTERONA']:
                                valor_actual = combined_data.get(col_name, '').upper()
                                # Si el valor actual ya es POSITIVO o NEGATIVO вҶ’ preservar (ya normalizado)
                                if any(kw in valor_actual for kw in ['POSITIVO', 'NEGATIVO']):
                                    logger.info(
                                        f"REGLA 2: Preservando {col_name}: '{combined_data[col_name]}' "
                                        f"(valor normalizado de biomarker_extractor)"
                                    )
                                    continue
                                # Si el valor de FP es descriptivo (positividad, marcaciГіn) вҶ’ ignorar
                                if any(kw in valor_completo.upper() for kw in ['POSITIVIDAD', 'MARCACIГ“N', 'TINCIГ“N']):
                                    logger.info(
                                        f"REGLA 2: Ignorando valor descriptivo para {col_name}: '{valor_completo[:50]}...'"
                                    )
                                    continue

                            # V6.3.85 FIX IHQ250111: Prevent overwriting valid values with empty/dot from Factor Pronostico
                            # If we already have a value and the new one is trash, KEEP the old one.
                            existing_val = combined_data.get(col_name, '')
                            if existing_val and existing_val not in ['.', 'NO MENCIONADO', 'N/A', 'SIN DATO'] and valor_completo in ['.', '']:
                                logger.info(f"PROTECCIГ“N REGLA 2: Ignorando sobrescritura de '{existing_val}' con '{valor_completo}' para {col_name}")
                                continue

                            # Log si estamos sobrescribiendo
                            if col_name in combined_data and combined_data[col_name] != valor_completo:
                                logger.info(
                                    f"REGLA 2: Sincronizando {col_name}: "
                                    f"'{combined_data[col_name]}' вҶ’ '{valor_completo}'"
                                )
                            else:
                                logger.debug(f"REGLA 2: Estableciendo {col_name} = '{valor_completo}'")
                            combined_data[col_name] = valor_completo

                    if biomarkers_from_fp:
                        logger.info(f"вң… REGLA 2: {len(biomarkers_from_fp)} biomarcadores sincronizados desde Factor PronГіstico")

                except Exception as e:
                    logger.warning(f"вҡ пёҸ REGLA 2: Error al parsear biomarcadores desde Factor PronГіstico: {e}")

            # V6.3.36 FIX IHQ250031: REGLA 3 - Corregir Factor PronГіstico si HER2 tiene valor correcto
            # Si IHQ_HER2 contiene "EQUIVOCO" pero Factor PronГіstico tiene descripciГіn larga, corregir
            ihq_her2_valor = combined_data.get('IHQ_HER2', '').upper()
            factor_actual = combined_data.get('Factor pronostico', '')

            if 'EQUIVOCO' in ihq_her2_valor and factor_actual:
                # Verificar si Factor PronГіstico tiene texto descriptivo incorrecto de HER2
                if 'HER2:' in factor_actual.upper() or 'HER-2:' in factor_actual.upper():
                    # Buscar el valor incorrecto (descripciГіn larga)
                    # NOTA: re ya estГЎ importado al inicio del mГіdulo
                    patron_her2_fp = r'(?i)(HER\s*-?\s*2\s*:\s*)([^/,]+?)(?=\s*/|\s*,|$)'
                    match_her2_fp = re.search(patron_her2_fp, factor_actual)

                    if match_her2_fp:
                        valor_fp_her2 = match_her2_fp.group(2).strip().upper()
                        # Si el valor del FP tiene "TINCIГ“N" o "SCORE:" вҶ’ es descripciГіn incorrecta
                        if 'TINCIГ“N' in valor_fp_her2 or ': ' in valor_fp_her2:
                            # Reemplazar con valor correcto de IHQ_HER2
                            valor_correcto = combined_data.get('IHQ_HER2', 'EQUIVOCO ( Score 2+)')
                            nuevo_fp = re.sub(
                                patron_her2_fp,
                                f'HER2: {valor_correcto}',
                                factor_actual,
                                flags=re.IGNORECASE
                            )
                            combined_data['Factor pronostico'] = nuevo_fp
                            logger.info(
                                f"вң… REGLA 3: Factor PronГіstico corregido - HER2 actualizado a '{valor_correcto}'"
                            )

        # === V5.3.9: SISTEMA UNIFICADO DE CORRECCIONES ===
        from core.correction_tracker import CorrectionTracker

        # Crear tracker para acumular todas las correcciones
        tracker = CorrectionTracker()

        # Obtener nГәmero de caso para tracking
        numero_caso = combined_data.get('numero_peticion', combined_data.get('N. peticion (0. Numero de biopsia)', ''))

        # 1. CORRECCIONES ORTOGRГҒFICAS
        combined_data, correcciones_orto = correct_extracted_data(combined_data, numero_caso)
        for corr in correcciones_orto:
            tracker.add_correction(**corr)
        logger.info(f"вң… Correcciones ortogrГЎficas aplicadas: {len(correcciones_orto)}")

        # 2. VALIDACIГ“N MГүDICO-SERVICIO
        try:
            from core.validador_medico_servicio import validar_y_obtener_correccion

            corr_medico = validar_y_obtener_correccion(combined_data)
            if corr_medico:
                # Aplicar la correcciГіn a los datos
                combined_data[corr_medico["campo"]] = corr_medico["valor_corregido"]
                tracker.add_correction(**corr_medico)
                logger.info(f"вң… ValidaciГіn mГ©dico-servicio: {corr_medico['valor_original']} вҶ’ {corr_medico['valor_corregido']}")
        except Exception as e:
            logger.warning(f"вҡ пёҸ Error en validaciГіn mГ©dico-servicio: {e}")

        # 3. ALMACENAR CORRECCIONES EN METADATA
        # Las correcciones se almacenarГЎn en debug_map y se usarГЎn en ventana de resultados
        # NOTA: Esta clave temporal permite que ihq_processor.py extraiga las correcciones
        # y las pase a debug_mapper.registrar_correcciones(). Aunque parezca duplicaciГіn,
        # es el mecanismo de transporte necesario. ihq_processor hace .pop() para removerla.
        combined_data['_correcciones_aplicadas'] = tracker.get_all_corrections()

        logger.info(f"рҹ”§ Total correcciones aplicadas: {tracker.count_corrections()}")

        # === CAMPOS DE METADATA ===
        # V6.0.2: Leer versiГіn desde config/version_info.py
        try:
            from config.version_info import VERSION_INFO
            extractor_version = f"{VERSION_INFO['version']}_unified_corrections"
        except ImportError:
            extractor_version = '6.0.2_unified_corrections'  # Fallback

        combined_data.update({
            'extraction_timestamp': datetime.now().isoformat(),
            'extractor_version': extractor_version,
            'processing_method': 'modular_extractors_with_corrections'
        })

        # FIX IHQ251018: Agregar texto completo para extracciГіn alternativa de diagnГіstico
        combined_data['_full_text'] = text  # Campo interno para procesamiento posterior

        # ELIMINADO: SincronizaciГіn duplicada de columnas (inglГ©s вҶ’ espaГұol)
        # Ahora los extractores generan directamente en espaГұol:
        # - IHQ_CROMOGRANINA (no IHQ_CHROMOGRANINA)
        # - IHQ_SINAPTOFISINA (no IHQ_SYNAPTOPHYSIN)

        # V6.4.67 DEBUG: Log valor de HER2 antes de retornar
        if 'IHQ_HER2' in combined_data:
            logger.info(f"рҹ”Қ [V6.4.67 DEBUG] IHQ_HER2 final antes de retornar: {repr(combined_data['IHQ_HER2'])}")

        # V6.4.90 FIX IHQ250218: POST-FILTRO SELECTIVO - Eliminar solo CD3/BCL2 POSITIVOS de "linfocitos T acompaГұantes"
        # Problema: En linfomas B, "linfocitos T acompaГұantes CD3+, BCL2+" son cГ©lulas normales NO tumorales
        # SoluciГіn SELECTIVA: Solo eliminar si el valor es POSITIVO (viene de acompaГұantes)
        #                     Mantener si el valor es NEGATIVO (resultado tumoral real)
        # Este post-filtro se ejecuta DESPUГүS de combinar todos los extractores (centralizado)
        acompanantes_pattern = r'(?i)(?:hay\s+)?linfocitos?\s+T\s+acompa[Гұn]antes\s+(?:CD\s*3|BCL\s*2)'
        patron_encontrado = re.search(acompanantes_pattern, text)

        if patron_encontrado:
            logger.info(f"рҹ”Қ [V6.4.90 POST-FILTRO] PatrГіn 'linfocitos T acompaГұantes' detectado: '{patron_encontrado.group()}'")

            # Buscar CD3 en todas sus formas posibles
            # V6.4.90: Incluir variantes en minГәsculas (algunos extractores generan 'cd3')
            claves_cd3 = ['CD3', 'IHQ_CD3', 'cd3']
            claves_bcl2 = ['BCL2', 'IHQ_BCL2', 'bcl2']

            # V6.4.90 FIX: FILTRO SELECTIVO POR VALOR
            # Solo eliminar si el valor contiene "POSITIVO" o "+"
            # Mantener si es "NEGATIVO", "NO MENCIONADO", etc. (resultado tumoral real)

            for clave in claves_cd3:
                if clave in combined_data:
                    valor = combined_data[clave]
                    valor_upper = str(valor).upper()

                    # Criterio de eliminaciГіn: valor POSITIVO (proviene de linfocitos acompaГұantes)
                    if 'POSITIV' in valor_upper or '+' in valor:
                        valor_removido = combined_data.pop(clave)
                        logger.info(f"вҡ пёҸ [V6.4.90 POST-FILTRO SELECTIVO] {clave} removido: '{valor_removido}' (POSITIVO вҶ’ linfocitos T acompaГұantes, NO resultado tumoral)")
                    else:
                        # Mantener si es NEGATIVO o cualquier otro valor (es resultado tumoral real)
                        logger.info(f"вң… [V6.4.90 POST-FILTRO SELECTIVO] {clave} MANTENIDO: '{valor}' (NEGATIVO вҶ’ resultado tumoral real, NO acompaГұantes)")

            for clave in claves_bcl2:
                if clave in combined_data:
                    valor = combined_data[clave]
                    valor_upper = str(valor).upper()

                    # Criterio de eliminaciГіn: valor POSITIVO (proviene de linfocitos acompaГұantes)
                    if 'POSITIV' in valor_upper or '+' in valor:
                        valor_removido = combined_data.pop(clave)
                        logger.info(f"вҡ пёҸ [V6.4.90 POST-FILTRO SELECTIVO] {clave} removido: '{valor_removido}' (POSITIVO вҶ’ linfocitos T acompaГұantes, NO resultado tumoral)")
                    else:
                        # Mantener si es NEGATIVO o cualquier otro valor (es resultado tumoral real)
                        logger.info(f"вң… [V6.4.90 POST-FILTRO SELECTIVO] {clave} MANTENIDO: '{valor}' (NEGATIVO вҶ’ resultado tumoral real, NO acompaГұantes)")

        # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        # V6.5.44 FIX IHQ250242: PASE FINAL ABSOLUTO "Los demГЎs marcadores... son negativos"
        # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        # Problema: extract_narrative_biomarkers() se ejecuta DESPUГүS de extract_biomarkers()
        # y sobrescribe valores del PASE FINAL con valores de regiones secundarias
        # SoluciГіn: PASE FINAL ABSOLUTO justo antes de retornar combined_data
        # Este es el ГҡLTIMO paso y tiene PRIORIDAD MГҒXIMA sobre TODO
        # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

        try:
            # V6.5.45: Imports movidos al inicio del archivo para evitar UnboundLocalError

            final_demas_marcadores = re.finditer(
                r'(?i)Los?\s+dem[aГЎ]s\s+marcadores?\s+([A-Za-z0-9\s,./\-\(\)+yYeГүГіГ“ГЎГҒГӯГҚГәГҡГұГ‘]+?)\s+son\s+negativ[oa]s?(?:\.|$|\s+[ГҚI]ndice)',
                clean_text
            )

            for match in final_demas_marcadores:
                lista_negativos = match.group(1).strip()
                # Filtrar matches que contengan "positivo" (patrГіn genГ©rico capturando demasiado)
                if 'POSITIVO' in lista_negativos.upper():
                    continue

                logger.info(f"рҹ”ҙ [PASE FINAL ABSOLUTO v6.5.44] 'Los demГЎs marcadores' detected: '{lista_negativos[:80]}...'")

                # Procesar lista de NEGATIVOS con SOBRESCRITURA ABSOLUTA
                for bio_negativo in re.split(r'[,\s]+y\s+|\s+y\s+|,\s*', lista_negativos):
                    bio_negativo = bio_negativo.strip()
                    if bio_negativo:
                        normalized = normalize_biomarker_name(bio_negativo)
                        if normalized:
                            # Obtener definiciГіn del biomarcador
                            bio_def = BIOMARKER_DEFINITIONS.get(normalized, {})
                            tipo_valor = bio_def.get('tipo_valor', 'QUALITATIVE')

                            # Construir nombre de columna correcto
                            if tipo_valor == 'QUALITATIVE':
                                columna = f"IHQ_{normalized}_ESTADO"
                            else:
                                columna = f"IHQ_{normalized}"

                            valor_previo = combined_data.get(columna, 'N/A')
                            combined_data[columna] = 'NEGATIVO'
                            if valor_previo and valor_previo != 'N/A' and valor_previo != 'NEGATIVO':
                                logger.info(f"   рҹ”ҙ SOBRESCRITO ABSOLUTO: {columna}: {valor_previo} вҶ’ NEGATIVO (main diagnosis)")
                            else:
                                logger.info(f"   вң… Asignado: {columna} = NEGATIVO")

        except Exception as e:
            logger.warning(f"вҡ пёҸ [PASE FINAL ABSOLUTO v6.5.44] Error: {e}")

        logger.info(f"вң… ExtraГӯdos {len(combined_data)} campos con extractores refactorizados")
        return combined_data
        
    except Exception as e:
        logger.error(f"вқҢ Error en extractores refactorizados: {e}")
        import traceback
        logger.error(f"Traceback completo: {traceback.format_exc()}")

        # No hay fallback legacy disponible (core/procesador_ihq.py eliminado en v4.0)
        logger.error("вқҢ No se puede procesar el caso. Verifique los patrones de extracciГіn.")
        return {}


def process_ihq_paths(pdf_paths: List[str], output_dir: str) -> int:
    """Procesa mГәltiples PDFs usando extractores refactorizados
    
    Interfaz compatible con la funciГіn original pero implementada
    con los nuevos extractores modulares y mejor manejo de errores.
    ACTUALIZADA: Ahora procesa mГәltiples casos por PDF.
    
    Args:
        pdf_paths (List[str]): Lista de rutas de PDFs
        output_dir (str): Directorio de salida
        
    Returns:
        int: NГәmero de registros procesados exitosamente
    """
    if not pdf_paths:
        logger.warning("вҡ пёҸ No se proporcionaron PDFs para procesar")
        return 0
    
    if not EXTRACTORS_AVAILABLE:
        # Fallback a procesador antiguo
        logger.warning("вҡ пёҸ Usando procesador legacy como fallback")
        return process_ihq_paths_legacy(pdf_paths, output_dir)
    
    logger.info(f"рҹҡҖ Procesando {len(pdf_paths)} PDFs con extractores refactorizados...")
    
    processed_count = 0
    results = []
    errors = []
    
    # Crear directorio de salida si no existe
    os.makedirs(output_dir, exist_ok=True)
    
    for i, pdf_path in enumerate(pdf_paths, 1):
        try:
            logger.info(f"рҹ“„ Procesando {i}/{len(pdf_paths)}: {Path(pdf_path).name}")
            
            # Extraer texto del PDF
            try:
                # Usar OCR real del sistema existente
                from core.processors.ocr_processor import pdf_to_text_enhanced
                
                text_content = pdf_to_text_enhanced(pdf_path)
                
                # Si devuelve una lista, convertir a string
                if isinstance(text_content, list):
                    text_content = '\n'.join(text_content)
                
                if not text_content or len(text_content.strip()) < 10:
                    logger.warning(f"вҡ пёҸ PDF vacГӯo o texto insuficiente: {pdf_path}")
                    continue
                    
                logger.info(f"вң… Texto extraГӯdo: {len(text_content)} caracteres")
                
            except Exception as e:
                logger.error(f"вқҢ Error extrayendo texto de {pdf_path}: {e}")
                errors.append(f"{Path(pdf_path).name}: Error OCR - {str(e)}")
                continue
            
            # NUEVO: Segmentar texto en mГәltiples casos
            try:
                # Usar funciГіn de segmentaciГіn del OCR processor
                from core.processors.ocr_processor import segment_reports_multicase
                
                segments = segment_reports_multicase(text_content)
                logger.info(f"рҹ”Қ Encontrados {len(segments)} casos en {Path(pdf_path).name}")
                
                if not segments:
                    logger.warning(f"вҡ пёҸ No se encontraron casos en {pdf_path}")
                    continue
                    
            except Exception as e:
                logger.warning(f"вҡ пёҸ Error segmentando casos, procesando como caso Гәnico: {e}")
                segments = [text_content]  # Fallback a procesamiento Гәnico
            
            # Procesar cada caso individualmente
            pdf_case_count = 0
            for case_idx, case_text in enumerate(segments, 1):
                try:
                    if not case_text.strip():
                        continue
                    
                    logger.info(f"  рҹ“Ӣ Procesando caso {case_idx}/{len(segments)}")
                    
                    # Extraer datos estructurados del caso
                    extracted_data = extract_ihq_data(case_text)

                    if not extracted_data:
                        # Intentar extraer cГіdigo IHQ para mejor identificaciГіn
                        import re
                        ihq_match = re.search(r'IHQ[-\s]?(\d{6})', case_text)
                        case_id = ihq_match.group(0) if ihq_match else f"Caso_{case_idx}"

                        # Guardar muestra del texto para debugging (primeros 200 caracteres)
                        text_sample = case_text[:200].replace('\n', ' ').strip()

                        logger.warning(f"  вҡ пёҸ No se extrajeron datos del {case_id} (caso {case_idx})")
                        logger.debug(f"     Muestra del texto: {text_sample}...")

                        # Agregar a lista de errores para reporte final
                        errors.append(f"{Path(pdf_path).name} - {case_id}: No se pudieron extraer datos (extract_ihq_data retornГі vacГӯo)")
                        continue
                    
                    # Agregar metadatos del archivo y caso
                    extracted_data.update({
                        'archivo_pdf': Path(pdf_path).name,
                        'ruta_completa': pdf_path,
                        'fecha_procesamiento': datetime.now().isoformat(),
                        'numero_archivo': i,
                        'caso_numero': case_idx,
                        'total_casos_archivo': len(segments)
                    })
                    
                    results.append(extracted_data)
                    pdf_case_count += 1
                    
                    logger.info(f"  вң… Caso {case_idx} procesado exitosamente")
                    
                except Exception as e:
                    logger.error(f"  вқҢ Error procesando caso {case_idx}: {e}")
                    errors.append(f"{Path(pdf_path).name} - Caso {case_idx}: {str(e)}")
                    continue
            
            processed_count += pdf_case_count
            logger.info(f"вң… PDF completado: {pdf_case_count} casos extraГӯdos de {Path(pdf_path).name}")
            
        except Exception as e:
            logger.error(f"вқҢ Error procesando {pdf_path}: {e}")
            errors.append(f"{Path(pdf_path).name}: {str(e)}")
            continue
    
    # Guardar resultados si hay datos
    if results:
        try:
            # MAPEAR DATOS PARA AMBOS: EXCEL Y BASE DE DATOS
            db_records = []
            for result in results:
                db_record = map_to_database_format(result)
                db_records.append(db_record)
            
            # Crear DataFrame con datos mapeados (no crudos)
            df = pd.DataFrame(db_records)
            
            # Guardar en Excel
            excel_path = Path(output_dir) / f"resultados_ihq_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"
            df.to_excel(excel_path, index=False)
            logger.info(f"рҹ’ҫ Resultados guardados en: {excel_path}")
            
            # Guardar en base de datos
            try:
                from core.database_manager import save_records, init_db
                
                # Inicializar BD para asegurar nuevas columnas
                init_db()
                
                # Usar los mismos datos mapeados para la BD
                saved_count = save_records(db_records)
                logger.info(f"рҹ’ҫ {saved_count} registros guardados en base de datos")
                logger.info(f"рҹ’ҫ {saved_count} registros guardados en base de datos")
                
            except Exception as e:
                logger.warning(f"вҡ пёҸ No se pudo guardar en BD: {e}")
                # Continuar porque ya se guardГі en Excel
                
        except Exception as e:
            logger.error(f"вқҢ Error guardando resultados: {e}")
    
    # Reporte final
    if errors:
        error_file = Path(output_dir) / f"errores_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
        with open(error_file, 'w', encoding='utf-8') as f:
            f.write("ERRORES DE PROCESAMIENTO:\n\n")
            for error in errors:
                f.write(f"вҖў {error}\n")
        logger.warning(f"вҡ пёҸ {len(errors)} errores registrados en: {error_file}")
    
    logger.info(f"рҹҺҜ Procesamiento completado: {processed_count}/{len(pdf_paths)} archivos exitosos")
    return processed_count


def parse_estudios_table_for_organo(text: str) -> Dict[str, Any]:
    """Parsea tabla de estudios para mapear Гіrganos especГӯficos
    
    VersiГіn mejorada que usa extractores refactorizados para 
    mejor detecciГіn de Гіrganos y diagnГіsticos.
    
    Args:
        text (str): Texto completo del informe
        
    Returns:
        Dict[str, Any]: Mapeo de Гіrganos detectados
    """
    if not text or not text.strip():
        return {}
    
    if not EXTRACTORS_AVAILABLE:
        # Fallback a funciГіn antigua
        logger.warning("вҡ пёҸ Usando parser legacy para Гіrganos")
        return parse_estudios_table_for_organo_legacy(text)
    
    try:
        # Limpiar texto
        clean_text = clean_text_comprehensive(text)
        
        # TODO: Implementar detector de Гіrganos con extractores refactorizados
        # Por ahora, usar lГіgica bГЎsica mejorada
        
        organos_detectados = {}
        
        # Patrones bГЎsicos de Гіrganos comunes
        organ_patterns = {
            'mama': ['mama', 'breast', 'mamario', 'mamaria'],
            'pulmon': ['pulmГіn', 'pulmonar', 'lung', 'bronquio'],
            'colon': ['colon', 'colorrectal', 'intestino'],
            'prostata': ['prГіstata', 'prostate', 'prostГЎtico'],
            'estomago': ['estГіmago', 'gГЎstrico', 'stomach'],
            'higado': ['hГӯgado', 'hepГЎtico', 'liver'],
            'pancreas': ['pГЎncreas', 'pancreГЎtico', 'pancreas'],
            'ovario': ['ovario', 'ovГЎrico', 'ovarian'],
            'utero': ['Гәtero', 'uterino', 'endometrio'],
            'riГұon': ['riГұГіn', 'renal', 'kidney'],
            'vejiga': ['vejiga', 'vesical', 'bladder'],
            'tiroides': ['tiroides', 'tiroideo', 'thyroid']
        }
        
        text_lower = clean_text.lower()
        
        for organo, keywords in organ_patterns.items():
            for keyword in keywords:
                if keyword in text_lower:
                    organos_detectados[organo] = {
                        'detectado': True,
                        'keyword_usado': keyword,
                        'confianza': 0.8  # Confianza bГЎsica
                    }
                    break
        
        if organos_detectados:
            logger.info(f"рҹҺҜ Detectados Гіrganos: {list(organos_detectados.keys())}")
        
        return organos_detectados
        
    except Exception as e:
        logger.error(f"вқҢ Error en parser de Гіrganos: {e}")
        # Fallback a funciГіn antigua
        return parse_estudios_table_for_organo_legacy(text)


