    Convierte los datos extraГӯdos por los nuevos extractores al formato
    esperado por database_manager.save_records()
    """
    if not extracted_data:
        return {}
    
    # Crear mapeo bГЎsico usando los datos disponibles
    db_record = {}
    
    # === DATOS BГҒSICOS DE IDENTIFICACIГ“N ===
    # v5.3.6: CORREGIDO - Renombrado a "Numero de caso"
    db_record["Numero de caso"] = extracted_data.get('numero_peticion', '')
