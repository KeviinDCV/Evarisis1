def extract_diagnostico_principal(diagnostico_completo: str, full_text: str = '') -> str:
    """
    Extrae el diagnГіstico principal del texto completo de diagnГіstico.

    V6.0.9: LIMPIEZA CRГҚTICA - Elimina datos del estudio M (GRADO, SCORE, NOTTINGHAM)
    para mantener DIAGNOSTICO_PRINCIPAL limpio (solo IHQ).

    V6.2.0 (FIX IHQ251018): Si diagnostico_completo estГЎ vacГӯo o es muy corto,
    intenta extraer desde full_text usando extract_principal_diagnosis()

    V6.2.7 (FIX IHQ251018): PRIORIDAD ALTA - Buscar en full_text PRIMERO para casos
    de patologГӯa renal con "LOS HALLAZGOS MORFOLГ“GICOS..." en pГЎgina 2

    ESTRATEGIA PRINCIPAL: Capturar la primera lГӯnea DESPUГүS de:
    - "Estudios de inmunohistoquГӯmica."
    - "Biopsia con aguja gruesa."
    - O similar marcador de inicio de resultados

    IMPORTANTE: NO incluye datos del estudio M:
    - NO captura: GRADO HISTOLГ“GICO, SCORE, NOTTINGHAM
    - NO captura: INVASIГ“N LINFOVASCULAR/PERINEURAL
    - NO captura: IN SITU, etc.

    Args:
        diagnostico_completo: Texto completo del diagnГіstico
        full_text: Texto completo del caso (opcional, para bГәsqueda alternativa)

    Returns:
        str: DiagnГіstico principal extraГӯdo o cadena vacГӯa (SIN datos del estudio M)

    Ejemplo:
        Input: "Estudios de inmunohistoquГӯmica. - CARCINOMA MICROPAPILAR, INVASIVO GRADO HISTOLOGICO: 1 (SCORE 3/9)"
        Output: "CARCINOMA MICROPAPILAR, INVASIVO" (sin GRADO ni SCORE)
    """
    # Si no hay diagnГіstico completo, intentar con full_text como FALLBACK
    if not diagnostico_completo or diagnostico_completo in ['N/A', '']:
        if full_text:
            diag_from_full_text = extract_principal_diagnosis(full_text)
            if diag_from_full_text and len(diag_from_full_text) > 20:
                return diag_from_full_text
        return ''

    # Limpiar texto
    texto = diagnostico_completo.strip()

    # ESTRATEGIA 0 (MГҒXIMA PRIORIDAD): V6.1.2 - Tumores malignos indiferenciados (IHQ250997)
    # Formato: "TUMOR MALIGNO INDIFERENCIADO A CARACTERIZAR MEDIANTE... NECROSIS TUMORAL PRESENTE"
    # DEBE ejecutarse ANTES de ESTRATEGIA 1 para evitar capturar "Reporte preliminar"
    patron_tumor_indiferenciado = r'(?i)(TUMOR\s+MALIGNO\s+INDIFERENCIADO\s+A\s+CARACTERIZAR.+?NECROSIS\s+TUMORAL\s+PRESENTE)'
    match_indiferenciado = re.search(patron_tumor_indiferenciado, texto, re.IGNORECASE | re.DOTALL)
    if match_indiferenciado:
        diagnostico = match_indiferenciado.group(1).strip()
        # Limpiar saltos de lГӯnea mГәltiples
        diagnostico = ' '.join(diagnostico.split())
        diagnostico = diagnostico.upper().rstrip('.')
        return diagnostico

    # ESTRATEGIA 0.5 (ALTA PRIORIDAD): V6.0.10 - DiagnГіstico FINAL despuГ©s de "ExpansiГіn" (IHQ251002)
    # Formato: "DIAGNГ“STICO\nFГ©mur derecho. Tumor. Biopsia... ExpansiГіn.\nSARCOMA FUSOCELULAR INDIFERENCIADO."
    # Este patrГіn detecta el diagnГіstico DEFINITIVO que viene despuГ©s de la secciГіn "ExpansiГіn"
    # DEBE ejecutarse ANTES de ESTRATEGIA 1 para tener prioridad sobre diagnГіsticos preliminares
    patron_expansion = r'Expansi[Гіo]n\.\s*([A-ZГҒГүГҚГ“ГҡГ‘][^.]+?)\.'
    match_expansion = re.search(patron_expansion, texto, re.IGNORECASE)
    if match_expansion:
        diagnostico = match_expansion.group(1).strip()
        # Verificar que no sea texto descriptivo (debe ser diagnГіstico real)
        if not any(kw in diagnostico.upper() for kw in ['RECEPTOR', 'POSITIVO', 'NEGATIVO', 'COMENTARIO', 'ESTUDIO']):
            # Limpiar y normalizar
            diagnostico = ' '.join(diagnostico.split())
            diagnostico = diagnostico.upper().rstrip('.')
            return diagnostico

    # ESTRATEGIA 1 (PRIORITARIA): Buscar despuГ©s de marcadores clave
    # Marcadores que indican el inicio de los resultados de diagnГіstico
    # V4.2.10: Soportar ":" ademГЎs de "." (IHQ250995: "Estudios de inmunohistoquГӯmica:")
    marcadores = [
        r'Estudios de inmunohistoqu[iГӯ]mica[\.:]\s*',
        r'Biopsia con aguja gruesa\.',
        r'Estudio de inmunohistoqu[iГӯ]mica[\.:]\s*',
        r'Biopsia\.',
        r'Muestra\.',
    ]

    for marcador in marcadores:
        # Buscar el marcador en el texto
        match_marcador = re.search(marcador, texto, re.IGNORECASE)
        if match_marcador:
            # Extraer el texto DESPUГүS del marcador
            texto_despues = texto[match_marcador.end():].strip()

            # La primera lГӯnea despuГ©s del marcador (hasta el primer salto de lГӯnea o punto seguido de guiГіn)
            # V6.0.9: PATRГ“N MEJORADO - NO capturar datos del estudio M (GRADO, SCORE, etc.)
            # Captura hasta encontrar: punto, salto de lГӯnea, o keywords del estudio M
            # V6.4.2: NO truncar aquГӯ por SCORE/NOTTINGHAM, se harГЎ en la limpieza posterior (IHQ250119)
            patron_primera_linea = r'^[^\n]*?-?\s*([^.\n]+?)(?:VER COMENTARIO|\.|$)'
            match_linea = re.search(patron_primera_linea, texto_despues, re.IGNORECASE)

            if match_linea:
                diagnostico = match_linea.group(1).strip()
                # Limpiar guiones adicionales
                diagnostico = diagnostico.rstrip('-.').strip()

                # V6.1.2: Descartar "Reporte preliminar" y buscar en lГӯneas siguientes (IHQ250997)
                if 'REPORTE PRELIMINAR' in diagnostico.upper():
                    # Buscar la siguiente lГӯnea significativa
                    lineas = texto_despues.split('\n')
                    for linea in lineas[1:]:  # Saltar primera lГӯnea (Reporte preliminar)
                        linea = linea.strip()
                        if linea and len(linea) > 20 and not linea.startswith('-'):
                            # Verificar que no sea descripciГіn
                            if not any(kw in linea.upper() for kw in ['RECEPTOR', 'POSITIVO', 'NEGATIVO']):
                                return linea.upper()

                # V6.0.9: LIMPIEZA CRГҚTICA - Eliminar datos del estudio M (IHQ250981)
                # Keywords que indican datos del estudio M que NO deben estar en DIAGNOSTICO_PRINCIPAL
                keywords_estudio_m = [
                    'GRADO HISTOLOGICO', 'GRADO HISTOLГ“GICO',
                    'SCORE', 'NOTTINGHAM',
                    'INVASIГ“N LINFOVASCULAR', 'INVASION LINFOVASCULAR',
                    'INVASIГ“N PERINEURAL', 'INVASION PERINEURAL',
                    'IN SITU', 'DUCTAL IN SITU', 'LOBULAR IN SITU'
                ]

                # Detener diagnГіstico ANTES del primer keyword del estudio M
                for keyword in keywords_estudio_m:
                    if keyword in diagnostico.upper():
                        # V6.4.2 FIX IHQ250119: Solo truncar si el keyword NO parece ser parte de un valor asignado (ej: HER2: SCORE)
                        # Buscamos el keyword con word boundaries y que NO tenga ": " antes
                        pattern_trunc = rf'(?<!:\s)\b{keyword}\b'
                        match_trunc = re.search(pattern_trunc, diagnostico.upper())
                        if match_trunc:
                            pos = match_trunc.start()
                            diagnostico = diagnostico[:pos].strip()
                            # Limpiar trailing punctuation
                            diagnostico = diagnostico.rstrip(',:;-').strip()
                            break

                # V6.0.2: Detener ANTES de primer guion en nueva lГӯnea (CRГҚTICO IHQ250981)
                # Buscar patrГіn: salto de lГӯnea seguido de guion (lista de atributos adicionales)
                match_first_dash = re.search(r'\n\s*-', diagnostico)
                if match_first_dash:
                    diagnostico = diagnostico[:match_first_dash.start()].strip()
                # Alternativamente, si hay " - " en la misma lГӯnea
                elif ' - ' in diagnostico:
                    # V6.x.x FIX IHQ250118: Solo separar si NO parece ser parte de un tГ©rmino mГ©dico (guiГіn corto)
                    # Ej: TГҡBULO - INTERSTICIAL no debe separar si hay espacio alrededor del guiГіn
                    # Pero si es " - ARTERIOPATIA" (nueva secciГіn), sГӯ debe separar.
                    if re.search(r'\s+-\s+[A-ZГҒГүГҚГ“ГҡГ‘]{4,}', diagnostico):
                        # Si es un tГ©rmino conocido con guiГіn, NO separar
                        if not re.search(r'(?:T[UГҡ]BULO|INTERSTICIAL|ESCAMO|CELULAR|NEURO)\s+-\s+', diagnostico, re.IGNORECASE):
                             parts = diagnostico.split(' - ')
                             diagnostico = parts[0].strip()

                # Convertir a mayГәsculas si tiene suficiente contenido en mayГәsculas
                palabras_mayus = sum(1 for p in diagnostico.split() if p.isupper())
                if palabras_mayus >= 2:
                    return diagnostico.upper()
                return diagnostico

    # ESTRATEGIA 2: Buscar texto entre guiones (- DIAGNГ“STICO -)
    # V6.x.x FIX IHQ250118: Permitir guiones internos y multilГӯnea hasta el punto
    patron_guiones = r'-\s*([A-ZГҒГүГҚГ“ГҡГ‘][^.]+?)(?:\s+-\s*|\.|$)'
    matches_guiones = re.findall(patron_guiones, texto, re.DOTALL)

    if matches_guiones:
        # Tomar el primer match que NO sea descriptor de biomarcadores
        for diagnostico in matches_guiones:
            diagnostico = diagnostico.strip().rstrip('.')
            # Saltar si es descripciГіn de receptores/biomarcadores
            if not any(kw in diagnostico.upper() for kw in ['RECEPTOR', 'ESTUDIO', 'BIOPSIA', 'MUESTRA', 'POSITIVO', 'NEGATIVO']):
                return diagnostico

    # ESTRATEGIA 3: Buscar frases "LOS HALLAZGOS FAVORECEN/SON COMPATIBLES CON..." (v6.0.5)
    # V6.0.12: MEJORADO - "UNA/UN" es opcional (IHQ250988: "FAVORECEN LINFOMA...")
    # V6.0.17: MEJORADO - Incluye "SON COMPATIBLES CON" (IHQ250992: "SON COMPATIBLES CON NEOPLASIA...")
    # V6.2.2: MEJORADO - "LOS" y "SON" son opcionales (IHQ251012: "HALLAZGOS ... COMPATIBLES CON TIMOMA AB")
    # PatrГіn: "[LOS] HALLAZGOS ... [FAVORECEN|[SON] COMPATIBLES CON] [UNA/UN] ..."
    patron_hallazgos = r'(?:LOS\s+)?HALLAZGOS[^.]*?(?:FAVORECEN\s+(?:UNA\s+|UN\s+)?|(?:SON\s+)?COMPATIBLES CON\s+(?:UNA\s+|UN\s+)?)([^.]+?)(?:\.|VER COMENTARIO|TAMAГ‘O|$)'
    match_hallazgos = re.search(patron_hallazgos, texto, re.IGNORECASE)
    if match_hallazgos:
        diagnostico = match_hallazgos.group(1).strip().upper()
        # Limpiar "VER COMENTARIO" si quedГі
        diagnostico = re.sub(r'\s*VER COMENTARIO.*$', '', diagnostico, flags=re.IGNORECASE).strip()
        # V6.0.12: Limpiar calificadores adicionales que contaminan (IHQ250988)
        # Eliminar "SOBREEXPRESIГ“N DE P53 (MUTADO)" y similares
        diagnostico = re.sub(r'\s*SOBREEXPRESI[Г“O]N\s+DE\s+P\d+.*$', '', diagnostico, flags=re.IGNORECASE).strip()
        # V6.2.2: Limpiar "TAMAГ‘O TUMORAL" y datos posteriores (IHQ251012)
        diagnostico = re.sub(r'\s*TAMAГ‘O\s+TUMORAL.*$', '', diagnostico, flags=re.IGNORECASE).strip()
        return diagnostico

    # ESTRATEGIA 4: Buscar diagnГіsticos patolГіgicos al inicio
    patron_inicio = r'^\s*((?:CARCINOMA|ADENOCARCINOMA|LINFOMA|SARCOMA|MELANOMA|GLIOMA|MENINGIOMA|METASTASIS|TUMOR|NEOPLASIA)[^.]+?)(?:\.|$)'
    match_inicio = re.search(patron_inicio, texto, re.IGNORECASE)
    if match_inicio:
        diagnostico = match_inicio.group(1).strip().upper()
        if not any(kw in diagnostico for kw in ['RECEPTOR', 'POSITIVO', 'NEGATIVO', 'HER', 'KI-67', 'ESTUDI']):
            return diagnostico

    # ESTRATEGIA 5: Buscar patrones comunes de diagnГіstico
    patrones_diagnostico = [
        r'((?:CARCINOMA|ADENOCARCINOMA|LINFOMA|SARCOMA|MELANOMA|GLIOMA|MENINGIOMA|METASTASIS)[^.]+?)(?:\.|$)',
        r'((?:TUMOR|NEOPLASIA|LESION)[^.]+?(?:MALIGNO|BENIGNO|INVASIVO)[^.]*?)(?:\.|$)',
    ]

    for patron in patrones_diagnostico:
        match = re.search(patron, texto, re.IGNORECASE)
        if match:
            diagnostico = match.group(1).strip().lstrip('-').strip()
            if not diagnostico.isupper():
                diagnostico = diagnostico.upper()
            if not any(kw in diagnostico for kw in ['RECEPTOR', 'POSITIVO', 'NEGATIVO', 'HER', 'KI-67']):
                return diagnostico

    # Si no se puede extraer nada especГӯfico, devolver vacГӯo
    return ''


def limpiar_diagnostico(diagnostico: str) -> str:
    """
    Limpia frases introductorias de cualquier diagnГіstico.

    V6.3.3: FIX IHQ250005 - Elimina frases como "LOS HALLAZGOS... SON COMPATIBLES CON"
    Aplica tanto a DIAGNOSTICO_COLORACION como DIAGNOSTICO_PRINCIPAL.

    Args:
        diagnostico: DiagnГіstico extraГӯdo

    Returns:
        DiagnГіstico limpio sin frases introductorias
    """
    if not diagnostico:
        return diagnostico

    # Normalizar espacios y saltos de lГӯnea
    diagnostico = ' '.join(diagnostico.split()).upper()

    # V6.4.29 FIX IHQ250163: Limpiar fechas al inicio (ej: ": 12/02/2025")
    # Formato: ": DD/MM/AAAA" o similar al inicio del diagnГіstico
    diagnostico = re.sub(r'^:\s*\d{1,2}/\d{1,2}/\d{4}\s+', '', diagnostico)

    # V6.4.95 FIX IHQ250224: Limpiar metadatos del estudio IHQ al inicio
    # Formato: "ESTUDIO DE INMUNOHISTOQUIMICA (LГҒMINA X): DD/MM/AAAA"
    # Ejemplo: "ESTUDIO DE INMUNOHISTOQUIMICA (LГҒMINA A): 03/03/2025 ADENOCARCINOMA GLEASON"
    # Resultado: "ADENOCARCINOMA GLEASON"
    diagnostico = re.sub(
        r'^ESTUDIO\s+DE\s+INMUNOHISTOQU[ГҚI]MICA\s+\(L[ГҒA]MINA\s+[A-Z]+\)(?::\s*(?:\d{1,2}/\d{1,2}/\d{4})?)?\s+',
        '',
        diagnostico,
        flags=re.IGNORECASE
    )

    # V6.3.91: Limpiar comillas (incluyendo inteligentes) y prefijos de propiedad
    diagnostico = re.sub(r'^["\'\u201c\u201d\s]+', '', diagnostico)
    diagnostico = re.sub(r'["\'\u201c\u201d\s]+$', '', diagnostico)
    diagnostico = re.sub(r'^(?:DIAGN[Г“O]STICO\s+)?DE\s+', '', diagnostico, flags=re.IGNORECASE)

    # Eliminar frases introductorias comunes
    frases_introductorias = [
        r'^LOS\s+HALLAZGOS\s+HISTOL[Г“O]GICOS\s+SON\s+COMPATIBLES\s+CON\s+',
        r'^LOS\s+HALLAZGOS\s+SON\s+COMPATIBLES\s+CON\s+',
        r'^LOS\s+HALLAZGOS\s+MORFOL[Г“O]GICOS\s+(?:SON\s+)?COMPATIBLES\s+CON\s+',
        r'^LOS\s+HALLAZGOS\s+FAVORECEN\s+(?:UN\s+)?',
        r'^HALLAZGOS\s+MORFOL[Г“O]GICOS\s+Y\s+DE\s+INMUNOHISTOQU[ГҚI]MICA\s+COMPATIBLES\s+CON\s+',  # V6.5.26 FIX IHQ250237
        r'^HALLAZGOS\s+COMPATIBLES\s+CON\s+',
        r'^HALLAZGOS\s+FAVORECEN\s+',
        r'^COMPATIBLE\s+CON\s+',
        r'^COMPATIBLES\s+CON\s+',
    ]

    for patron in frases_introductorias:
        diagnostico_limpio = re.sub(patron, '', diagnostico, flags=re.IGNORECASE)
        if diagnostico_limpio != diagnostico:
            diagnostico = diagnostico_limpio.strip()

    # V6.3.26: FIX IHQ250024 - Eliminar metadatos del estudio M (NOTTINGHAM, GRADO)
    metadatos_estudio_m = [
        r'\s+GRADO\s+HISTOL[Г“O]GICO\s+\d+.*$',
        r'\s+\(NOTTINGHAM\s+\d+/\d+\s+PUNTOS\).*$',
        r'\s+NOTTINGHAM\s+\d+/\d+\s+PUNTOS.*$',
    ]

    for patron in metadatos_estudio_m:
        diagnostico = re.sub(patron, '', diagnostico, flags=re.IGNORECASE).strip()

    # Limpiar comillas finales de nuevo tras remociГіn de frases
    diagnostico = re.sub(r'["\'\u201c\u201d\s]+$', '', diagnostico)

    # Limpiar puntos finales
    diagnostico = diagnostico.rstrip('.')

    # V6.4.29 FIX IHQ250163: Limpiar factores pronГіsticos al final
    # Ej: "... PATRON MICROSATELITAL ESTABLE HER-2 NEGATIVO (" вҶ’ "... PATRON MICROSATELITAL ESTABLE"
    # Factores pronГіsticos comunes: HER-2, HER2, Ki-67, RE, RP
    factores_pronosticos = [
        r'\s+HER-?2[:\s]*(NEGATIVO|POSITIVO|EQUIVOCO)(?:\s+\([^)]*\))?(?:\s*\(.*)?$',
        r'\s+KI-?67[:\s]*\d+%(?:\s*\(.*)?$',
        r'\s+RE[:\s]*(NEGATIVO|POSITIVO)(?:\s*\(.*)?$',
        r'\s+RP[:\s]*(NEGATIVO|POSITIVO)(?:\s*\(.*)?$',
    ]

    for patron in factores_pronosticos:
        diagnostico = re.sub(patron, '', diagnostico, flags=re.IGNORECASE).strip()

    # V6.4.29 FIX IHQ250163: Limpiar parГ©ntesis colgantes al final
    # Ej: "DIAGNOSTICO (" вҶ’ "DIAGNOSTICO"
    diagnostico = re.sub(r'\s*\(\s*$', '', diagnostico).strip()

    # V6.3.31: FIX IHQ250030 - Detectar metadata del estudio
    patron_metadata_estudio = r'^[A-ZГҒГүГҚГ“ГҡГ‘\s\.]+(?:BIOPSIA|MUESTRA).*ESTUDIO\s+DE\s+INMUNOHISTOQU[ГҚI]MICA:\s*-?\s*EXPRESI[Г“O]N\s+DE.*(?:NEGATIVA|POSITIVA)$'
    if re.match(patron_metadata_estudio, diagnostico, re.IGNORECASE):
        return None

    # V6.3.61 FIX IHQ250075: Caso especГӯfico Peritonitis
    match_peritonitis = re.match(r'(PERITONITIS\s+AGUDA\s+Y\s+CR[Г“O]NICA)(?:,|\.\s*GRUPOS)', diagnostico)
    if match_peritonitis:
        diagnostico = match_peritonitis.group(1)

    return diagnostico


def extract_ihq_data(text: str) -> Dict[str, Any]:
    """Extrae datos IHQ de texto usando extractores refactorizados
    
    Interfaz compatible con la funciГіn original pero implementada
    con los nuevos extractores modulares.
    
    Args:
        text (str): Texto a procesar
        
    Returns:
        Dict[str, Any]: Datos extraГӯdos en formato compatible
    """
    if not text or not text.strip():
        return {}
    
    if not EXTRACTORS_AVAILABLE:
        # No hay fallback legacy disponible (core/procesador_ihq.py eliminado en v4.0)
        logger.error("вқҢ Extractores refactorizados no disponibles y no hay fallback legacy")
        logger.error("вқҢ core/procesador_ihq.py no existe (eliminado en refactorizaciГіn v4.0)")
        return {}
    
    try:
        # CORREGIDO: NO limpiar el texto aquГӯ, los extractores lo hacen internamente
        clean_text = text  # No usar clean_text_comprehensive aquГӯ

        # Extraer datos con nuevos extractores COMPLETOS
        patient_data = extract_patient_data(clean_text)
        biomarker_data = extract_biomarkers(clean_text)
        medical_data = extract_medical_data(clean_text)  # NUEVO: Datos mГ©dicos

        # V6.1.6 FIX CRГҚTICO: Inicializar combined_data ANTES de usarlo en narrative_list
        combined_data = {}

        # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        # V6.0.3: EXTRACCIГ“N NARRATIVA COMPLEMENTARIA (IHQ250982)
        # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        # Extrae biomarcadores en formato narrativo que no fueron capturados
        # por extract_biomarkers() (patrones estructurados estГЎndar)
        try:
            # Extraer secciГіn DESCRIPCIГ“N MICROSCГ“PICA para anГЎlisis narrativo
            descripcion_microscopica = medical_data.get('descripcion_microscopica', '') or \
                                       medical_data.get('descripcion_microscopica_final', '')

            # V6.5.08 FIX IHQ250231: FALLBACK - Si descripcion_microscopica estГЎ vacГӯa, usar OCR completo
            # Problema: extract_medical_data a veces falla en capturar la descripciГіn microscГіpica
            # SoluciГіn: Usar clean_text como fallback para no perder biomarcadores crГӯticos
            if not descripcion_microscopica:
                logger.warning("вҡ пёҸ DESCRIPCION_MICROSCOPICA vacГӯa, usando OCR completo como fallback")
                descripcion_microscopica = clean_text

            if descripcion_microscopica:
                # Listas simples: "son positivas para CKAE1E3, CK7 Y CAM 5.2"
                narrative_list = extract_narrative_biomarkers_list(descripcion_microscopica, BIOMARKER_DEFINITIONS)

                if narrative_list:
                    logger.info(f"рҹ§¬ V6.0.3: Detectados {len(narrative_list)} biomarcadores narrativos adicionales")
                    # V6.1.6: DEBUG IHQ251007 - Log completo de narrative_list recibido
                    logger.info(f"рҹ“Ӣ narrative_list recibido: {narrative_list}")

                    # V6.X.X FIX IHQ251007: Guardar directamente en combined_data
                    # narrative_list ya tiene prefijo IHQ_, guardar directo evita problemas de mapeo
                    for columna, valor in narrative_list.items():
                        # V6.3.88 FIX IHQ250113: Remapeo explГӯcito de claves cortas a largas
                        if columna == 'IHQ_ER': columna = 'IHQ_RECEPTOR_ESTROGENOS'
                        if columna == 'IHQ_PR': columna = 'IHQ_RECEPTOR_PROGESTERONA'

                        # V6.5.23 FIX IHQ250237: Extractor narrativo tiene PRIORIDAD sobre extract_biomarkers()
                        # RazГіn: Patrones narrativos (especialmente mixtos v6.5.20) son mГЎs contextuales y precisos
                        # que patrones estructurados que pueden capturar de listas de estudios solicitados
                        # SIEMPRE sobrescribir si el valor es diferente
                        valor_previo = biomarker_data.get(columna)
                        if columna not in biomarker_data or biomarker_data[columna] in ('N/A', '', None):
                            biomarker_data[columna] = valor
                            logger.info(f"   вң“ Guardado en biomarker_data: {columna} = {valor}")
                        elif valor_previo != valor:
                            # Valor diferente - narrativo SOBRESCRIBE (tiene prioridad contextual)
                            logger.warning(f"   рҹ”„ SOBRESCRIBIENDO en biomarker_data: {columna} = {valor_previo} вҶ’ {valor} (narrativo tiene prioridad)")
                            biomarker_data[columna] = valor

                        # V6.X.X FIX: TambiГ©n guardar directamente en combined_data
                        # V6.5.23: SIEMPRE sobrescribir si valor es diferente (narrativo tiene prioridad)
                        valor_previo_combined = combined_data.get(columna)
                        if columna not in combined_data or combined_data[columna] in ('N/A', '', None, 'NO MENCIONADO'):
                            combined_data[columna] = valor
                            logger.info(f"   вң… Guardado en combined_data: {columna} = {valor} (narrativo directo)")
                        elif valor_previo_combined != valor:
                            # Valor diferente - narrativo SOBRESCRIBE
                            logger.warning(f"   рҹ”„ SOBRESCRIBIENDO en combined_data: {columna} = {valor_previo_combined} вҶ’ {valor} (narrativo tiene prioridad)")
                            combined_data[columna] = valor
                        else:
                            logger.info(f"   вң“ Ya existe con mismo valor: {columna} = {valor}")
        except Exception as e:
            logger.warning(f"вҡ пёҸ Error en extracciГіn narrativa: {e}")

        # Combinar y mapear al formato esperado por ui.py
        # V6.1.6 FIX: combined_data ya estГЎ inicializado en lГӯnea 386, NO sobrescribir
        # combined_data = {}  # REMOVIDO: sobrescribГӯa valores narrativos guardados

        # === DATOS DE PACIENTE ===
        if patient_data:
            # Campos bГЎsicos de identificaciГіn
            combined_data.update({
                'nombre_completo': patient_data.get('nombre_completo', ''),
                'numero_peticion': patient_data.get('numero_peticion', ''),
                # CORREGIDO v4.2: Priorizar identificacion_numero (solo dГӯgitos) sobre identificacion_completa
