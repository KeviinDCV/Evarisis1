    db_record["Tipo de documento"] = extracted_data.get('tipo_documento', 'CC')
    
    # === NOMBRES Y APELLIDOS ===
    # v5.3.2: SIMPLIFICADO - Usar campos ya calculados por extract_ihq_data()
