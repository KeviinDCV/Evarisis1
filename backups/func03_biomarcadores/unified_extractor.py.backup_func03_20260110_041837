    #     'IHQ_CKAE1AE3': ['IHQ_CKAE1E3'],
    # }

    # SKIP - no hay alias_sync
    if False:  # Placeholder para mantener indentación del código siguiente
        if False:
                    db_record[col_alias] = valor_principal
                    logger.debug(f"🔄 Sync alias: {col_alias} = {valor_principal} (desde {col_principal})")

    # FIX IHQ251018: Eliminar campos internos (que empiezan con _) antes de retornar
    db_record = {k: v for k, v in db_record.items() if not k.startswith('_')}

    return db_record


def map_to_excel_format(extracted_data: Dict[str, Any]) -> List[Dict[str, str]]:
    """Mapea los datos extraídos al formato final de base de datos HUV

    CORREGIDO v4.1: Usar map_to_database_format para mapeo completo
    """
    if not extracted_data:
        return []

    # CORREGIDO: Usar map_to_database_format que tiene TODOS los mapeos correctos
    db_record = map_to_database_format(extracted_data)

    return [db_record]


