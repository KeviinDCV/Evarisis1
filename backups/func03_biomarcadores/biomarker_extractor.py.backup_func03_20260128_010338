    marcacion_list_pattern = r'(?i)(?:presentan\s+)?marcaci[Гіo]n\s+(positiva|negativa)\s+para[:\s]+(.+?)(?=,\s*Con\s+marcaci[oГі]n|\s+Linfocitos|\s+ademГЎs|\.\s*(?:En|A\d+\.|Negativ)|\.\s+[A-Z]|$)'
    for match in re.finditer(marcacion_list_pattern, text, re.DOTALL):
