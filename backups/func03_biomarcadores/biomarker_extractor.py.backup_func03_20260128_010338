        r'(?i)positiv[oa]s?\s+para:\s+(.+?)(?:\.\s|\s+con\s+una|\s+las\s+cГ©lulas)',

        # V6.4.47 FIX IHQ250185: PRIORIDAD MГЃXIMA - "son negativos para: [lista]" con DOS PUNTOS
