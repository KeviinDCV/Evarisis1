def extract_molecular_expression_section(text: str) -> str:
    """Extrae la secciГіn EXPRESIГ“N MOLECULAR del texto (PRIORIDAD MГЃXIMA)

    v6.0.2: NUEVO - Prioriza secciГіn "ExpresiГіn molecular" sobre descripciГіn microscГіpica (IHQ250981)

    Args:
        text: Texto completo del informe

    Returns:
        Texto de la secciГіn "ExpresiГіn molecular", o string vacГ­o si no se encuentra
    """
    if not text:
        return ''

    # PatrГіn para identificar "ExpresiГіn molecular:"
    pattern = r'Expresi[Гіo]n\s+molecular\s*:\s*(.*?)(?=\n\n|Nota:|NANCY|ARMANDO|CARLOS|M[Г‰E]dica?\s+Pat[Гіo]log|$)'
    match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)

    if match:
        return match.group(1).strip()

    return ''


def extract_report_section(text: str) -> str:
    """Extrae la secciГіn REPORTE DE BIOMARCADORES del texto

    v5.3.1: NUEVO - Prioriza resultados sobre descripciГіn de anticuerpos

    Args:
        text: Texto completo del informe

    Returns:
        Texto de la secciГіn de reporte, o string vacГ­o si no se encuentra
    """
    if not text:
        return ''

    # V6.4.8: Agregado "RESULTADO" simple para casos como IHQ250136
    report_start_patterns = [
        r'REPORTE\s+DE\s+BIOMARCADORES\s*:?',
        r'RESULTADOS?\s*:', # IHQ250136
        r'RESULTADOS?\s+(?:DE\s+)?INMUNOHISTOQU[ГЌI]MICA',
        r'RESULTADOS?\s+(?:DE\s+)?IHQ',
        r'BIOMARCADORES\s*:',
    ]

    # Patrones para el final de la secciГіn (antes de diagnГіstico o comentarios)
    report_end_patterns = [
        r'DIAGN[Г“O]STICO',
        r'COMENTARIOS',
        r'Isquemia\s+fr[Г­i]a',
        r'diagnГіsticos?\s+de\s+"',  # Antes de diagnГіstico citado
    ]

    # Buscar inicio de secciГіn REPORTE
    report_start = None
    for pattern in report_start_patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            report_start = match.end()
            break

    if report_start is None:
        return ''  # No se encontrГі secciГіn REPORTE

    # Buscar final de secciГіn
    report_end = None
    text_after_start = text[report_start:]
    for pattern in report_end_patterns:
        match = re.search(pattern, text_after_start, re.IGNORECASE)
        if match:
            report_end = report_start + match.start()
            break

    # Si no se encontrГі final, usar hasta el final del texto
    if report_end is None:
        report_end = len(text)

    # Extraer la secciГіn
    report_section = text[report_start:report_end].strip()

    return report_section


def extraer_seccion(texto, inicio, fin):
    """Extrae una secciГіn del texto entre dos marcadores

    V6.0.0: NUEVO - FunciГіn auxiliar para lГіgica de prioridad de secciones
    V6.3.32: FIX IHQ250031 - Buscar encabezados SOLO al inicio de lГ­nea (mayГєsculas)
             Evita capturar palabras sueltas como "diagnГіsticos de" en medio de pГЎrrafos
    V6.3.35: FIX IHQ250028 - NO usar IGNORECASE para encabezados
             Problema: "con diagnГіstico de ADENOCARCINOMA" hacГ­a match incorrecto
             SoluciГіn: Buscar encabezados en MAYГљSCULAS literalmente

    Args:
        texto: Texto completo del informe
        inicio: PatrГіn regex del marcador de inicio de secciГіn
        fin: PatrГіn regex del marcador de fin de secciГіn

    Returns:
        Texto de la secciГіn extraГ­da o None si no se encuentra
    """
    # V6.3.94: PatrГіn mГЎs robusto para detectar encabezados con ruido de OCR
    # Permite caracteres opcionales como puntos, guiones o espacios extras antes y despuГ©s del nombre
    patron = rf'(?im)(?:^|\n)[^a-zA-Z0-9]*\b({inicio})\b[^a-zA-Z0-9]*[:\s]*(.*?)(?=\n\s*[^a-zA-Z0-9]*\b(?:{fin})\b|\Z)'
    match = re.search(patron, texto, re.DOTALL)
    if match:
        return match.group(2).strip()

    # Fallback si no encuentra con el delimitador de fin especГ­fico
    patron_fallback = rf'(?im)(?:^|\n)[^a-zA-Z0-9]*\b({inicio})\b[^a-zA-Z0-9]*[:\s]*(.*)'
    match = re.search(patron_fallback, texto, re.DOTALL)
    return match.group(2).strip() if match else None


def buscar_en_diagnostico(texto_completo, patron):
    """Busca patrГіn en la secciГіn DIAGNГ“STICO del PDF

    V6.0.0: NUEVO - PRIORIDAD 1 para extracciГіn de biomarcadores
    V6.3.32: FIX IHQ250031 - Busca solo en encabezados de lГ­nea para evitar capturar palabras sueltas

    Esta funciГіn implementa la lГіgica de prioridad:
    - Busca PRIMERO en la secciГіn DIAGNГ“STICO (incluye subsecciones como "ExpresiГіn molecular")
    - La informaciГіn del DIAGNГ“STICO es la final, revisada y condensada

    Args:
        texto_completo: Texto completo del informe IHQ
        patron: PatrГіn regex a buscar

    Returns:
        Valor capturado por el patrГіn o None si no se encuentra
    """
    # Extraer secciГіn DIAGNГ“STICO (incluye subsecciones como "ExpresiГіn molecular")
    seccion_diagnostico = extraer_seccion(
        texto_completo,
        inicio=r"DIAGN[Г“O]STICO|EXPRESI[Г“O]N\s+MOLECULAR",
        fin=r"COMENTARIOS|OBSERVACIONES|DESCRIPCI[Г“O]N\s+MICROSC[Г“O]PICA|RESPONSABLE|$"
    )

    if seccion_diagnostico:
        match = re.search(patron, seccion_diagnostico, re.IGNORECASE)
        if match:
            # Retornar el primer grupo capturado si existe, sino el match completo
            if match.groups():
                return match.group(1).strip()
            else:
                return match.group(0).strip()
    return None


def buscar_en_microscopica(texto_completo, patron):
    """Busca patrГіn en la secciГіn DESCRIPCIГ“N MICROSCГ“PICA del PDF

    V6.0.0: NUEVO - PRIORIDAD 2 (fallback) para extracciГіn de biomarcadores
    V6.0.14: MEJORADO - Excluye subsecciГіn "Anticuerpos:" para evitar capturar reactivos tГ©cnicos (IHQ250984)

    Esta funciГіn implementa la lГіgica de prioridad:
    - Busca SOLO SI NO se encontrГі en DIAGNГ“STICO
    - La informaciГіn de DESCRIPCIГ“N MICROSCГ“PICA es mГЎs detallada pero preliminar

    Args:
        texto_completo: Texto completo del informe IHQ
        patron: PatrГіn regex a buscar

    Returns:
        Valor capturado por el patrГіn o None si no se encuentra
    """
    seccion_microscopica = extraer_seccion(
        texto_completo,
        inicio=r"DESCRIPCI[Г“O]N\s+MICROSC[Г“O]PICA",
        fin=r"DIAGN[Г“O]STICO|EXPRESI[Г“O]N\s+MOLECULAR|RESPONSABLE"
    )

    if seccion_microscopica:
        # V6.0.14: FILTRAR subsecciГіn "Anticuerpos:" (reactivos tГ©cnicos, NO resultados)
        # Esta subsecciГіn contiene informaciГіn tГ©cnica de reactivos que NO debe ser extraГ­da
        anticuerpos_match = re.search(
            r'Anticuerpos:\s*(.+?)(?=REPORTE\s+DE\s+BIOMARCADORES|RESULTADOS?|BLOQUE|$)',
            seccion_microscopica,
            re.IGNORECASE | re.DOTALL
        )
        if anticuerpos_match:
            # Eliminar la subsecciГіn de anticuerpos del texto a buscar
            seccion_sin_anticuerpos = seccion_microscopica[:anticuerpos_match.start()] + \
                                     seccion_microscopica[anticuerpos_match.end():]
            seccion_microscopica = seccion_sin_anticuerpos

        match = re.search(patron, seccion_microscopica, re.IGNORECASE)
        if match:
            # Retornar el primer grupo capturado si existe, sino el match completo
            if match.groups():
                return match.group(1).strip()
            else:
                return match.group(0).strip()
    return None


def extract_biomarkers(text: str, existing_data: Dict[str, Any] = None, debug_mode: bool = False) -> Dict[str, str]:
    """Extrae todos los biomarcadores configurados del texto

    v6.4.13: CRГЌTICO - Detecta casos hipocelulares y marca biomarcadores como "NO VALORABLE" (IHQ250153)
    v6.0.11: CRГЌTICO - Filtra secciГіn "Anticuerpos:" antes de extraer (IHQ250984)
    v6.0.2: MEJORADO - Prioriza "ExpresiГіn molecular" > REPORTE > texto completo (IHQ250981)

    Args:
        text: Texto del informe IHQ

    Returns:
        Diccionario con biomarcadores encontrados
        Ejemplo: {'HER2': 'POSITIVO', 'KI67': '25%', 'ER': 'POSITIVO'}
    """
    if not text:
        return {}

    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # V6.4.30: NORMALIZACIГ“N PREVIA (IHQ250164)
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # Normalizar variantes con espacios antes de procesamiento
    # "SOX -11" в†’ "SOX-11" (con espacio antes del guiГіn)
    text = re.sub(r'(?i)SOX\s+-\s*11', 'SOX-11', text)

    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # V6.4.13: DETECCIГ“N DE CASOS HIPOCELULARES (IHQ250153)
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # CASO ESPECIAL: Muestras hipocelulares sin valores individuales reportados
    # Ejemplos:
    # - "No hay poblaciones sugestivas de lesiones tumorales en la muestra evaluada"
    # - "Dado que la muestra es hipocelular, se recomienda correlacionar..."
    # - Biomarcadores solicitados pero sin valores: "Se ordenan los siguientes marcadores: X, Y, Z"
    #
    # ACCIГ“N: Marcar todos los biomarcadores solicitados como "NO VALORABLE"
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

    # Detectar patrones de caso hipocelular
    patron_hipocelular = r'(?i)(?:muestra\s+(?:es\s+)?hipocelular|dado\s+que\s+la\s+muestra\s+es\s+hipocelular)'
    patron_sin_lesiones = r'(?i)No\s+hay\s+poblaciones\s+sugestivas\s+de\s+lesiones\s+tumorales'

    es_hipocelular = bool(re.search(patron_hipocelular, text))
    sin_lesiones_tumorales = bool(re.search(patron_sin_lesiones, text))

    # Si cumple ambas condiciones, es un caso hipocelular sin valores reportados
    if es_hipocelular and sin_lesiones_tumorales:
        # Extraer biomarcadores solicitados de la descripciГіn macroscГіpica
        # PatrГіn: "Se ordenan los siguientes marcadores: X, Y, Z"
        patron_solicitados = r'(?i)(?:se\s+orden[ae]n?\s+los?\s+siguientes?\s+marcadores?|marcadores?)\s*:\s*([^\.]+)'
        match_solicitados = re.search(patron_solicitados, text)

        if match_solicitados:
            # Extraer lista de biomarcadores
            lista_raw = match_solicitados.group(1)
            # Dividir por comas o "y"
            biomarcadores_solicitados = re.split(r',|\sy\s', lista_raw)

            results = {}
            for biomarcador in biomarcadores_solicitados:
                biomarcador = biomarcador.strip()
                if not biomarcador:
                    continue

                # Normalizar nombre del biomarcador
                nombre_normalizado = biomarcador.upper().replace(' ', '_')

                # Mapear a nombre estГЎndar si es necesario
                mapeo = {
                    'MIELOPEROXIDASA': 'MIELOPEROXIDASA',
                    'CD34': 'CD34',
                    'CD20': 'CD20',
                    'CD117': 'CD117',
                    'CD3': 'CD3',
                    'GLICOFORINA': 'GLICOFORINA',
                    'CD_34': 'CD34',
                    'CD_20': 'CD20',
                    'CD_117': 'CD117',
                    'CD_3': 'CD3'
                }

                nombre_final = mapeo.get(nombre_normalizado, nombre_normalizado)
                results[nombre_final] = 'NO VALORABLE'

            if debug_mode:
                print(f"[HIPOCELULAR DETECTADO] Marcadores solicitados: {list(results.keys())}")
                print(f"[HIPOCELULAR] Todos marcados como 'NO VALORABLE'")

            # Retornar inmediatamente sin procesar mГЎs patrones
            return results

    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # V6.0.12: ESTRATEGIA MULTI-BГљSQUEDA SIN CORTAR TEXTO (IHQ250984)
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # LECCIГ“N APRENDIDA de v6.0.11:
    # - NO cortar el texto (elimina informaciГіn necesaria en pГЎginas posteriores)
    # - SГЌ buscar con patrones especГ­ficos que distingan entre:
    #   * SecciГіn tГ©cnica: "Anticuerpos: [nombres de reactivos]"
    #   * SecciГіn de resultados: "REPORTE DE BIOMARCADORES: [resultados]"
    #
    # ESTRATEGIA:
    # 1. Buscar primero en secciones especГ­ficas (REPORTE, ExpresiГіn molecular)
    # 2. Buscar con patrones que filtren contexto tГ©cnico
    # 3. Usar texto completo solo como Гєltimo recurso
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

    results = {}

    # V6.3.74 FIX IHQ250102: MГЃXIMA PRIORIDAD - ER/PR con intensidad+porcentaje
    # Buscar PRIMERO en descripciГіn microscГіpica: "ExpresiГіn de receptores de X: MarcaciГіn nuclear fuerte y positiva del Y%"
    # Estos valores tienen precedencia sobre cualquier otro mГ©todo de extracciГіn
    seccion_micro = extraer_seccion(text, r"DESCRIPCI[Г“O]N\s+MICROSC[Г“O]PICA", r"DIAGN[Г“O]STICO|EXPRESI[Г“O]N\s+MOLECULAR|RESPONSABLE")
    if seccion_micro:
        # V6.3.96 FIX IHQ250117: PatrГіn de intensidad + porcentaje (variante POSITIVO INTENSIDAD ...)
        patron_er_v2 = r'(?i)expresi[oГі]n\s+de\s+receptores?\s+de\s+estr[oГі]geno[s]?\s*:\s*\n?\s*-\s*(POSITIV[OA]S?|NEGATIV[OA]S?)\s*\(\s*INTENSIDAD\s+(fuerte|moderada|d[eГ©]bil)\s+EN\s+EL\s+(\d+)\s*%\s+'
        match_er_v2 = re.search(patron_er_v2, seccion_micro)
        if match_er_v2:
            estado = match_er_v2.group(1).upper()
            intensidad = match_er_v2.group(2).upper().replace('Г‰', 'E')
            porcentaje = match_er_v2.group(3)
            results['ER'] = f"{estado} (NUCLEAR {intensidad} {porcentaje}%)"

        # PatrГіn ER con intensidad + porcentaje original
        patron_er = r'(?i)expresi[oГі]n\s+de\s+receptores?\s+de\s+estr[oГі]geno[s]?\s*:\s*Marcaci[oГі]n\s+nuclear\s+(fuerte|moderada|d[eГ©]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'
        match_er = re.search(patron_er, seccion_micro)
        if match_er and 'ER' not in results:
            intensidad = match_er.group(1).upper().replace('Г‰', 'E')
            porcentaje = match_er.group(2)
            results['ER'] = f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

        # V6.3.96 FIX IHQ250117: PatrГіn PR v2
        patron_pr_v2 = r'(?i)expresi[oГі]n\s+de\s+receptores?\s+de\s+progesterona\s*:\s*\n?\s*-\s*(POSITIV[OA]S?|NEGATIV[OA]S?)\s*\(\s*INTENSIDAD\s+(fuerte|moderada|d[eГ©]bil)\s+EN\s+EL\s+(\d+)\s*%\s+'
        match_pr_v2 = re.search(patron_pr_v2, seccion_micro)
        if match_pr_v2:
            estado = match_pr_v2.group(1).upper()
            intensidad = match_pr_v2.group(2).upper().replace('Г‰', 'E')
            porcentaje = match_pr_v2.group(3)
            results['PR'] = f"{estado} (NUCLEAR {intensidad} {porcentaje}%)"

        # PatrГіn PR con intensidad + porcentaje original
        patron_pr = r'(?i)expresi[oГі]n\s+de\s+receptores?\s+de\s+progesterona\s*:\s*Marcaci[oГі]n\s+nuclear\s+(fuerte|moderada|d[eГ©]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'
        match_pr = re.search(patron_pr, seccion_micro)
        if match_pr and 'PR' not in results:
            intensidad = match_pr.group(1).upper().replace('Г‰', 'E')
            porcentaje = match_pr.group(2)
            results['PR'] = f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

        # V6.3.96 FIX IHQ250117: PatrГіn HER2 con dash
        patron_her2_dash = r'(?i)Sobreexpresi[oГі]n\s+de\s+oncog[eГ©]n\s+HER2\s*:\s*\n?\s*-\s*(EQU[ГЌI]VOCO|POSITIVO|NEGATIVO)\s*\((?:Score\s+)?(\d+\+?)\)'
        match_her2 = re.search(patron_her2_dash, seccion_micro)
        if match_her2:
            estado = match_her2.group(1).upper().replace('ГЌ', 'I')
            score = match_her2.group(2)
            results['HER2'] = f"{estado} (Score {score})"

    # PRIORIDAD 0: Extraer secciГіn "REPORTE DE BIOMARCADORES:" (IHQ250984)
    # Esta secciГіn contiene resultados en formato estructurado con guiones
    biomarker_report_section = None
    match_reporte = re.search(
        r'(?:REPORTE\s+DE\s+BIOMARCADORES?|RESULTADOS?):\s*(.+?)(?=DIAGN[Г“O]STICO|$)',
        text,
        re.IGNORECASE | re.DOTALL
    )
    if match_reporte:
        biomarker_report_section = match_reporte.group(1)

    # v6.0.2: PRIORIDAD 1 - Extraer secciГіn "ExpresiГіn molecular" (caso IHQ250981)
    molecular_section = extract_molecular_expression_section(text)

    # v5.3.1: PRIORIDAD 2 - Extraer secciГіn REPORTE (descripciГіn microscГіpica)
    report_section = extract_report_section(text)

    # V6.4.71 FIX IHQ250205: Filtrar microambiente y macroscГіpica de TODAS las secciones ANTES de procesar
    # ====================================================================================================
    # El microambiente describe cГ©lulas acompaГ±antes normales que NO deben reportarse
    # La macroscГіpica contiene estudios SOLICITADOS que NO son resultados
    def filtrar_secciones_no_resultado(texto: str) -> str:
        """Elimina secciones que NO contienen resultados (microambiente, macroscГіpica)"""
        if not texto:
            logging.info(f"вљ пёЏ [FILTRO v6.4.72] Filtro llamado con texto VACГЌO, retornando sin filtrar")
            return texto

        # DEBUG: Mostrar si el texto contiene CD4 o CD7 ANTES del filtro
        tiene_cd4_antes = 'CD4' in texto or 'CD 4' in texto
        tiene_cd7_antes = 'CD7' in texto or 'CD 7' in texto
        if tiene_cd4_antes or tiene_cd7_antes:
            logging.info(f"рџџЎ [FILTRO v6.4.72 DEBUG] ANTES del filtro: texto contiene CD4={tiene_cd4_antes}, CD7={tiene_cd7_antes}, len={len(texto)}")

        texto_filtrado = texto

        # V6.4.72 FIX IHQ250205: Filtro 1 MEJORADO - Microambiente (cГ©lulas acompaГ±antes normales)
        # PatrГіn mejorado que captura TODA la oraciГіn hasta el punto final (usando .+? con DOTALL)
        # Esto asegura capturar TODO el microambiente incluso con saltos de lГ­nea y parГ©ntesis internos
        microambiente_pattern = r'(?i)(?:El\s+)?(?:micro[\s-]?ambiente\s+acompa[Г±n]ante|componente\s+inflamatorio|infiltrado\s+inflamatorio|poblaci[oГі]n\s+acompa[Г±n]ante).+?\.\s*(?=[A-Z]|$)'
        for match in re.finditer(microambiente_pattern, texto_filtrado, re.DOTALL):
            microambiente_text = match.group(0)
            texto_filtrado = texto_filtrado.replace(microambiente_text, " [MICROAMBIENTE FILTRADO] ")
            logging.info(f"рџ”µ [FILTRO v6.4.72] Microambiente excluido: {microambiente_text[:100]}...")

        # Filtro 2: DescripciГіn macroscГіpica (estudios solicitados, NO resultados)
        # Formato: "se realizan cortes... para los siguientes marcadores: CD2, CD3, CD4..."
        macro_pattern = r'(?i)(?:se\s+realiz[ao]n?\s+(?:estudios?|cortes?)[^.]*?para\s+los?\s+siguientes?\s+marcadores?[^.]+\.)'
        for match in re.finditer(macro_pattern, texto_filtrado, re.DOTALL):
            macro_text = match.group(0)
            texto_filtrado = texto_filtrado.replace(macro_text, " [ESTUDIOS SOLICITADOS FILTRADO] ")
            logging.info(f"рџ”µ [FILTRO v6.4.71] Estudios solicitados (macro) excluidos: {macro_text[:100]}...")

        # V6.4.89 FIX IHQ250218: Filtro adicional para "se realizan niveles histolГіgicos para tinciГіn con: [LISTA]"
        # Formato: "se realizan niveles histolГіgicos para tinciГіn con: Ki67, BCL2, BCL6, CD3, CD5..."
        # Este es un listado de estudios SOLICITADOS, NO de resultados
        macro_tincion_pattern = r'(?i)se\s+realiz[ao]n?\s+niveles?\s+histol[Гіo]gicos?\s+para\s+tinci[Гіo]n\s+con:?\s+[^.]+\.'
        for match in re.finditer(macro_tincion_pattern, texto_filtrado, re.DOTALL):
            macro_text = match.group(0)
            texto_filtrado = texto_filtrado.replace(macro_text, " [ESTUDIOS SOLICITADOS FILTRADO] ")
            logging.info(f"рџ”µ [FILTRO v6.4.89] Estudios solicitados (niveles histolГіgicos) excluidos: {macro_text[:100]}...")

        # DEBUG: Mostrar si el texto contiene CD4 o CD7 DESPUГ‰S del filtro
        tiene_cd4_despues = ('CD4' in texto_filtrado or 'CD 4' in texto_filtrado) and '[FILTRADO]' not in texto_filtrado
        tiene_cd7_despues = ('CD7' in texto_filtrado or 'CD 7' in texto_filtrado) and '[FILTRADO]' not in texto_filtrado
        if (tiene_cd4_antes or tiene_cd7_antes) and (tiene_cd4_despues or tiene_cd7_despues):
            logging.warning(f"вљ пёЏ [FILTRO DEBUG] DESPUГ‰S del filtro: CD4 TODAVГЌA presente={tiene_cd4_despues}, CD7 TODAVГЌA presente={tiene_cd7_despues}")
            logging.warning(f"вљ пёЏ [FILTRO DEBUG] Texto filtrado (primeros 300 chars): {texto_filtrado[:300]}")

        return texto_filtrado

    # Aplicar filtros a todas las secciones
    biomarker_report_section = filtrar_secciones_no_resultado(biomarker_report_section)
    molecular_section = filtrar_secciones_no_resultado(molecular_section)
    report_section = filtrar_secciones_no_resultado(report_section)

    # Definir biomarcadores que deben priorizarse de "ExpresiГіn molecular"
    molecular_priority = ['ER', 'PR', 'HER2', 'RECEPTOR_ESTROGENOS', 'RECEPTOR_PROGESTERONA']

    # V6.0.12: NUEVA CASCADA DE BГљSQUEDA (sin cortar texto)
    # Buscar en orden de especificidad: REPORTE > Molecular > report_section > texto completo

    # PRIORIDAD 0: Buscar en "REPORTE DE BIOMARCADORES:" (formato estructurado IHQ250984)
    if biomarker_report_section:
        narrative_results = extract_narrative_biomarkers(biomarker_report_section, debug_mode=debug_mode)
        results.update(narrative_results)
        # V6.2.6: Agregar extracciГіn de listas narrativas (IHQ251026)
        list_results = extract_narrative_biomarkers_list(biomarker_report_section)
        # V6.3.50: FIX IHQ250052 - NO sobrescribir valores ya detectados (ej: "Son negativas para CK 7 y CD 117")
        # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es mГЎs especГ­fico (tiene calificador individual)
        for key, value in list_results.items():
            valor_anterior = results.get(key, '')
            # Sobrescribir si:
            # 1. No existe valor anterior
            # 2. Valor nuevo tiene parГ©ntesis (calificador) Y valor anterior NO (es mГЎs especГ­fico)
            if key not in results or ('(' in value and '(' not in valor_anterior):
                results[key] = value

    # PRIORIDAD 1: Buscar en "ExpresiГіn molecular" (IHQ250981)
    if molecular_section:
        narrative_results = extract_narrative_biomarkers(molecular_section)
        # Solo actualizar si no encontrГі antes
        for key, value in narrative_results.items():
            if key not in results:
                results[key] = value
        # V6.2.6: Agregar extracciГіn de listas narrativas (IHQ251026)
        list_results = extract_narrative_biomarkers_list(molecular_section)
        # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es mГЎs especГ­fico
        for key, value in list_results.items():
            valor_anterior = results.get(key, '')
            if key not in results or ('(' in value and '(' not in valor_anterior):
                results[key] = value

    # PRIORIDAD 2: Buscar en secciГіn REPORTE (descripciГіn microscГіpica)
    if report_section:
        narrative_results = extract_narrative_biomarkers(report_section, debug_mode=debug_mode)
        for key, value in narrative_results.items():
            if key not in results:
                results[key] = value
        # V6.2.6: Agregar extracciГіn de listas narrativas (IHQ251026)
        list_results = extract_narrative_biomarkers_list(report_section)
        # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es mГЎs especГ­fico
        for key, value in list_results.items():
            valor_anterior = results.get(key, '')
            if key not in results or ('(' in value and '(' not in valor_anterior):
                results[key] = value

    # PRIORIDAD 3: Buscar en texto completo (SIEMPRE ejecutar para capturar patrones narrativos)
    # V6.3.92 FIX IHQ250114: Filtrar secciГіn MACROSCГ“PICA del texto completo para evitar falsos positivos
    # de marcadores solicitados (pedidos) detectados como resultados.
    # V6.4.71: Filtrar tambiГ©n MICROAMBIENTE y estudios solicitados
    text_for_full_search = text
    macro_section = extraer_seccion(text, r"DESCRIPCI[Г“O]N\s+MACROSC[Г“O]PICA", r"DESCRIPCI[Г“O]N\s+MICROSC[Г“O]PICA|DIAGN[Г“O]STICO|EXPRESI[Г“O]N\s+MOLECULAR")
    if macro_section:
        text_for_full_search = text.replace(macro_section, "[MACROSCГ“PICA FILTRADA]")
    # Aplicar filtros de microambiente y estudios solicitados
    text_for_full_search = filtrar_secciones_no_resultado(text_for_full_search)

    narrative_results = extract_narrative_biomarkers(text_for_full_search, debug_mode=debug_mode)
    for key, value in narrative_results.items():
        if key not in results:
            results[key] = value
    # V6.2.6: Agregar extracciГіn de listas narrativas (IHQ251026)
    list_results = extract_narrative_biomarkers_list(text_for_full_search, BIOMARKER_DEFINITIONS, debug_mode=debug_mode)
    # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es mГЎs especГ­fico
    for key, value in list_results.items():
        valor_anterior = results.get(key, '')
        if key not in results or ('(' in value and '(' not in valor_anterior):
            results[key] = value

    # Procesar cada biomarcador definido en configuraciГіn (mГ©todo original)
    for biomarker_name, definition in BIOMARKER_DEFINITIONS.items():
        # Solo procesar si no fue encontrado por mГ©todo narrativo
        if biomarker_name not in results:
            value = None

            # V6.0.12: Cascada de bГєsqueda especГ­fica
            # PRIORIDAD 0: Buscar en "REPORTE DE BIOMARCADORES:"
            if biomarker_report_section:
                value = extract_single_biomarker(biomarker_report_section, biomarker_name, definition)

            # PRIORIDAD 1: Buscar en "ExpresiГіn molecular"
            if not value and biomarker_name.upper() in molecular_priority and molecular_section:
                value = extract_single_biomarker(molecular_section, biomarker_name, definition)

            # PRIORIDAD 2: Buscar en secciГіn REPORTE
            if not value and report_section:
                value = extract_single_biomarker(report_section, biomarker_name, definition)

            # PRIORIDAD 3: Buscar en texto completo filtrado (fallback)
            if not value:
                value = extract_single_biomarker(text_for_full_search, biomarker_name, definition)

            # V6.4.19 FIX IHQ250159: NO sobrescribir valores vГЎlidos de patrones narrativos
            # Si extract_narrative_biomarkers() ya extrajo POSITIVO/NEGATIVO, no sobrescribir con N/A
            if value:
                valor_anterior = results.get(biomarker_name, '')
                if biomarker_name not in results or valor_anterior in ['NO MENCIONADO', 'N/A', '']:
                    results[biomarker_name] = value

    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # V6.3.77 FIX IHQ250105: PASE FINAL EN FUNCIГ“N PRINCIPAL
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # Problema: Listas genГ©ricas como "tinciГіn con marcadores: CD20, CD79, CD34..."
    # marcan TODO como POSITIVO. Luego, aunque extract_narrative_biomarkers() detecta
    # NEGATIVO, la lГіgica "if key not in results" NO sobrescribe.
    #
    # SoluciГіn: Buscar patrones explГ­citos NEGATIVO en texto COMPLETO y sobrescribir.
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

    # PatrГіn 1: "marcaciГіn negativa para X"
    final_neg_marcacion = re.findall(
        r'(?i)marcaci[Гіo]n\s+negativa\s+para\s+([A-Za-z0-9\s,\-]+?)(?=,\s*[Cc]on\s+marcaci[oГі]n|\s+Linfocitos|\.\s|$)',
        text
    )
    for match in final_neg_marcacion:
        for bio in re.split(r'\s*,\s*', match.strip()):
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized and results.get(normalized) == 'POSITIVO':
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"рџ”ґ [PASE FINAL extract_biomarkers v6.3.77] {normalized}: POSITIVO в†’ NEGATIVO (marcaciГіn negativa)")

    # PatrГіn 2: "Negativo para X, Y, Z"
    final_neg_para = re.findall(
        r'(?i)(?:^|\.\s*)Negativo\s+para\s+([A-Za-z0-9\s,\-]+?)(?=\s+Linfocitos|\s+cГ©lulas|\s+acompaГ±antes|\.\s|$)',
        text
    )
    for match in final_neg_para:
        for bio in re.split(r'\s*,\s*', match.strip()):
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized and results.get(normalized) == 'POSITIVO':
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"рџ”ґ [PASE FINAL extract_biomarkers v6.3.77] {normalized}: POSITIVO в†’ NEGATIVO (Negativo para)")

    # PatrГіn 3: "tienen marcaciГіn negativa para X"
    final_tienen_neg = re.findall(
        r'(?i)tienen\s+marcaci[Гіo]n\s+negativa\s+para\s+([A-Za-z0-9\s,\-]+?)(?=,\s*[Cc]on|\.\s|$)',
        text
    )
    for match in final_tienen_neg:
        for bio in re.split(r'\s*,\s*', match.strip()):
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized and results.get(normalized) == 'POSITIVO':
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"рџ”ґ [PASE FINAL extract_biomarkers v6.3.77] {normalized}: POSITIVO в†’ NEGATIVO (tienen marcaciГіn negativa)")

    # PatrГіn 4: V6.4.30 FIX IHQ250164: "negativa con el X, Y, Z"
    # Formato: "es positiva para CD20, PAX-5 Y BCL-2, y negativa con el CD5, CD10, BCL6, IgD, SOX -11 y Ciclyna D1"
    final_neg_con_el = re.findall(
        r'(?i)negativ[oa]s?\s+con(?:\s+el)?\s+([A-Za-z0-9\s,\-]+?)(?=;|\.|$)',
        text
    )
    for match in final_neg_con_el:
        # Separar por comas y "y"
        for bio in re.split(r'\s*,\s*|\s+y\s+', match.strip()):
            bio = bio.strip()
            # Limpiar "el" al inicio
            bio = re.sub(r'(?i)^el\s+', '', bio)
            if bio and len(bio) > 1:
                normalized = normalize_biomarker_name(bio)
                if normalized:
                    # V6.4.31 FIX IHQ250164: Asignar NEGATIVO sin condiciГіn previa (autoridad absoluta)
                    valor_previo = results.get(normalized, 'N/A')
                    results[normalized] = 'NEGATIVO'
                    if valor_previo and valor_previo != 'N/A':
                        logging.info(f"рџ”ґ [PASE FINAL v6.4.31] {normalized}: {valor_previo} в†’ NEGATIVO (negativa con el)")
                    else:
                        logging.info(f"рџ”ґ [PASE FINAL v6.4.31] {normalized} = NEGATIVO (negativa con el)")

    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # V6.4.9 FIX IHQ250141: POST-PROCESAMIENTO KAPPA/LAMBDA IMPLГЌCITO
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # LГіgica: En casos de neoplasias de cГ©lulas plasmГЎticas/mieloma mГєltiple
    # - Si hay RESTRICCIГ“N de KAPPA в†’ LAMBDA es implГ­citamente NEGATIVO
    # - Si hay RESTRICCIГ“N de LAMBDA в†’ KAPPA es implГ­citamente NEGATIVO
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

    if 'KAPPA' in results:
        kappa_value = results.get('KAPPA', '')
        # Si KAPPA tiene "restricciГіn" o es POSITIVO в†’ Lambda es NEGATIVO
        if 'restricciГіn' in kappa_value.lower() or kappa_value.upper().startswith('POSITIVO'):
            if 'LAMBDA' not in results:
                results['LAMBDA'] = 'NEGATIVO'
                logging.info(f"вњ… [POST-PROCESAMIENTO v6.4.9] LAMBDA = NEGATIVO (implГ­cito por restricciГіn KAPPA)")

    if 'LAMBDA' in results:
        lambda_value = results.get('LAMBDA', '')
        # Si LAMBDA tiene "restricciГіn" o es POSITIVO в†’ Kappa es NEGATIVO
        if 'restricciГіn' in lambda_value.lower() or lambda_value.upper().startswith('POSITIVO'):
            if 'KAPPA' not in results:
                results['KAPPA'] = 'NEGATIVO'
                logging.info(f"вњ… [POST-PROCESAMIENTO v6.4.9] KAPPA = NEGATIVO (implГ­cito por restricciГіn LAMBDA)")

    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # V6.4.72 FIX IHQ250205: Asignar "NO MENCIONADO" solo a biomarcadores solicitados
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    # Extraer estudios solicitados del texto
    estudios_pattern = r'(?i)(?:se\s+realiz[ao]n?\s+(?:estudios?|cortes?)[^.]*?para\s+los?\s+siguientes?\s+marcadores?)[:\s]+([^.]+)\.'
    match_estudios = re.search(estudios_pattern, text, re.DOTALL)

    if match_estudios:
        estudios_text = match_estudios.group(1)
        # Separar por comas y normalizar
        biomarcadores_solicitados = re.split(r'[,;]\s*|\s+y\s+', estudios_text)

        for bio_solicitado in biomarcadores_solicitados:
            bio_solicitado = bio_solicitado.strip().rstrip('.')
            if not bio_solicitado or len(bio_solicitado) < 2:
                continue

            # Normalizar nombre
            bio_normalizado = normalize_biomarker_name(bio_solicitado)

            # Si estГЎ en BIOMARKER_DEFINITIONS pero NO en results, asignar "NO MENCIONADO"
            if bio_normalizado and bio_normalizado in BIOMARKER_DEFINITIONS and bio_normalizado not in results:
                results[bio_normalizado] = 'NO MENCIONADO'
                logging.info(f"в„№пёЏ [V6.4.72] {bio_normalizado} = NO MENCIONADO (solicitado pero no encontrado)")

    return results


def extract_narrative_biomarkers(text: str, debug_mode: bool = False) -> Dict[str, str]:
    """Extrae biomarcadores del formato narrativo tipo:
    'cГ©lulas neoplГЎsicas son fuertemente positivas para CK7 y GATA 3 y EMA, negativas para CK20, SOX10 y CDX2'
    Y formatos complejos como 'RECEPTOR DE ESTRГ“GENOS, positivo focal'

    V6.3.41: FIX IHQ250035 - HER2 con score en formato narrativo
    V6.2.8: FIX IHQ250011 - PatrГіn mixto "positivo para X y negativas para Y, Z, W"
    V6.1.1: FIX IHQ250995 - Soporta "pГ©rdida de expresiГіn" y patrones complejos de prГіstata
    """
    results = {}

    # V6.3.41: FIX IHQ250035 - HER2 debe extraerse COMPLETO con score antes de patrones generales
    # V6.4.67 FIX IHQ250204: Ampliado para capturar "SobreexpresiГіn de oncogen HER 2"
    # Formatos soportados:
    #   - "Las cГ©lulas tumorales tienen expresiГіn HER 2 negativo (score 0)"
    #   - "SobreexpresiГіn de oncogen HER 2: Negativo (score 0)"
    # CRГЌTICO: Este patrГіn debe ir PRIMERO para evitar que otros patrones capturen solo "NEGATIVO"
    # V6.4.67: PatrГіn tolerante a problemas de encoding (expresiпїЅn, oncogпїЅn)
    # Captura valor completo incluyendo parГ©ntesis y se detiene antes de nueva secciГіn
    her2_pattern = r'(?i)(?:c[eГ©]lulas\s+tumorales\s+tienen\s+)?(?:sobre)?expresi.n\s+(?:de\s+(?:oncog.n\s+)?)?(?:del?\s+)?HER\s*-?\s*2\s*:?\s*(.+?(?:\([^)]+\))?)(?=\s+(?:DIAGN|Prueba|-\s*Prueba|\n-|\.)|$)'
    her2_match = re.search(her2_pattern, text)
    if her2_match:
        her2_valor_raw = her2_match.group(1).strip()
        # V6.4.65 FIX IHQ250204: Normalizar HER2 usando su diccionario de normalizaciГіn
        her2_definition = BIOMARKER_DEFINITIONS.get('HER2', {})
        her2_normalization = her2_definition.get('normalizacion', {})
        her2_valor = normalize_biomarker_value(
            her2_valor_raw,
            her2_normalization,
            her2_definition.get('tipo_valor', 'DESCRIPTIVE')
        )
        results['HER2'] = her2_valor  # V6.4.67: Valor normalizado con SCORE preservado
        logging.info(f"вњ… [HER2 narrativo v6.4.67] ExtraГ­do: {her2_valor_raw} в†’ {her2_valor}")
    else:
        # V6.4.67 DEBUG: Log cuando NO hace match
        if 'HER' in text.upper() and '2' in text:
            logging.warning(f"вљ пёЏ [HER2 narrativo v6.4.67] PatrГіn NO hizo match. Texto contiene HER2 pero formato no coincide.")

    # V6.4.44 FIX IHQ250179: PRIORIDAD ALTA - Mucinas (MUC1/MUC2) con formato "inmunorreactiva positiva difusa...para MUCX"
    # Formato: "El epitelio demuestra inmunorreactiva positiva difusa en el epitelio para MUC1 y son negativas para MUC2"
    # CRГЌTICO: Debe ejecutarse ANTES de patrones genГ©ricos "negativas para" que podrГ­an capturar incorrectamente
    muc_positivo_pattern = r'(?i)inmunorreactiva?\s+positiva?\s+difusa?[^.]{0,80}?\s+para\s+(muc\s*-?\s*[12])'
    for match in re.finditer(muc_positivo_pattern, text):
        muc_raw = match.group(1).strip()
        normalized_name = normalize_biomarker_name(muc_raw)
        if normalized_name and normalized_name not in results:
            results[normalized_name] = 'POSITIVO DIFUSO'
            logging.info(f"вњ… [MUC positivo v6.4.44] '{muc_raw}' в†’ {normalized_name} = POSITIVO DIFUSO")

    # V6.4.44 FIX IHQ250179: PRIORIDAD ALTA - Ki-67 cualitativo sin porcentaje
    # Formato: "el Г­ndice de proliferaciГіn celular medido con Ki 67 se distribuye uniformemente"
    # CRГЌTICO: Debe ejecutarse ANTES de patrones numГ©ricos que capturan "67" del nombre
    ki67_cualitativo_pattern = r'(?i)[iГ­]ndice\s+de\s+proliferaci[Гіo]n\s+c[Г©e]lular\s+medido\s+con\s+ki[^\w]*67\s+se\s+distribuye\s+uniformemente'
    ki67_cualitativo_match = re.search(ki67_cualitativo_pattern, text)
    if ki67_cualitativo_match and 'KI67' not in results:
        results['KI67'] = 'POSITIVO (distribuciГіn uniforme)'
        logging.info(f"вњ… [Ki-67 cualitativo v6.4.44] ExtraГ­do: KI67 = POSITIVO (distribuciГіn uniforme)")

    # V6.4.91 FIX IHQ250219: PRIORIDAD ALTA - Ki-67 cualitativo con distribuciГіn variable
    # Formato: "Г­ndice de proliferaciГіn celular medido mediante el Ki67 se distribuye predominantemente en el centro"
    # Diferencias vs v6.4.44: "medido mediante" (vs "medido con"), "predominantemente" (vs "uniformemente")
    # Captura cualquier tipo de distribuciГіn (uniformemente, predominantemente, focalmente, etc.)
    ki67_distribucion_pattern = r'(?i)[iГ­]ndice\s+de\s+proliferaci[Гіo]n\s+c[Г©e]lular\s+medido\s+(?:con|mediante(?:\s+el)?)\s+ki[^\w]*67\s+se\s+distribuye\s+(\w+)'
    ki67_dist_match = re.search(ki67_distribucion_pattern, text)
    if ki67_dist_match and 'KI67' not in results:
        distribucion = ki67_dist_match.group(1).strip().lower()
        # Mapeo de distribuciones a valores normalizados
        if 'uniforme' in distribucion:
            results['KI67'] = 'POSITIVO (distribuciГіn uniforme)'
        elif 'predominante' in distribucion:
            results['KI67'] = 'POSITIVO (distribuciГіn predominante)'
        elif 'focal' in distribucion:
            results['KI67'] = 'POSITIVO (distribuciГіn focal)'
        elif 'difusa' in distribucion or 'difuso' in distribucion:
            results['KI67'] = 'POSITIVO (distribuciГіn difusa)'
        else:
            results['KI67'] = f'POSITIVO (distribuciГіn {distribucion})'
        logging.info(f"вњ… [Ki-67 distribuciГіn v6.4.91] ExtraГ­do: KI67 = {results['KI67']}")

    # V6.4.91 FIX IHQ250219: PRIORIDAD ALTA - "No hay expresiГіn para [LISTA]"
    # Formato: "No hay expreisГіn para HHV-8 ni para LMP-1" (typo OCR comГєn: expreisГіn con 'i' antes de 's')
    # Captura biomarcadores en lista despuГ©s de "No hay expresiГіn para" в†’ NEGATIVO
    # Variantes: "ni para", "ni", "y" como separadores
    # PatrГіn robusto: acepta "expresiГіn", "expresion", "expreisГіn", "expreison" (typos OCR comunes)
    no_expresion_pattern = r'(?i)no\s+hay\s+expr[ei]+s[ioГі]+n\s+para\s+([^.]+)'
    for match in re.finditer(no_expresion_pattern, text):
        lista_raw = match.group(1).strip()
        logging.info(f"рџ”Ќ [V6.4.91 No hay expresiГіn] Lista detectada: '{lista_raw}'")

        # Separar por "ni para", "ni", "y", comas
        lista_raw = re.sub(r'\s+ni\s+para\s+', ', ', lista_raw)
        lista_raw = re.sub(r'\s+ni\s+', ', ', lista_raw)
        lista_raw = re.sub(r'\s+y\s+', ', ', lista_raw)
        biomarcadores_lista = re.split(r'[,;]\s*', lista_raw)

        for bio_raw in biomarcadores_lista:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw or len(bio_raw) < 2:
                continue

            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"вњ… [V6.4.91 No hay expresiГіn] '{bio_raw}' в†’ {normalized_name} = NEGATIVO")

    # V6.4.62 FIX IHQ250202: PRIORIDAD MГЃXIMA - "Los marcadores [lista] - son negativos/positivos"
    # Formato especГ­fico: "Los marcadores napsina y TTF-1 - son negativos."
    # Este patrГіn ejecuta PRIMERO con mГЎxima prioridad (formato con guion antes del verbo)
    # IMPORTANTE: Posicionado al inicio para que NO sea sobrescrito por patrones genГ©ricos posteriores
    # V6.4.62: FIX regex - [^-]+? solo capturaba "n", cambiado a .+? para capturar toda la lista
    marcadores_con_guion_pattern = r'(?i)Los?\s+marcadores?\s+(.+?)\s+-\s+(?:son|es)\s+(negativos?|positivos?)'
    for match in re.finditer(marcadores_con_guion_pattern, text):
        lista_biomarkers_raw = match.group(1).strip()
        resultado = match.group(2).strip().upper()

        logging.info(f"рџ”Ќ [V6.4.61 Los marcadores - son negativos] Lista detectada: '{lista_biomarkers_raw}' в†’ {resultado}")

        # Determinar valor base segГєn resultado
        if 'NEGATIVO' in resultado:
            valor_base = 'NEGATIVO'
        elif 'POSITIVO' in resultado:
            valor_base = 'POSITIVO'
        else:
            continue

        # Separar por comas Y "y"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw:
                continue

            # Normalizar nombre (maneja TTF-1 в†’ TTF1, napsina в†’ NAPSIN)
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                results[normalized_name] = valor_base
                logging.info(f"вњ… [Los marcadores - son {valor_base} v6.4.61 MГЃXIMA PRIORIDAD] '{bio_raw}' в†’ {normalized_name} = {valor_base}")

    # V6.4.1: FIX IHQ250115 - Soporta adjetivos como "es de forma difusa positiva para"
    # Y restringe la captura de marcadores positivos para evitar over-greedy sobre "negativo para"
    # V6.3.94 FIX IHQ250115: Soporte para "positivo con" ademГЎs de "positiva para"
    # V6.4.30 FIX IHQ250164: Soporte para "negativa con el" (agregar "el" opcional despuГ©s de "con")
    mixto_pattern = r'(?i)(?:es\s+|son\s+)?(?:de\s+forma\s+\w+\s+)?positiv[oa]s?\s+(?:para|con)\s+(?:receptores?\s+(?:hormonales?\s+)?de\s+)?([^.]+?)\s+y\s+(?:es\s+|son\s+)?negativ[oa]s?\s+(?:para|con(?:\s+el)?)\s+(?:receptores?\s+(?:de\s+)?)?(.+?)(?:\.|$)'

    for match in re.finditer(mixto_pattern, text, re.DOTALL):
        # Grupo 1: POSITIVOS
        positivos_raw = match.group(1).strip()
        logging.info(f"рџ”Ќ [Mixto +/-] POSITIVOS detectados: '{positivos_raw}'")

        # Limpiar y separar
        positivos_raw = re.sub(r'\s*\n\s*', ' ', positivos_raw)
        biomarcadores_positivos = re.split(r'[,;]\s*|\s+y\s+', positivos_raw)

        for bio_raw in biomarcadores_positivos:
            bio_raw = bio_raw.strip().rstrip('.')
            # Limpiar frases descriptivas (ej: "receptores hormonales de progesterona" в†’ "progesterona")
            bio_raw = re.sub(r'(?i)receptores?\s+(?:hormonales?\s+)?de\s+', '', bio_raw)

            if not bio_raw or bio_raw.lower() in ['de', 'la', 'las', 'los', 'para']:
                continue

            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                # V6.4.9: Default score (3+) for HER2 if missing
                results[normalized_name] = 'POSITIVO (3+)' if normalized_name == 'HER2' else 'POSITIVO'
                logging.info(f"вњ… [Mixto +/-] POSITIVO: '{bio_raw}' в†’ {normalized_name} = {results[normalized_name]}")

        # Grupo 2: NEGATIVOS
        negativos_raw = match.group(2).strip()
        logging.info(f"рџ”Ќ [Mixto +/-] NEGATIVOS detectados: '{negativos_raw}'")

        # Limpiar y separar
