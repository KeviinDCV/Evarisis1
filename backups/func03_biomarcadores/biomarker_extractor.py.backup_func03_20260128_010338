    inmuno_match = re.search(r'INMUNOR?R?EACTIVIDAD\s+((?:MODERADA(?:\s+Y\s+FUERTE)?)|FUERTE|D[Г‰E]BIL|INTENSA)\s+(?:PARA|A)\s+(?:LOS\s+)?RECEPTORES?\s+DE\s+(?:ESTR[Г“O]GENO[S]?|PROGESTERONA)', value_clean)
