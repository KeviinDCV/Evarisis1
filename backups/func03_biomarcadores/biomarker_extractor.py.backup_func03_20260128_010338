        return None

    # V6.3.74 FIX IHQ250102: LГ“GICA ESPECIAL PARA ER/PR con intensidad+porcentaje
    # Buscar PRIMERO en descripciГіn microscГіpica el patrГіn "MarcaciГіn nuclear fuerte y positiva del XX%"
    # Si lo encuentra, retornar "POSITIVO (NUCLEAR FUERTE XX%)"
    # Si no, continuar con la lГіgica normal de prioridad de secciГіn
    if biomarker_name in ['ER', 'PR'] and definition.get('usa_prioridad_seccion', False):
        # PatrГіn especГ­fico para capturar intensidad + porcentaje en descripciГіn microscГіpica
        if biomarker_name == 'ER':
            patron_intensidad = r'(?i)expresi[oГі]n\s+de\s+receptores?\s+de\s+estr[oГі]geno[s]?\s*:\s*Marcaci[oГі]n\s+nuclear\s+(fuerte|moderada|d[eГ©]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'
        else:  # PR
            patron_intensidad = r'(?i)expresi[oГі]n\s+de\s+receptores?\s+de\s+progesterona\s*:\s*Marcaci[oГі]n\s+nuclear\s+(fuerte|moderada|d[eГ©]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'

        # Buscar en descripciГіn microscГіpica
        seccion_micro = extraer_seccion(text, r"DESCRIPCI[Г“O]N\s+MICROSC[Г“O]PICA", r"DIAGN[Г“O]STICO|EXPRESI[Г“O]N\s+MOLECULAR|RESPONSABLE")
        if seccion_micro:
            match = re.search(patron_intensidad, seccion_micro)
            if match:
                intensidad = match.group(1).upper().replace('Г‰', 'E')  # "dГ©bil" в†’ "DEBIL"
                porcentaje = match.group(2)
                return f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

        # Si no encontrГі el patrГіn especГ­fico, continuar con lГіgica normal

    # V6.0.0: Si el biomarcador usa prioridad de secciГіn (RESTO DE BIOMARCADORES)
    if definition.get('usa_prioridad_seccion', False):
        # PRIORIDAD 1: Buscar en secciГіn DIAGNГ“STICO
        for idx, pattern in enumerate(definition.get('patrones', [])):
            valor_diagnostico = buscar_en_diagnostico(text, pattern)
            if valor_diagnostico:
                # V6.3.32 DEBUG: Log para HER2 (siempre)
                if biomarker_name == 'HER2':
                    with open('debug_her2_extraction.log', 'a', encoding='utf-8') as f:
                        f.write(f"\n[HER2] Pattern {idx + 1} matched in DIAGNOSTICO\n")
                        f.write(f"  Pattern: {str(pattern)[:100]}\n")
                        f.write(f"  Captured: '{valor_diagnostico}'\n")
                        f.write(f"  Normalization map: {definition.get('normalizacion', {})}\n")
                        f.write(f"  Value type: {definition.get('tipo_valor', 'CATEGORICAL')}\n")

                # V6.2.2: FIX IHQ251015 - Manejo especial para ER/PR con "receptores de X y Y"
                # Si el valor contiene frase completa "receptores de estrГіgeno y progesterona" в†’ POSITIVO
                if biomarker_name in ['ER', 'PR']:
                    if re.search(r'(?i)receptores\s+de\s+estr[oГі]geno[s]?\s+y\s+progesterona', valor_diagnostico):
                        if re.search(r'(?i)marcaci[oГі]n|positividad', valor_diagnostico):
                            return 'POSITIVO'

                # V6.3.14: CRГЌTICO - ValidaciГіn KI-67 "expresiГіn limitada" ANTES de normalizar
                if biomarker_name == 'KI67' and 'expresi' in valor_diagnostico.lower() and 'limitada' in valor_diagnostico.lower():
                    return "EXPRESIГ“N LIMITADA A CAPA BASAL"

                # V6.3.59 FIX IHQ250071: Buscar "menor/menos del" en secciГіn diagnГіstico para Ki-67
                if biomarker_name == 'KI67':
                    seccion_diag = extraer_seccion(text, r"DIAGN[Г“O]STICO|EXPRESI[Г“O]N\s+MOLECULAR", r"COMENTARIOS|OBSERVACIONES|DESCRIPCI[Г“O]N\s+MICROSC[Г“O]PICA|RESPONSABLE")
                    if seccion_diag and re.search(rf'(?i)ki[^\w]*67\s+(?:es\s+bajo\s*\()?(?:menor\s+(?:al|del)|menos\s+del)\s+{re.escape(valor_diagnostico)}\s*%?\)?', seccion_diag):
                        # Valor es solo el nГєmero, agregar < y %
                        if re.match(r'^\d+$', valor_diagnostico):
                            valor_diagnostico = f"<{valor_diagnostico}%"
                        elif not valor_diagnostico.startswith('<'):
                            valor_diagnostico = f"<{valor_diagnostico}"
                    # Asegurar que siempre tenga % si es un nГєmero puro
                    elif re.match(r'^\d+$', valor_diagnostico):
                        valor_diagnostico = f"{valor_diagnostico}%"

                # Normalizar el valor
                normalized = normalize_biomarker_value(
                    valor_diagnostico,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )

                # V6.3.32 DEBUG: Log normalizaciГіn (siempre)
                if biomarker_name == 'HER2':
                    with open('debug_her2_extraction.log', 'a', encoding='utf-8') as f:
                        f.write(f"  Normalized: '{normalized}'\n")

                if normalized:
                    return normalized

        # PRIORIDAD 2: Buscar en DESCRIPCIГ“N MICROSCГ“PICA (fallback)
        for pattern in definition.get('patrones', []):
            valor_microscopica = buscar_en_microscopica(text, pattern)
            if valor_microscopica:
                # V6.2.2: FIX IHQ251015 - Manejo especial para ER/PR con "receptores de X y Y"
                # Si el valor contiene frase completa "receptores de estrГіgeno y progesterona" в†’ POSITIVO
                if biomarker_name in ['ER', 'PR']:
                    if re.search(r'(?i)receptores\s+de\s+estr[oГі]geno[s]?\s+y\s+progesterona', valor_microscopica):
                        if re.search(r'(?i)marcaci[oГі]n|positividad', valor_microscopica):
                            return 'POSITIVO'

                # V6.3.14: CRГЌTICO - ValidaciГіn KI-67 "expresiГіn limitada" ANTES de normalizar
                if biomarker_name == 'KI67' and 'expresi' in valor_microscopica.lower() and 'limitada' in valor_microscopica.lower():
                    return "EXPRESIГ“N LIMITADA A CAPA BASAL"

                # V6.3.59 FIX IHQ250071: Buscar "menor/menos del" en secciГіn microscГіpica para Ki-67
                if biomarker_name == 'KI67':
                    seccion_micro = extraer_seccion(text, r"DESCRIPCI[Г“O]N\s+MICROSC[Г“O]PICA", r"DIAGN[Г“O]STICO|EXPRESI[Г“O]N\s+MOLECULAR|RESPONSABLE")
                    if seccion_micro and re.search(rf'(?i)ki[^\w]*67\s+(?:es\s+bajo\s*\()?(?:menor\s+(?:al|del)|menos\s+del)\s+{re.escape(valor_microscopica)}\s*%?\)?', seccion_micro):
                        # Valor es solo el nГєmero, agregar < y %
                        if re.match(r'^\d+$', valor_microscopica):
                            valor_microscopica = f"<{valor_microscopica}%"
                        elif not valor_microscopica.startswith('<'):
                            valor_microscopica = f"<{valor_microscopica}"
                    # Asegurar que siempre tenga % si es un nГєmero puro
                    elif re.match(r'^\d+$', valor_microscopica):
                        valor_microscopica = f"{valor_microscopica}%"

                # Normalizar el valor
                normalized = normalize_biomarker_value(
                    valor_microscopica,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )
                if normalized:
                    return normalized

        # V6.1.4: PRIORIDAD 3 - Buscar en texto completo (fallback final)
        # Casos donde el biomarcador estГЎ en secciones no estГЎndar (ej: E-Cadherina en IHQ251008)
        for pattern in definition.get('patrones', []):
            match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
            if match:
                # Obtener valor capturado
                if match.groups():
                    raw_value = match.group(1).strip()
                else:
                    raw_value = match.group(0).strip()

                # V6.3.14: CRГЌTICO - ValidaciГіn KI-67 "expresiГіn limitada" ANTES de normalizar
                # Bug: PRIORIDAD 3 llamaba normalize_biomarker_value sin validaciГіn especial
                # SoluciГіn: Duplicar validaciГіn de lГ­nea 4190 tambiГ©n aquГ­
                if biomarker_name == 'KI67' and 'expresi' in raw_value.lower() and 'limitada' in raw_value.lower():
                    return "EXPRESIГ“N LIMITADA A CAPA BASAL"

                # Normalizar
                normalized = normalize_biomarker_value(
                    raw_value,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )
                if normalized:
                    return normalized

        return None

    # LГіgica original continГєa debajo (para biomarcadores sin prioridad de secciГіn)
    # Intentar con cada patrГіn definido
    for pattern in definition.get('patrones', []):
        match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
        if match:
            # VALIDACIГ“N ESPECIAL PARA KI67 v5.0.1
            # Verificar que NO estemos capturando porcentajes de otros campos
            if biomarker_name == 'KI67':
                match_start = match.start()
                context_before = text[max(0, match_start - 150):match_start].upper()

                # Si "DIFERENCIACIГ“N" o "GLANDULAR" aparecen en los 150 caracteres previos, descartar
                if 'DIFERENCIACI' in context_before and 'GLANDULAR' in context_before:
                    continue

                # V6.4.0 FIX IHQ250013: NO descartar "MENOR DEL" - lo procesaremos mГЎs adelante
                # (Comentado el continue que descartaba valores con "menor del")
                # if 'MENOR DEL' in context_before[-30:]:
                #     continue

            # Obtener el valor capturado, manejar casos sin grupos
            if match.groups():
                # V3.2.2: Manejar rangos (Ki67: 1-2%)
                if len(match.groups()) >= 2 and match.group(2):
                    # Es un rango, tomar el valor superior
                    raw_value = match.group(2).strip()
                else:
                    raw_value = match.group(1).strip()
            else:
                raw_value = match.group(0).strip()

            # V6.4.0 FIX IHQ250013: Manejo especial para KI-67 con "menor"
            # Si el patrГіn capturГі "Ki67 menor del X%" в†’ convertir a "<X%"
            # V6.3.59 FIX IHQ250071: TambiГ©n detectar "menos del" (diferente de "menor del")
            if biomarker_name == 'KI67':
                # Obtener el texto completo del match para ver si contiene "menor" o "menos"
                full_match_text = match.group(0)
                # "menor al/del" o "menos del" в†’ indica valor < X%
                if re.search(r'(?i)(?:menor\s+(?:al|del)|menos\s+del)', full_match_text):
                    # El valor raw_value es solo el nГєmero (ej: "1" o "10")
                    # Convertir a formato "<X%"
                    raw_value = f"<{raw_value}%"

            # V6.2.2: FIX IHQ251015 - Manejo especial para P63 sin estado explГ­cito
            # Cuando el patrГіn de P63 encuentra "expresiГіn de ... P63" o "inmunorreactividad para ... P63"
            # sin capturar grupo (match.groups() retorna tupla vacГ­a)
            # в†’ Infiere POSITIVO porque hablar de "expresiГіn" o "inmunorreactividad" implica positividad
            if biomarker_name == 'P63' and len(match.groups()) == 0:
                # El match completo contiene "expresiГіn" o "inmunorreactividad" в†’ POSITIVO
                if re.search(r'(?i)expresi[oГі]n|inmunor+eactividad', raw_value):
                    return 'POSITIVO'

            # V6.2.2: FIX IHQ251015 - Manejo especial para ER/PR con "receptores de X y Y"
            # Cuando detectamos "receptores de estrГіgeno y progesterona con marcaciГіn/positividad"
            # в†’ ER = POSITIVO, PR = POSITIVO (el contexto "marcaciГіn" o "positividad" implica positivo)
            if biomarker_name in ['ER', 'PR'] and len(match.groups()) == 0:
                # Match sin grupos capturados в†’ es uno de los nuevos patrones "receptores de estrГіgeno y progesterona"
                if re.search(r'(?i)marcaci[oГі]n|positividad', raw_value):
                    return 'POSITIVO'

            # V6.3.74 FIX IHQ250102: Manejo especial para ER/PR con intensidad + porcentaje
            # Cuando el patrГіn captura dos grupos: (intensidad, porcentaje)
            # Ej: "MarcaciГіn nuclear fuerte y positiva del 70%" в†’ ("fuerte", "70")
            # в†’ Normalizar a "POSITIVO (NUCLEAR FUERTE 70%)"
            if biomarker_name in ['ER', 'PR'] and len(match.groups()) >= 2:
                group1 = match.group(1)
                group2 = match.group(2)
                # Verificar si group1 es intensidad (fuerte/moderada/dГ©bil) y group2 es porcentaje
                if group1 and group2 and re.match(r'(?i)fuerte|moderada|d[eГ©]bil', group1) and re.match(r'\d+', group2):
                    intensidad = group1.upper().replace('Г‰', 'E')  # "dГ©bil" в†’ "DEBIL"
                    porcentaje = group2
                    return f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

            # V3.2.2: Manejo especial para "expresiГіn limitada" в†’ convertir a texto descriptivo
            if biomarker_name == 'KI67' and 'expresi' in raw_value.lower() and 'limitada' in raw_value.lower():
                return "EXPRESIГ“N LIMITADA A CAPA BASAL"

            # V6.3.57 FIX IHQ250066: Manejo especial para KI67 "positivo en espesor"
            # Cuando el patrГіn captura "Ki 67 es positivo en todo el espesor" sin porcentaje
            # в†’ Retornar POSITIVO (indica alta proliferaciГіn en displasias/NIC)
            if biomarker_name == 'KI67' and re.search(r'(?i)positivo\s+en\s+(?:todo\s+)?(?:el\s+)?espesor', raw_value):
                return 'POSITIVO'

            # Normalizar el valor
            normalized = normalize_biomarker_value(
                raw_value,
                definition.get('normalizacion', {}),
                definition.get('tipo_valor', 'CATEGORICAL')
            )

            return normalized

    return None


def normalize_biomarker_value(
    raw_value: str,
    specific_normalization: Dict[str, str],
    value_type: str = 'CATEGORICAL'
) -> str:
    """Normaliza el valor de un biomarcador

    v5.3.1: MEJORADO - Manejo de rangos (ej: "51-60%")
    v6.0.5: MEJORADO - NormalizaciГіn de valores narrativos contaminados
    v6.1.7: CRГЌTICO - Limpieza completa de \n, \r, \t + estandarizaciГіn narrativa
    v6.3.19: FIX IHQ250017 - Preservar texto completo para tipo DESCRIPTIVE (HER2 con score)

    Args:
        raw_value: Valor extraГ­do del texto
        specific_normalization: NormalizaciГіn especГ­fica del biomarcador
        value_type: Tipo de valor ('CATEGORICAL', 'PERCENTAGE', 'NUMERIC', 'DESCRIPTIVE')

    Returns:
        Valor normalizado
    """
    if not raw_value:
        return 'SIN DATO'

    # V6.3.19 FIX CRГЌTICO: Si tipo_valor es DESCRIPTIVE, NO normalizar
    # Preservar texto completo para biomarcadores descriptivos (ej: HER2 con score)
    # Solo limpiar espacios, sin convertir a mayГєsculas ni normalizar valores
    import re
    if value_type == 'DESCRIPTIVE':
        value_clean = raw_value.strip()
        # Reemplazar \n, \r, \t con espacio
        value_clean = re.sub(r'[\n\r\t]+', ' ', value_clean)
        # Reemplazar espacios mГєltiples con uno solo
        value_clean = re.sub(r'\s+', ' ', value_clean)
        value_clean = value_clean.strip()

        # V6.3.61 FIX IHQ250074: Limpieza de valores mal capturados de HER2
        # Problema: PatrГіn general captura "/NEU (SCORE 0)" en lugar del valor correcto
        # SoluciГіn: Detectar y corregir patrones errГіneos

        # Caso 1: Valor empieza con "/NEU" o "NEU" - error de captura del patrГіn general
        if re.match(r'^/?NEU\s*', value_clean, re.IGNORECASE):
            # Extraer el score si existe
            score_match = re.search(r'\(SCORE\s*(\d+\+?)\)', value_clean, re.IGNORECASE)
            if score_match:
                score = score_match.group(1)
                # Score 0 = NEGATIVO, Score 3+ = POSITIVO, Score 1+ o 2+ = valor correspondiente
                if score == '0':
                    return "NEGATIVO (Score 0)"
                elif score == '3+' or score == '3':
                    return "POSITIVO (Score 3+)"
                else:
                    return f"NEGATIVO (Score {score})"

        # Caso 2: "No hay marcaciГіn de las cГ©lulas tumorales (Score X)" в†’ "NEGATIVO (Score X)"
        patrones_negativo_her2 = [
            r'no hay marcaci[oГі]n',
            r'sin marcaci[oГі]n',
            r'ausencia de marcaci[oГі]n',
        ]
        for patron in patrones_negativo_her2:
            if re.search(patron, value_clean, re.IGNORECASE):
                # Extraer el score si existe
                score_match = re.search(r'\(Score\s*(\d+\+?)\)', value_clean, re.IGNORECASE)
                if score_match:
                    return f"NEGATIVO (Score {score_match.group(1)})"
                return "NEGATIVO"

        # V6.3.74 FIX IHQ250102: Detectar cuando solo hay especificaciГіn de anticuerpo sin resultado real
        # Caso 3: "PATHWAY anti-HER-2/Neu (4B5)" в†’ solo anticuerpo, NO hay resultado de HER2
        # Indicadores de especificaciГіn de anticuerpo sin resultado:
        # - "PATHWAY" al inicio (nombre comercial del anticuerpo)
        # - "anti-HER" (descripciГіn del anticuerpo)
        # - "Rabbit Monoclonal" (tipo de anticuerpo)
        # - "VENTANA Ref." (referencia del fabricante)
        # - NO tiene palabras clave de resultado: negativo, positivo, score, equivoco
        patrones_solo_anticuerpo = [
            r'^PATHWAY\s+anti',           # Inicia con "PATHWAY anti-..."
            r'^CONFIRM\s+anti',           # Inicia con "CONFIRM anti-..."
            r'Rabbit\s+Monoclonal',       # Contiene tipo de anticuerpo
            r'VENTANA\s+Ref\.',           # Contiene referencia del fabricante
        ]
        # Verificar si es solo especificaciГіn de anticuerpo
        es_solo_anticuerpo = False
        for patron_anticuerpo in patrones_solo_anticuerpo:
            if re.search(patron_anticuerpo, value_clean, re.IGNORECASE):
                es_solo_anticuerpo = True
                break

        if es_solo_anticuerpo:
            # Verificar que NO contiene resultado real (negativo, positivo, score, equivoco)
            tiene_resultado = re.search(r'(?i)negativ|positiv|score\s*\d|equi?v[oГ­]', value_clean)
            if not tiene_resultado:
                # Es solo especificaciГіn de anticuerpo, NO hay resultado de HER2
