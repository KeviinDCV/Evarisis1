    # V6.4.23 PASE FINAL (PRIORIDAD MГЃXIMA): FIX IHQ250162 - PatrГіn "No presentan expresiГіn para [lista]" в†’ NEGATIVO
    # Ej: "No presentan expresiГіn para calretinina, desmina, SMA, EMA, progesterona, CD34, GFAP, p53"
    # CRГЌTICO: Este patrГіn se ejecuta AL FINAL para sobrescribir valores incorrectos capturados por patrones anteriores
    # Motivo: PatrГіn "positivas de manera focal para" puede capturar incorrectamente biomarcadores de frase siguiente
    no_presentan_expresion_pattern = r'(?i)No\s+presentan?\s+expresi[Гіo]n\s+para\s+([A-Za-z0-9\s,./\-yY]+?)(?:\.\s|\.$|$)'
    for match in re.finditer(no_presentan_expresion_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"рџ”Ќ [V6.4.23 PASE FINAL - No presentan expresiГіn] Lista detectada: '{lista_biomarkers_raw}'")

        # Limpiar saltos de lГ­nea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # Separar por comas Y "y"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw:
                continue

            # Normalizar nombre del biomarcador (maneja typos como CKE1E3 в†’ CKAE1E3)
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                # FORZAR NEGATIVO - sobrescribe SIEMPRE valores anteriores (incluso "POSITIVO (focal)" incorrecto)
                valor_anterior = results.get(normalized_name, 'NO EXISTГЌA')
                results[normalized_name] = 'NEGATIVO (0)' if normalized_name == 'HER2' else 'NEGATIVO'
                logging.info(f"рџ”ґ [PASE FINAL v6.4.23] FORZANDO: {normalized_name} = NEGATIVO (era: {valor_anterior}) desde 'No presentan expresiГіn'")

    # V6.4.89 FIX IHQ250218: POST-PROCESAMIENTO - Eliminar CD3/BCL2 si provienen de "linfocitos T acompaГ±antes"
    # Problema: Linfomas B tienen linfocitos T acompaГ±antes (cГ©lulas normales, NO tumorales)
    # Formato OCR: "Hay linfocitos T acompaГ±antes CD3+, BCL2+" в†’ CD3/BCL2 NO deben reportarse
    # SoluciГіn: Si detectamos el patrГіn de cГ©lulas acompaГ±antes Y tenemos CD3/BCL2 extraГ­dos, eliminarlos
    # Nota: Buscar tanto 'CD3' como 'IHQ_CD3' porque depende de la fuente de extracciГіn
    if 'CD3' in results or 'IHQ_CD3' in results or 'BCL2' in results or 'IHQ_BCL2' in results:
        # Buscar patrГіn de cГ©lulas acompaГ±antes en el texto
        acompanantes_pattern = r'(?i)(?:hay\s+)?linfocitos?\s+T\s+acompa[Г±n]antes\s+(?:CD\s*3|BCL\s*2)'
        if re.search(acompanantes_pattern, text):
