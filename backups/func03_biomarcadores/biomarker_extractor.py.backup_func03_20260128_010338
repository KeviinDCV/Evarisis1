        # V6.1.5: Nuevo patrГіn "Hay positividad para celulas mioepiteliales X y Y" (IHQ251007)
        r'(?:Hay|hay)\s+positividad\s+para\s+(?:celulas|cГ©lulas)\s+(?:mioepiteliales\s+)?((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeГ‰ГіГ“\n])+?)(?=\.|$)',
        r'expresan\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeГ‰ГіГ“\n])+?)\s+y\s+c[eГ©]lulas',
        r'expresan\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeГ‰ГіГ“\n])+?)(?=\s+y\s+c[eГ©]lulas|\.|$)',
        r'muestran\s+positividad\s+para\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeГ‰ГіГ“\n])+?)(?=\s+y\s+c[eГ©]lulas|\.|$)',
        r'con\s+marcaci[Гіo]n\s+positiva\s+para\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeГ‰ГіГ“\n])+?)\s+y\s+c[eГ©]lulas',
        r'con\s+marcaci[Гіo]n\s+positiva\s+para\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeГ‰ГіГ“\n])+?)(?=\s+y\s+c[eГ©]lulas|\.|$|,\s*(?:son|siendo)?\s*negativ[ao]s?)',
        # V6.4.3 FIX IHQ250120: PatrГіn para listas que terminan en "son negativas"
        r'((?:(?!son\s+positiv[oa]s?|son\s+negativ[oa]s?)[\w\s,./\-\(\)+yYeГ‰ГіГ“\n])+?)\s+son\s+negativ[oa]s?',
    ]

    for patron in patrones_narrativo:
        matches = re.finditer(patron, texto_microscopica, re.IGNORECASE)

        for match in matches:
            # V6.4.46 FIX IHQ250184: FILTRO - Excluir contextos de "estudios solicitados" (descripciГіn macroscГіpica)
            # Problema: "se procesa estudio...para marcaciГіn con CA19-9, HER2, TTF-1" se marcaba como POSITIVO
            # SoluciГіn: Detectar contexto previo (100 caracteres antes) y descartar si es lista de estudios a realizar
            contexto_previo = texto_microscopica[max(0, match.start() - 100):match.start()].upper()
            contextos_excluidos = [
                'SE PROCESA ESTUDIO',
                'SE ORDENAN MARCADORES',
                'PARA MARCACIГ“N CON',
                'PARA MARCACION CON',
                'ESTUDIO DE INMUNOHISTOQUГЌMICA PARA MARCACIГ“N',
                'ESTUDIO DE INMUNOHISTOQUIMICA PARA MARCACION',
                'SE SOLICITAN ESTUDIOS',
                'ESTUDIOS SOLICITADOS'
            ]
            if any(contexto in contexto_previo for contexto in contextos_excluidos):
                # Saltar este match: es una lista de estudios solicitados, no resultados
                continue

            # V6.3.77 FIX IHQ250116: Manejar mГєltiples grupos si el patrГіn tiene intensidad
            if len(match.groups()) >= 2:
                # Si el patrГіn mismo tiene un indicador negativo
                match_full = match.group(0).upper()
                if 'NO SE DETECTA' in match_full or 'NEGATIV' in match_full:
                    intensidad_raw = None
                    lista_texto = match.group(2).strip()
                    estado_defecto = 'NEGATIVO'
                else:
                    # El grupo 1 es intensidad, el grupo 2 es la lista
                    intensidad_raw = match.group(1).strip().upper()
                    lista_texto = match.group(2).strip()
                    estado_defecto = 'POSITIVO'
            else:
                intensidad_raw = None
                lista_texto = match.group(1).strip()
                # V6.4.3 FIX IHQ250120: Detectar estado negativo en patrГіn de un solo grupo (ej: son negativas)
                match_full = match.group(0).upper()
                if 'NO SE DETECTA' in match_full or 'NEGATIV' in match_full:
                    estado_defecto = 'NEGATIVO'
                else:
                    estado_defecto = 'POSITIVO'

            # V6.4.65 FIX IHQ250203: Pre-procesar calificadores individuales por biomarcador
            # Problema: "p16 ( en bloque ) y p63" asignaba "(bloque)" a ambos biomarcadores
            # SoluciГіn: Extraer calificadores especГ­ficos ANTES de separar la lista

            # Detectar calificadores individuales: "BIOMARCADOR ( calificador )"
            # PatrГіn: nombre seguido de parГ©ntesis con contenido
            calificadores_individuales = {}
            patron_calificador = r'([A-Za-z0-9\-/]+)\s*\(\s*(.+?)\s*\)'
            for match_calif in re.finditer(patron_calificador, lista_texto, re.IGNORECASE):
                biomarcador_raw = match_calif.group(1).strip()
                calificador_texto = match_calif.group(2).strip()
                # Normalizar nombre del biomarcador
                bio_norm = normalize_biomarker_name(biomarcador_raw)
                if bio_norm:
                    # Guardar calificador especГ­fico para este biomarcador
                    calificadores_individuales[bio_norm] = calificador_texto

            # Limpiar calificadores entre parГ©ntesis de la lista para parsing normal
            lista_texto_clean = re.sub(r'\(\s*[^)]+\s*\)', '', lista_texto)
            lista_texto = lista_texto_clean.strip()

            # V6.3.85 FIX IHQ250111: Detectar contexto de valor especial GLOBAL (aplicable a todos)
            # Si dice "positividad en mosaico", el valor debe reflejarlo
            match_full = match.group(0).upper()
            special_value_global = None
            if estado_defecto == 'NEGATIVO':
                special_value_global = 'NEGATIVO'
            elif 'MOSAICO' in match_full:
                special_value_global = 'POSITIVO (mosaico)'
            # V6.3.87 FIX IHQ250112: "positivo en todo el espesor del epitelio"
            elif 'TODO EL ESPESOR' in match_full:
                special_value_global = 'POSITIVO (todo el espesor)'

            # V6.4.65: No usar special_value global para "BLOQUE" - ahora se maneja individualmente
            special_value = special_value_global
            
            # V6.3.88 FIX IHQ250113: Captura de intensidad/patrГіn (fuerte, difuso, focal)
            # Solo si no se ha asignado un valor especial mГЎs especГ­fico (como bloque/mosaico)
            if not special_value:
                descriptors = []
                # V6.3.77 FIX IHQ250116: Usar intensidad capturada del regex si existe
                if intensidad_raw:
                    if 'FOCAL' in intensidad_raw: descriptors.append('focal')
                    elif 'MAYORITARIA' in intensidad_raw: descriptors.append('mayoritaria')
                    elif 'FUERTE' in intensidad_raw: descriptors.append('fuerte')
                    elif 'DIFUSA' in intensidad_raw: descriptors.append('difusa')
                
                # Solo buscar en match_full si no se ha detectado en intensidad_raw
                if not descriptors:
                    if 'FUERTE' in match_full or 'INTENSA' in match_full:
                        descriptors.append('fuerte')
                    if 'DIFUSA' in match_full:
                        descriptors.append('difusa')
                    if 'FOCAL' in match_full:
                        descriptors.append('focal')
                    if 'MODERADA' in match_full:
                        descriptors.append('moderada')
                
                if descriptors:
                    special_value = f"POSITIVO ({' y '.join(descriptors)})"

            # V6.0.5: Usar parser inteligente para procesar la lista
            biomarcadores_dict = parse_narrative_biomarker_list(lista_texto, biomarker_definitions, default_state=estado_defecto, debug_mode=debug_mode)

            # V6.4.65 FIX IHQ250203: Agregar biomarcadores con calificadores individuales
            for col, valor in biomarcadores_dict.items():
                # Primero verificar si hay un calificador GLOBAL (aplica a todos)
                if special_value:
                    valor = special_value
                else:
                    # V6.4.65: Verificar si este biomarcador especГ­fico tiene un calificador individual
                    # Extraer nombre normalizado de la columna (ej: "IHQ_P16_ESTADO" -> "P16")
                    bio_name = col.replace('IHQ_', '').replace('_ESTADO', '')
                    if bio_name in calificadores_individuales:
                        calificador = calificadores_individuales[bio_name]
                        # Aplicar calificador solo a este biomarcador
                        if valor in ['POSITIVO', 'NEGATIVO']:
                            valor = f"{valor} ({calificador})"

                # V6.4.65 FIX IHQ250203: SOBRESCRIBIR valores genГ©ricos con calificadores individuales
                # Si este biomarcador tiene calificador individual, SIEMPRE sobrescribir
                # (incluso si ya existe un valor genГ©rico "POSITIVO" sin calificador)
                bio_name = col.replace('IHQ_', '').replace('_ESTADO', '')
                if bio_name in calificadores_individuales:
                    # Este biomarcador tiene calificador especГ­fico в†’ SOBRESCRIBIR siempre
                    resultados[col] = valor
                elif col not in resultados:
                    # No tiene calificador individual в†’ solo agregar si no existe
                    resultados[col] = valor

    return resultados


def parse_narrative_biomarker_list(biomarker_text: str, biomarker_definitions: Dict[str, Any] = None, default_state: str = 'POSITIVO', debug_mode: bool = False) -> Dict[str, str]:
    """Parsea una lista narrativa de biomarcadores y retorna diccionario con valores.

    VersiГіn: 6.0.6 - Agregado default_state para evitar sobrescrituras incorrectas

    Ejemplos de entrada:
    - "CKAE1E3, CK7 Y CAM 5.2"
    - "GFAP, S100 y SOX10"
    - "HER2, Ki-67 y Receptor de EstrГіgenos"

    Args:
        biomarker_text: Texto con lista de biomarcadores (ej: "CKAE1E3, CK7 Y CAM 5.2")
        biomarker_definitions: Diccionario con definiciones de biomarcadores (BIOMARKER_DEFINITIONS)

    Returns:
        Dict con claves IHQ_* y valores "POSITIVO"

    Ejemplo:
        Input: "CKAE1E3, CK7 Y CAM 5.2"
        Output: {'IHQ_CKAE1AE3': 'POSITIVO', 'IHQ_CK7': 'POSITIVO', 'IHQ_CAM52': 'POSITIVO'}
    """
    if not biomarker_text:
        return {}

    if biomarker_definitions is None:
        biomarker_definitions = BIOMARKER_DEFINITIONS

    # Normalizar texto: quitar saltos de lГ­nea, mГєltiples espacios
    text_clean = ' '.join(biomarker_text.split())
    text_clean = text_clean.upper()

    # V6.2.7: FIX IHQ251026 - Separar biomarcadores pegados sin coma
    # Ej: "CK7 CAM 5.2" в†’ "CK7, CAM 5.2"
    # PatrГіn: [A-Z]+\d+ seguido de espacio y otro [A-Z]+ (sin nГєmero intermedio)
    # Excepciones: No separar "5.2", "5/6" (parte del nombre del biomarcador)
    text_clean = re.sub(r'([A-Z]+\d+)\s+([A-Z]{2,}(?:\s+\d))', r'\1, \2', text_clean)

    # V6.3.94: Romper por comas, punto y coma, y "ni"
    # V6.3.77: Agregar "NI " como separador
    # V6.4.2 FIX IHQ250119: Manejar "siendo negativo para" como separador que cambia el estado
    text_clean = re.sub(r'\bNI\s+(?:DE\s+)?', ', ', text_clean)
    text_clean = re.sub(r'\bSIENDO\s+NEGATIV[OA]\s+PARA\b', ', NEGATIVO PARA ', text_clean)
    raw_segments = re.split(r'[,;]\s*', text_clean)
    
    parts = []
    # V6.3.94 FIX IHQ250115: Detectar si el segmento completo termina en estado negativo (ej: "A y B negativos")

    # Si es asГ­, evitaremos romper por 'y' para preservar la relaciГіn
    for segment in raw_segments:
        segment_upper = segment.upper()
        # Si termina en NEGATIVO/POSITIVO, no romper por "Y" si son marcadores
        prevenir_split_y = False
        if re.search(r'\s+(?:NEGATIVO|NEGATIVA|POSITIVO|POSITIVA|POSITIVAS)\s*$', segment_upper):
             prevenir_split_y = True
             
        # Solo romper por "y"/"e"/"ni" si lo que sigue parece un marcador conocido (o variante)
        # Esto evita romper "fuerte y difusa"
        # Buscamos " Y ", " E ", " NI ", " NI DE " rodeados de espacios
        y_split_pattern = r'\s+(?:Y|E|NI(?:\s+DE)?)\s+'
        sub_segments = []
        
        last_idx = 0
        for m in re.finditer(y_split_pattern, segment):
            if prevenir_split_y: continue # V6.3.94
            text_after = segment[m.end():].strip()
            # Si el texto tras el 'y'/'ni' empieza con algo que parece un marcador
            # O si el texto previo termina en algo que parece un marcador
            is_new_marker = False
            # V6.3.77: HeurГ­stica mГЎs simple para 'y' en listas de biomarcadores
            if re.search(r'^[A-Z]{1,10}\s?\d?\d?', text_after) or re.search(r'^[Rr]eceptor', text_after, re.IGNORECASE):
                is_new_marker = True
            else:
                for marker_id, def_val in biomarker_definitions.items():
                    keywords = [marker_id.upper()] + [n.upper() for n in def_val.get('nombres_alternativos', [])]
                    for kw in keywords:
                        if re.search(rf'^{re.escape(kw)}\b', text_after, re.IGNORECASE):
                            is_new_marker = True
                            break
                    if is_new_marker: break
            
            if is_new_marker:
                sub_segments.append(segment[last_idx:m.start()].strip())
                last_idx = m.end()
        
        sub_segments.append(segment[last_idx:].strip())
        parts.extend(sub_segments)
    
    # Limpiar cada parte y normalizar
    biomarkers_found = []
    for part in parts:
        part = part.strip()
        # V6.4.3 FIX IHQ250120: Limpiar ruido tГ­pico de introducciones de lista (ej: "Las inmunotinciones con todos los marcadores descritos (SOX-10")
        # V6.4.5: Limpiar prefijos adicionales como ". LOS MARCADORES"
        part = re.sub(r'^(?:\.*?\s*)?(?:LAS\s+INMUNOTINCIONES|LOS\s+MARCADORES|DE\s+MANERA|LOS\s+MARCADORES)\s+.*?\s*\(', '', part, flags=re.IGNORECASE)
        part = re.sub(r'^(?:\.*?\s*)?(?:LOS\s+MARCADORES|MARCADORES|EL\s+INDICE\s+DE\s+PROLIFERACION)\s+', '', part, flags=re.IGNORECASE)
        # Quitar puntos iniciales/residuales
        part = re.sub(r'^[.\s:]+', '', part).strip()
        # Quitar parГ©ntesis al inicio/fin solamente si no envuelven un score (V6.4.7)
        if part.startswith('(') and not re.match(r'^\([0-3]\+?\)', part):
            part = part[1:].strip()
        if part.endswith(')') and not re.search(r'\([0-3]\+?\)$', part):
            part = part[:-1].strip()
        if part:
            biomarkers_found.append(part)
    
    if debug_mode:
        logging.info(f"рџ”Ќ [parse_narrative_biomarker_list] Partes identificadas: {biomarkers_found}")

    # Mapear biomarcadores usando un escaneo de palabras clave (V6.3.94)
    result = {}
    for part in biomarkers_found:
        part_upper = part.upper()
        
        # 1. Detectar el estado base de esta parte
        # Si la parte contiene "negativo", etc., el estado base es NEGATIVO
        estado_base = default_state
        # V6.3.94 FIX IHQ250115: Evitar que "y es negativo para" afecte a marcadores ANTES de esa frase
        # Si detectamos "Y ES NEGATIVO PARA", dividimos la parte
        if ' Y ES NEGATIVO PARA ' in part_upper:
            # Procesar lo de antes como POSITIVO y lo de despuГ©s como NEGATIVO
            sub_parts_mixed = part_upper.split(' Y ES NEGATIVO PARA ')
            # Procesar sub_parts_mixed[0] con estado POSITIVO
            # Procesar sub_parts_mixed[1] con estado NEGATIVO
            # Para simplificar, transformamos la parte actual en una que procesaremos recursivamente o por partes
            # Pero como estamos dentro del loop de 'parts', mejor ajustamos el estado dinГЎmicamente
            pass 

        if re.search(r'\b(?:NEGATIVO|NEGATIVA|NO\s+SE\s+OBSERVA|EXPRESI[Г“O]N\s+PERDIDA|NO\s+SE\s+DETECTA)\b', part_upper):
             # Solo si no es el caso mixto complejo
             if ' Y ES NEGATIVO PARA ' not in part_upper:
                estado_base = 'NEGATIVO'
            
        # 2. Buscar TODOS los marcadores conocidos dentro de esta parte
        marcodores_en_parte = []

        # V6.4.47 FIX IHQ250185: Limpiar calificadores ANTES de normalizar
        # "p53 sobre expresado" в†’ "p53" (calificador: sobreexpresado)
        # "receptor de estrГіgenos" в†’ ya tiene alias en ER definition
        # "PAX 8" в†’ "PAX8" (quitar espacio interno)
        part_limpio = part
        calificador_detectado = None

        # Detectar y extraer calificadores comunes
        calificadores_pattern = r'\b(sobre\s+expresado|sobreexpresado|mutado|mutada|wild\s+type|salvaje)\b'
        match_calificador = re.search(calificadores_pattern, part, re.IGNORECASE)
        if match_calificador:
            calificador_detectado = match_calificador.group(1).upper()
            # Remover calificador del nombre para normalizaciГіn
            part_limpio = re.sub(calificadores_pattern, '', part, flags=re.IGNORECASE).strip()

        # Primero probar match exacto (vГ­a normalize_biomarker_name)
        col_directa = normalize_biomarker_name(part_limpio)
        if col_directa:
            col_id = col_directa if col_directa.startswith('IHQ_') else f'IHQ_{col_directa}'
            
            # V6.4.47: Aplicar calificador detectado si existe (ej: "p53 sobre expresado")
            estado_local = estado_base
            if calificador_detectado:
                estado_local = f'{estado_base} ({calificador_detectado})'
            # V6.4.9: Default scores for HER2 if missing context (solo si no hay calificador explГ­cito)
            elif 'HER2' in col_id:
                if estado_base == 'NEGATIVO': estado_local = 'NEGATIVO (0)'
                elif estado_base == 'POSITIVO': estado_local = 'POSITIVO (3+)'
                elif estado_base == 'EQUIVOCO': estado_local = 'EQUIVOCO (2+)'

            marcodores_en_parte.append((col_id, estado_local))
        else:
            # Escaneo dinГЎmico por nombres alternativos
            for m_id, m_def in biomarker_definitions.items():
                nombres = [m_id] + m_def.get('nombres_alternativos', [])
                for nombre in nombres:
                    # Buscar el nombre como palabra completa (escapando caracteres especiales como /)
                    # V6.3.77: Mejor manejo de nombres con /
                    nombre_esc = re.escape(nombre.upper())
                    if '/' in nombre_esc:
                        # Si tiene slash, no usamos \b inicial porque / no es word char
                        # Pero el nombre suele empezar con letra (CK)
                        pattern_nombre = rf'{nombre_esc}\b'
                    else:
                        pattern_nombre = rf'\b{nombre_esc}\b'
                    
                    if re.search(pattern_nombre, part_upper):
                        col_id = m_id if m_id.startswith('IHQ_') else f'IHQ_{m_id}'
                        
                        # V6.4.5 FIX IHQ250133: DetecciГіn de valores especГ­ficos locales (equГ­voco, salvaje, mutado)
                        # Inicializar con el estado por defecto de la lista/parte
                        estado_local = default_state
                        
                        # V6.4.7: Detectar score real si existe (ej: "HER2 negativo (1+)")
                        match_score = re.search(r'\(\s*([0-3]\+?)\s*\)', part_upper)
                        score_suffix = f" ({match_score.group(1)})" if match_score and 'HER2' in col_id else ""

                        # Buscar en la parte del texto correspondiente a este biomarcador
                        if 'EQUГЌVOCO' in part_upper or 'EQUIVOCO' in part_upper:
                            # Solo si es HER2 o similar (HER2 es el caso principal de equГ­voco)
                            if 'HER2' in col_id:
                                estado_local = f'EQUIVOCO{score_suffix if score_suffix else " (2+)"}'
                            else:
                                estado_local = 'EQUIVOCO'
                        elif 'SALVAJE' in part_upper or 'WILD TYPE' in part_upper:
                            # TГ­pico de p53
                            # V6.4.28: Detectar si incluye "en mosaico" para formato completo
                            # Formato estГЎndar: POSITIVO + (descripciГіn)
                            if 'EN MOSAICO' in part_upper or 'MOSAICO' in part_upper:
                                estado_local = 'POSITIVO (patrГіn salvaje - mosaico)'
                            else:
                                estado_local = 'POSITIVO (PATRГ“N SALVAJE)'
                        elif 'MUTADO' in part_upper and 'NO' not in part_upper:
                            estado_local = 'POSITIVO (MUTADA)'
                        elif 'NEGATIV' in part_upper or 'NO SE OBSERVA' in part_upper:
                            # V6.4.9: Default score (0) for HER2 if missing
                            if 'HER2' in col_id and not score_suffix:
                                estado_local = 'NEGATIVO (0)'
                            else:
                                estado_local = f'NEGATIVO{score_suffix}'
                        else:
                            # V6.4.47: Aplicar calificador detectado si existe (ej: "p53 sobre expresado")
                            if calificador_detectado:
                                estado_local = f'{default_state} ({calificador_detectado})'
                            # V6.4.7: Aplicar score al estado por defecto si existe (ej: "HER2 positivo (3+)")
                            # V6.4.9: Default score (3+) for HER2 if missing and state is POSITIVO
                            elif 'HER2' in col_id and not score_suffix and default_state == 'POSITIVO':
                                estado_local = 'POSITIVO (3+)'
                            else:
                                estado_local = f'{default_state}{score_suffix}'
                        
                        marcodores_en_parte.append((col_id, estado_local))
                        break # Encontrado este marcador, pasar al siguiente marker_id
        
        # 3. Agregar resultados encontrados
        for cid, est in marcodores_en_parte:
            # V6.3.47: Manejar sufijo _ESTADO para P16/P40
            if cid in ['IHQ_P16', 'IHQ_P40']:
                cid = f'{cid}_ESTADO'
            # V6.3.94: Solo guardar si no estГЎ ya o si el nuevo valor es mГЎs especГ­fico (NEGATIVO gana en conflictos de lista)
            if cid not in result or est == 'NEGATIVO':
                result[cid] = est

    return result


