    # Este bloque se ejecuta AL FINAL para garantizar que indicadores explГ­citos
    # de NEGATIVO tengan la Гєltima palabra sobre cualquier extracciГіn anterior.
    #
    # Problema: Patrones genГ©ricos extraen de listas como "tinciГіn con: CD20, CD79..."
    # y marcan todo como POSITIVO. Luego patrones NEGATIVO intentan corregir pero
    # pueden ejecutarse antes o el valor ya fue sobrescrito.
    #
    # SoluciГіn: Ejecutar patrones NEGATIVO explГ­citos AL FINAL con sobrescritura forzada.
    # в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

    # PatrГіn 1: "marcaciГіn negativa/negativo para X, Y, Z"
    # V6.4.12 FIX IHQ250149: Captura "negativo" (masculino) ademГЎs de "negativa" (femenino)
    # Ej: "con marcaciГіn negativo para MDM2, CDK4, DESMINA, AML" (error de concordancia en informe)
    final_marcacion_neg = re.findall(
        r'(?i)marcaci[Гіo]n\s+negativ[ao]\s+para\s+([A-Za-z0-9\s,\-/]+?)(?=,\s*[Ee]s\s+[Pp]ositiv|\s+es\s+Positiv|,\s*Con\s+marcaci[oГі]n|\s+Linfocitos|\.\s|$)',
        text
    )
    for match in final_marcacion_neg:
        # Separar por comas
        biomarkers = re.split(r'\s*,\s*', match.strip())
        for bio in biomarkers:
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized:
                    valor_anterior = results.get(normalized, 'NO EXISTГЌA')
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"рџ”ґ [PASE FINAL v6.3.77] FORZANDO: {normalized} = NEGATIVO (era: {valor_anterior}) desde 'marcaciГіn negativa para'")

    # PatrГіn 2: "Negativo para X, Y, Z" (al inicio de oraciГіn o despuГ©s de punto)
    final_negativo_para = re.findall(
        r'(?i)(?:^|\.\s*)Negativo\s+para\s+([A-Za-z0-9\s,\-]+?)(?=\s+Linfocitos|\s+cГ©lulas|\s+acompaГ±antes|\.\s|,\s+diagn[oГі]stico|$)',
        text
    )
    for match in final_negativo_para:
        # Separar por comas
        biomarkers = re.split(r'\s*,\s*', match.strip())
        for bio in biomarkers:
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized:
                    valor_anterior = results.get(normalized, 'NO EXISTГЌA')
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"рџ”ґ [PASE FINAL v6.3.77] FORZANDO: {normalized} = NEGATIVO (era: {valor_anterior}) desde 'Negativo para'")

    # PatrГіn 3: "tienen marcaciГіn negativa para X" (contexto narrativo completo)
    final_tienen_neg = re.findall(
        r'(?i)tienen\s+marcaci[Гіo]n\s+negativa\s+para\s+([A-Za-z0-9\s,\-]+?)(?=,\s*Con|\.\s|$)',
        text
    )
    for match in final_tienen_neg:
        biomarkers = re.split(r'\s*,\s*', match.strip())
        for bio in biomarkers:
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized:
