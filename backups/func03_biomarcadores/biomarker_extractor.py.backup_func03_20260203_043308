            results[normalized_name] = 'POSITIVO'
            logging.info(f"✅ [marcación simple] Extraído: '{bio_raw}' → {normalized_name} = POSITIVO")

    # V6.3.70 FIX IHQ250096: Patrones de linfoma/hematopatología
    # =========================================================================

    # Patrón 1: "inmunotinción para CD3, CD5, CD7" → POSITIVO
    # Ej: "La proliferación celular es de linaje T con inmunotinción para CD3, CD5, CD7"
    inmunotincion_para_pattern = r'(?i)inmunotinci[óo]n\s+para\s+([A-Za-z0-9\s,\-]+?)(?=,\s+así|;|\.|$)'
    for match in re.finditer(inmunotincion_para_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()
        logging.info(f"🔍 [V6.3.70 inmunotinción para] Lista detectada: '{lista_biomarkers_raw}'")

        # Separar por comas y espacios
        biomarcadores_encontrados = re.split(r'[,]\s*|\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.,')
