    # Patrón 3: "sin inmunomarcación para CD10, CD117, CD34 ni CD56" → NEGATIVO
    # Ej: "sin inmunomarcación para CD10, CD117, CD34 ni CD56"
    sin_inmunomarcacion_pattern = r'(?i)sin\s+inmunomarcaci[óo]n\s+para\s+([A-Za-z0-9\s,\-]+?)(?:\s+ni\s+([A-Za-z0-9\-]+))?(?=\.|\s*$)'
