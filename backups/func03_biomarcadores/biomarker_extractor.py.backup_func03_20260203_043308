                    logging.info(f"✅ [inmunotinción para] Extraído: '{bio_raw}' → {normalized_name} = POSITIVO (prev: {valor_anterior})")

    # Patrón 2: "marcación doble positiva para CD4 y CD8" → POSITIVO
    # Ej: "así como marcación doble positiva para CD4 y CD8"
    marcacion_doble_pattern = r'(?i)marcaci[óo]n\s+doble\s+positiva\s+para\s+([A-Za-z0-9\s,y\-]+?)(?=;|\.|$)'
    for match in re.finditer(marcacion_doble_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()
        logging.info(f"🔍 [V6.3.70 marcación doble positiva] Lista detectada: '{lista_biomarkers_raw}'")

        # Separar por "y" y comas
        biomarcadores_encontrados = re.split(r'[,]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.,')
            if not bio_raw or len(bio_raw) < 2:
                continue
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                # V6.3.70b: Sobrescribir "NO MENCIONADO" - patrón de alta confianza
                valor_anterior = results.get(normalized_name, '')
                if normalized_name not in results or valor_anterior in ['NO MENCIONADO', 'N/A', '']:
                    results[normalized_name] = 'POSITIVO'
