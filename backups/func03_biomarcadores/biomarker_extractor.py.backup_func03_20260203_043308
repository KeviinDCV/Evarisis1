def extract_single_biomarker(
    text: str,
    biomarker_name: str,
    definition: Dict[str, Any]
) -> Optional[str]:
    """Extrae un biomarcador específico del texto

    Args:
        text: Texto del informe
        biomarker_name: Nombre del biomarcador (ej: 'HER2')
        definition: Definición del biomarcador de la configuración

    Returns:
        Valor del biomarcador normalizado o None si no se encuentra
    """
    # V6.5.35 FIX IHQ250239: MMR markers con protocolo CAP necesitan buscar PRIMERO en DESCRIPCIÓN MICROSCÓPICA
    # Patrón "Resultado de [MARKER]:" solo existe en DESCRIPCIÓN MICROSCÓPICA, no en DIAGNÓSTICO
    # Si se busca primero en DIAGNÓSTICO, patrones genéricos capturan fragmentos incorrectos de listas
    if biomarker_name in ['MLH1', 'MSH2', 'MSH6', 'PMS2'] and definition.get('usa_prioridad_seccion', False):
        # Para MMR, buscar PRIMERO en DESCRIPCIÓN MICROSCÓPICA
        for pattern in definition.get('patrones', []):
            valor_microscopica = buscar_en_microscopica(text, pattern)
            if valor_microscopica:
                # Normalizar
                normalized = normalize_biomarker_value(
                    valor_microscopica,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )
                if normalized:
                    return normalized

        # LUEGO buscar en DIAGNÓSTICO (fallback)
        for pattern in definition.get('patrones', []):
            valor_diagnostico = buscar_en_diagnostico(text, pattern)
            if valor_diagnostico:
                # Normalizar
                normalized = normalize_biomarker_value(
                    valor_diagnostico,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )
                if normalized:
                    return normalized

        # FINALMENTE buscar en texto completo (fallback final)
        for pattern in definition.get('patrones', []):
            match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
            if match:
                # Obtener valor capturado
                if match.groups():
                    raw_value = match.group(1).strip()
                else:
                    raw_value = match.group(0).strip()

                # Normalizar
                normalized = normalize_biomarker_value(
                    raw_value,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )
                if normalized:
                    return normalized

        return None

    if biomarker_name == 'KI67' and definition.get('usa_prioridad_seccion', False):
        # V6.5.37 FIX IHQ250242: Ki67 debe PRIORIZAR porcentaje sobre cualitativo
        # Problema: Texto con "Ki67 positivo" primero y "Ki67 en un 80%" después → capturaba "POSITIVO"
        # Solución: Buscar TODOS los valores, retornar porcentaje si existe, cualitativo solo como fallback
        valor_cualitativo = None
        valor_porcentaje = None

        # Buscar TODOS los matches en DESCRIPCIÓN MICROSCÓPICA
        for pattern in definition.get('patrones', []):
            valor_microscopica = buscar_en_microscopica(text, pattern)
            if valor_microscopica:
                # V6.3.14: CRÍTICO - Validación "expresión limitada" ANTES de normalizar
                if 'expresi' in valor_microscopica.lower() and 'limitada' in valor_microscopica.lower():
                    return "EXPRESIÓN LIMITADA A CAPA BASAL"

                # V6.5.37: Clasificar si es porcentaje o cualitativo
                if re.match(r'^\d+%?$', valor_microscopica) or re.search(r'\d+%', valor_microscopica):
                    # Es un porcentaje → tiene MÁXIMA PRIORIDAD
                    if not valor_porcentaje:  # Guardar primer porcentaje encontrado
                        valor_porcentaje = valor_microscopica
                elif valor_microscopica.upper() in ['POSITIVO', 'NEGATIVO']:
                    # Es cualitativo → BAJA PRIORIDAD
                    if not valor_cualitativo:
                        valor_cualitativo = valor_microscopica

        # V6.5.37: PRIORIDAD 1 - Retornar porcentaje si existe
        if valor_porcentaje:
            # V6.3.36 FIX IHQ250029: Buscar "menor" en el TEXTO REAL, no en el patrón
            # El texto original puede tener "Ki 67 menor al 20%" pero el patrón captura solo "20"
            # V6.3.59 FIX IHQ250071: También buscar "menos del" (diferente de "menor del")
            # Buscar directamente en la sección microscópica si hay "menor al/del [valor]%" o "menos del [valor]%"
            seccion_micro = extraer_seccion(text, r"DESCRIPCI[ÓO]N\s+MICROSC[ÓO]PICA", r"DIAGN[ÓO]STICO|EXPRESI[ÓO]N\s+MOLECULAR|RESPONSABLE")
            if seccion_micro and re.search(rf'(?i)ki[^\w]*67\s+(?:es\s+bajo\s*\()?(?:menor\s+(?:al|del)|menos\s+del)\s+{re.escape(valor_porcentaje)}\s*%?\)?', seccion_micro):
                # Valor es solo el número, agregar < y %
                if re.match(r'^\d+$', valor_porcentaje):
                    valor_porcentaje = f"<{valor_porcentaje}%"
                elif not valor_porcentaje.startswith('<'):
                    valor_porcentaje = f"<{valor_porcentaje}"
            # V6.3.36: Asegurar que siempre tenga % si es un número puro
            elif re.match(r'^\d+$', valor_porcentaje):
                valor_porcentaje = f"{valor_porcentaje}%"

            normalized = normalize_biomarker_value(
                valor_porcentaje,
                definition.get('normalizacion', {}),
                definition.get('tipo_valor', 'PERCENTAGE')
            )
            if normalized:
                return normalized

        # V6.5.37: PRIORIDAD 2 - Si no hay porcentaje, retornar cualitativo
        if valor_cualitativo:
            normalized = normalize_biomarker_value(
                valor_cualitativo,
                definition.get('normalizacion', {}),
                definition.get('tipo_valor', 'PERCENTAGE')
            )
            if normalized:
                return normalized

        # LUEGO en DIAGNÓSTICO (fallback)
        for pattern in definition.get('patrones', []):
            valor_diagnostico = buscar_en_diagnostico(text, pattern)
            if valor_diagnostico:
                # V6.3.14: CRÍTICO - Validación "expresión limitada" ANTES de normalizar
                if 'expresi' in valor_diagnostico.lower() and 'limitada' in valor_diagnostico.lower():
                    return "EXPRESIÓN LIMITADA A CAPA BASAL"

                # V6.3.36 FIX IHQ250029: Buscar "menor" en el TEXTO REAL, no en el patrón
                # V6.3.59 FIX IHQ250071: También buscar "menos del" (diferente de "menor del")
                seccion_diag = extraer_seccion(text, r"DIAGN[ÓO]STICO|EXPRESI[ÓO]N\s+MOLECULAR", r"COMENTARIOS|OBSERVACIONES|DESCRIPCI[ÓO]N\s+MICROSC[ÓO]PICA|RESPONSABLE")
                if seccion_diag and re.search(rf'(?i)ki[^\w]*67\s+(?:es\s+bajo\s*\()?(?:menor\s+(?:al|del)|menos\s+del)\s+{re.escape(valor_diagnostico)}\s*%?\)?', seccion_diag):
                    # Valor es solo el número, agregar < y %
                    if re.match(r'^\d+$', valor_diagnostico):
                        valor_diagnostico = f"<{valor_diagnostico}%"
                    elif not valor_diagnostico.startswith('<'):
                        valor_diagnostico = f"<{valor_diagnostico}"
                # V6.3.36: Asegurar que siempre tenga % si es un número puro
                elif re.match(r'^\d+$', valor_diagnostico):
                    valor_diagnostico = f"{valor_diagnostico}%"

                normalized = normalize_biomarker_value(
                    valor_diagnostico,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'PERCENTAGE')
                )
                if normalized:
                    return normalized

        # V6.1.2: PRIORIDAD 3 - Buscar en texto completo (fallback final para IHQ250997)
        # Casos donde Ki-67 está en sección "Inmunohistoquímica:" que NO es parte de DESCRIPCIÓN MICROSCÓPICA ni DIAGNÓSTICO
        for pattern in definition.get('patrones', []):
            match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
            if match:
                # Obtener valor capturado
                if match.groups():
                    raw_value = match.group(1).strip()
                else:
                    raw_value = match.group(0).strip()

                # V6.3.14: CRÍTICO - Validación "expresión limitada" ANTES de normalizar
                if 'expresi' in raw_value.lower() and 'limitada' in raw_value.lower():
                    return "EXPRESIÓN LIMITADA A CAPA BASAL"

                # V6.4.0 FIX IHQ250013: Detectar "menor" en el patrón o en el match
                if re.search(r'(?i)menor', pattern) or re.search(r'(?i)menor\s+(?:al|del)', match.group(0)):
                    # Extraer solo el número y agregar "<"
                    numero = re.search(r'\d+', raw_value)
                    if numero:
                        raw_value = f"<{numero.group()}%"

                # Normalizar
                normalized = normalize_biomarker_value(
                    raw_value,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'PERCENTAGE')
                )
                if normalized:
                    return normalized

        return None

    # V6.3.74 FIX IHQ250102: LÓGICA ESPECIAL PARA ER/PR con intensidad+porcentaje
    # V6.5.48 FIX IHQ250247: Buscar PRIMERO el patrón "positiva fuerte del X%" (v6.5.46)
    # Si lo encuentra, retornar "POSITIVO (X%)" (formato conciso)
    # Si no, buscar "fuerte y positiva del X%" (v6.3.74) y retornar "POSITIVO (NUCLEAR FUERTE X%)"
    # Si no, continuar con la lógica normal de prioridad de sección
    if biomarker_name in ['ER', 'PR'] and definition.get('usa_prioridad_seccion', False):
        # V6.5.48: PRIORIDAD 1 - Patrón "positiva fuerte del X%" (formato conciso)
        if biomarker_name == 'ER':
            patron_conciso = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+estr[oó]geno[s]?\s*:\s*Marcaci[oó]n\s+nuclear\s+positiva\s+(fuerte|moderada|d[eé]bil)\s+del?\s*(\d+)\s*%'
            patron_intensidad = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+estr[oó]geno[s]?\s*:\s*Marcaci[oó]n\s+nuclear\s+(fuerte|moderada|d[eé]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'
        else:  # PR
            patron_conciso = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+progesterona\s*:\s*Marcaci[oó]n\s+nuclear\s+positiva\s+(fuerte|moderada|d[eé]bil)\s+del?\s*(\d+)\s*%'
            patron_intensidad = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+progesterona\s*:\s*Marcaci[oó]n\s+nuclear\s+(fuerte|moderada|d[eé]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'

        # Buscar en descripción microscópica
        seccion_micro = extraer_seccion(text, r"DESCRIPCI[ÓO]N\s+MICROSC[ÓO]PICA", r"DIAGN[ÓO]STICO|EXPRESI[ÓO]N\s+MOLECULAR|RESPONSABLE")
        if seccion_micro:
            # V6.5.48: PRIMERO buscar patrón conciso "positiva fuerte del X%"
            match_conciso = re.search(patron_conciso, seccion_micro)
            if match_conciso:
                porcentaje = match_conciso.group(2)
                return f"POSITIVO ({porcentaje}%)"  # Formato conciso

            # V6.3.74: LUEGO buscar patrón "fuerte y positiva del X%"
            match_intensidad = re.search(patron_intensidad, seccion_micro)
            if match_intensidad:
                intensidad = match_intensidad.group(1).upper().replace('É', 'E')
                porcentaje = match_intensidad.group(2)
                return f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

        # Si no encontró ningún patrón específico, continuar con lógica normal

    # V6.0.0: Si el biomarcador usa prioridad de sección (RESTO DE BIOMARCADORES)
    if definition.get('usa_prioridad_seccion', False):
        # PRIORIDAD 1: Buscar en sección DIAGNÓSTICO
        for idx, pattern in enumerate(definition.get('patrones', [])):
            valor_diagnostico = buscar_en_diagnostico(text, pattern)
            if valor_diagnostico:
                # V6.3.32 DEBUG: Log para HER2 (siempre)
                if biomarker_name == 'HER2':
                    with open('debug_her2_extraction.log', 'a', encoding='utf-8') as f:
                        f.write(f"\n[HER2] Pattern {idx + 1} matched in DIAGNOSTICO\n")
                        f.write(f"  Pattern: {str(pattern)[:100]}\n")
                        f.write(f"  Captured: '{valor_diagnostico}'\n")
                        f.write(f"  Normalization map: {definition.get('normalizacion', {})}\n")
                        f.write(f"  Value type: {definition.get('tipo_valor', 'CATEGORICAL')}\n")

                # V6.2.2: FIX IHQ251015 - Manejo especial para ER/PR con "receptores de X y Y"
                # Si el valor contiene frase completa "receptores de estrógeno y progesterona" → POSITIVO
                if biomarker_name in ['ER', 'PR']:
                    if re.search(r'(?i)receptores\s+de\s+estr[oó]geno[s]?\s+y\s+progesterona', valor_diagnostico):
                        if re.search(r'(?i)marcaci[oó]n|positividad', valor_diagnostico):
                            return 'POSITIVO'

                # V6.3.14: CRÍTICO - Validación KI-67 "expresión limitada" ANTES de normalizar
                if biomarker_name == 'KI67' and 'expresi' in valor_diagnostico.lower() and 'limitada' in valor_diagnostico.lower():
                    return "EXPRESIÓN LIMITADA A CAPA BASAL"

                # V6.3.59 FIX IHQ250071: Buscar "menor/menos del" en sección diagnóstico para Ki-67
                if biomarker_name == 'KI67':
                    seccion_diag = extraer_seccion(text, r"DIAGN[ÓO]STICO|EXPRESI[ÓO]N\s+MOLECULAR", r"COMENTARIOS|OBSERVACIONES|DESCRIPCI[ÓO]N\s+MICROSC[ÓO]PICA|RESPONSABLE")
                    if seccion_diag and re.search(rf'(?i)ki[^\w]*67\s+(?:es\s+bajo\s*\()?(?:menor\s+(?:al|del)|menos\s+del)\s+{re.escape(valor_diagnostico)}\s*%?\)?', seccion_diag):
                        # Valor es solo el número, agregar < y %
                        if re.match(r'^\d+$', valor_diagnostico):
                            valor_diagnostico = f"<{valor_diagnostico}%"
                        elif not valor_diagnostico.startswith('<'):
                            valor_diagnostico = f"<{valor_diagnostico}"
                    # Asegurar que siempre tenga % si es un número puro
                    elif re.match(r'^\d+$', valor_diagnostico):
                        valor_diagnostico = f"{valor_diagnostico}%"

                # Normalizar el valor
                normalized = normalize_biomarker_value(
                    valor_diagnostico,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )

                # V6.3.32 DEBUG: Log normalización (siempre)
                if biomarker_name == 'HER2':
                    with open('debug_her2_extraction.log', 'a', encoding='utf-8') as f:
                        f.write(f"  Normalized: '{normalized}'\n")

                if normalized:
                    return normalized

        # PRIORIDAD 2: Buscar en DESCRIPCIÓN MICROSCÓPICA (fallback)
        for pattern in definition.get('patrones', []):
            valor_microscopica = buscar_en_microscopica(text, pattern)
            if valor_microscopica:
                # V6.2.2: FIX IHQ251015 - Manejo especial para ER/PR con "receptores de X y Y"
                # Si el valor contiene frase completa "receptores de estrógeno y progesterona" → POSITIVO
                if biomarker_name in ['ER', 'PR']:
                    if re.search(r'(?i)receptores\s+de\s+estr[oó]geno[s]?\s+y\s+progesterona', valor_microscopica):
                        if re.search(r'(?i)marcaci[oó]n|positividad', valor_microscopica):
                            return 'POSITIVO'

                # V6.3.14: CRÍTICO - Validación KI-67 "expresión limitada" ANTES de normalizar
                if biomarker_name == 'KI67' and 'expresi' in valor_microscopica.lower() and 'limitada' in valor_microscopica.lower():
                    return "EXPRESIÓN LIMITADA A CAPA BASAL"

                # V6.3.59 FIX IHQ250071: Buscar "menor/menos del" en sección microscópica para Ki-67
                if biomarker_name == 'KI67':
                    seccion_micro = extraer_seccion(text, r"DESCRIPCI[ÓO]N\s+MICROSC[ÓO]PICA", r"DIAGN[ÓO]STICO|EXPRESI[ÓO]N\s+MOLECULAR|RESPONSABLE")
                    if seccion_micro and re.search(rf'(?i)ki[^\w]*67\s+(?:es\s+bajo\s*\()?(?:menor\s+(?:al|del)|menos\s+del)\s+{re.escape(valor_microscopica)}\s*%?\)?', seccion_micro):
                        # Valor es solo el número, agregar < y %
                        if re.match(r'^\d+$', valor_microscopica):
                            valor_microscopica = f"<{valor_microscopica}%"
                        elif not valor_microscopica.startswith('<'):
                            valor_microscopica = f"<{valor_microscopica}"
                    # Asegurar que siempre tenga % si es un número puro
                    elif re.match(r'^\d+$', valor_microscopica):
                        valor_microscopica = f"{valor_microscopica}%"

                # Normalizar el valor
                normalized = normalize_biomarker_value(
                    valor_microscopica,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )
                if normalized:
                    return normalized

        # V6.1.4: PRIORIDAD 3 - Buscar en texto completo (fallback final)
        # Casos donde el biomarcador está en secciones no estándar (ej: E-Cadherina en IHQ251008)
        for pattern in definition.get('patrones', []):
            match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
            if match:
                # Obtener valor capturado
                if match.groups():
                    raw_value = match.group(1).strip()
                else:
                    raw_value = match.group(0).strip()

                # V6.3.14: CRÍTICO - Validación KI-67 "expresión limitada" ANTES de normalizar
                # Bug: PRIORIDAD 3 llamaba normalize_biomarker_value sin validación especial
                # Solución: Duplicar validación de línea 4190 también aquí
                if biomarker_name == 'KI67' and 'expresi' in raw_value.lower() and 'limitada' in raw_value.lower():
                    return "EXPRESIÓN LIMITADA A CAPA BASAL"

                # Normalizar
                normalized = normalize_biomarker_value(
                    raw_value,
                    definition.get('normalizacion', {}),
                    definition.get('tipo_valor', 'CATEGORICAL')
                )
                if normalized:
                    return normalized

        return None

    # Lógica original continúa debajo (para biomarcadores sin prioridad de sección)
    # Intentar con cada patrón definido
    for pattern in definition.get('patrones', []):
        match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
        if match:
            # VALIDACIÓN ESPECIAL PARA KI67 v5.0.1
            # Verificar que NO estemos capturando porcentajes de otros campos
            if biomarker_name == 'KI67':
                match_start = match.start()
                context_before = text[max(0, match_start - 150):match_start].upper()

                # Si "DIFERENCIACIÓN" o "GLANDULAR" aparecen en los 150 caracteres previos, descartar
                if 'DIFERENCIACI' in context_before and 'GLANDULAR' in context_before:
                    continue

                # V6.4.0 FIX IHQ250013: NO descartar "MENOR DEL" - lo procesaremos más adelante
                # (Comentado el continue que descartaba valores con "menor del")
                # if 'MENOR DEL' in context_before[-30:]:
                #     continue

            # Obtener el valor capturado, manejar casos sin grupos
            if match.groups():
                # V3.2.2: Manejar rangos (Ki67: 1-2%)
                if len(match.groups()) >= 2 and match.group(2):
                    # Es un rango, tomar el valor superior
                    raw_value = match.group(2).strip()
                else:
                    raw_value = match.group(1).strip()
            else:
                raw_value = match.group(0).strip()

            # V6.4.0 FIX IHQ250013: Manejo especial para KI-67 con "menor"
            # Si el patrón capturó "Ki67 menor del X%" → convertir a "<X%"
            # V6.3.59 FIX IHQ250071: También detectar "menos del" (diferente de "menor del")
            if biomarker_name == 'KI67':
                # Obtener el texto completo del match para ver si contiene "menor" o "menos"
                full_match_text = match.group(0)
                # "menor al/del" o "menos del" → indica valor < X%
                if re.search(r'(?i)(?:menor\s+(?:al|del)|menos\s+del)', full_match_text):
                    # El valor raw_value es solo el número (ej: "1" o "10")
                    # Convertir a formato "<X%"
                    raw_value = f"<{raw_value}%"

            # V6.2.2: FIX IHQ251015 - Manejo especial para P63 sin estado explícito
            # Cuando el patrón de P63 encuentra "expresión de ... P63" o "inmunorreactividad para ... P63"
            # sin capturar grupo (match.groups() retorna tupla vacía)
            # → Infiere POSITIVO porque hablar de "expresión" o "inmunorreactividad" implica positividad
            if biomarker_name == 'P63' and len(match.groups()) == 0:
                # El match completo contiene "expresión" o "inmunorreactividad" → POSITIVO
                if re.search(r'(?i)expresi[oó]n|inmunor+eactividad', raw_value):
                    return 'POSITIVO'

            # V6.5.38 FIX IHQ250242: Manejo especial para CKAE1AE3 sin grupo de captura
            # Patrón "CKAE1E3 y [biomarcador] positivos" → Infiere POSITIVO del contexto
            if biomarker_name == 'CKAE1AE3' and len(match.groups()) == 0:
                # Match completo contiene "positivos" → POSITIVO
                if re.search(r'(?i)positivos?', raw_value):
                    return 'POSITIVO'
                # Match completo contiene "negativos" → NEGATIVO
                if re.search(r'(?i)negativos?', raw_value):
                    return 'NEGATIVO'

            # V6.2.2: FIX IHQ251015 - Manejo especial para ER/PR con "receptores de X y Y"
            # Cuando detectamos "receptores de estrógeno y progesterona con marcación/positividad"
            # → ER = POSITIVO, PR = POSITIVO (el contexto "marcación" o "positividad" implica positivo)
            if biomarker_name in ['ER', 'PR'] and len(match.groups()) == 0:
                # Match sin grupos capturados → es uno de los nuevos patrones "receptores de estrógeno y progesterona"
                if re.search(r'(?i)marcaci[oó]n|positividad', raw_value):
                    return 'POSITIVO'

            # V6.5.46 FIX IHQ250247: Manejo especial para ER/PR con "positiva (intensidad) del X%"
            # Cuando el patrón captura dos grupos: (intensidad, porcentaje)
            # Ej: "Marcación nuclear positiva fuerte del 90%" → ("fuerte", "90")
            # → Normalizar a "POSITIVO (90%)" (formato conciso como HER2 score)
            if biomarker_name in ['ER', 'PR'] and len(match.groups()) >= 2:
                group1 = match.group(1)
                group2 = match.group(2)
                print(f"[DEBUG v6.5.48] ER/PR check: biomarker={biomarker_name}, g1='{group1}', g2='{group2}'")
                # Verificar si group1 es intensidad (fuerte/moderada/débil) y group2 es porcentaje
                if group1 and group2 and re.match(r'(?i)fuerte|moderada|d[eé]bil', group1) and re.match(r'\d+', group2):
                    porcentaje = group2
                    print(f"[DEBUG v6.5.48] Conditions MET - Retornando POSITIVO ({porcentaje}%)")
                    # V6.5.46: Formato conciso "POSITIVO (90%)" (similar a HER2 score)
                    return f"POSITIVO ({porcentaje}%)"
                else:
                    print(f"[DEBUG v6.5.48] Conditions NOT MET - continuing to normalize_biomarker_value()")
            else:
                if biomarker_name in ['ER', 'PR']:
                    print(f"[DEBUG v6.5.48] {biomarker_name} has {len(match.groups())} groups (need >= 2)")

            # V6.3.74 FIX IHQ250102: Manejo especial para ER/PR con intensidad + porcentaje (orden diferente)
            # Cuando el patrón captura dos grupos: (intensidad, porcentaje)
            # Ej: "Marcación nuclear fuerte y positiva del 70%" → ("fuerte", "70")
            # → Normalizar a "POSITIVO (NUCLEAR FUERTE 70%)" (formato descriptivo completo)
            # NOTA: Este pattern requiere "fuerte y positiva" mientras v6.5.46 requiere "positiva fuerte"
            if biomarker_name in ['ER', 'PR'] and len(match.groups()) >= 2:
                group1 = match.group(1)
                group2 = match.group(2)
                # Verificar si group1 es intensidad (fuerte/moderada/débil) y group2 es porcentaje
                if group1 and group2 and re.match(r'(?i)fuerte|moderada|d[eé]bil', group1) and re.match(r'\d+', group2):
                    intensidad = group1.upper().replace('É', 'E')  # "débil" → "DEBIL"
                    porcentaje = group2
                    return f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

            # V3.2.2: Manejo especial para "expresión limitada" → convertir a texto descriptivo
            if biomarker_name == 'KI67' and 'expresi' in raw_value.lower() and 'limitada' in raw_value.lower():
                return "EXPRESIÓN LIMITADA A CAPA BASAL"

            # V6.3.57 FIX IHQ250066: Manejo especial para KI67 "positivo en espesor"
            # Cuando el patrón captura "Ki 67 es positivo en todo el espesor" sin porcentaje
            # → Retornar POSITIVO (indica alta proliferación en displasias/NIC)
            if biomarker_name == 'KI67' and re.search(r'(?i)positivo\s+en\s+(?:todo\s+)?(?:el\s+)?espesor', raw_value):
                return 'POSITIVO'

            # Normalizar el valor
            normalized = normalize_biomarker_value(
                raw_value,
                definition.get('normalizacion', {}),
                definition.get('tipo_valor', 'CATEGORICAL')
            )

            return normalized

    return None


def normalize_biomarker_value(
    raw_value: str,
    specific_normalization: Dict[str, str],
    value_type: str = 'CATEGORICAL'
) -> str:
    """Normaliza el valor de un biomarcador

    v5.3.1: MEJORADO - Manejo de rangos (ej: "51-60%")
    v6.0.5: MEJORADO - Normalización de valores narrativos contaminados
    v6.1.7: CRÍTICO - Limpieza completa de \n, \r, \t + estandarización narrativa
    v6.3.19: FIX IHQ250017 - Preservar texto completo para tipo DESCRIPTIVE (HER2 con score)

    Args:
        raw_value: Valor extraído del texto
        specific_normalization: Normalización específica del biomarcador
        value_type: Tipo de valor ('CATEGORICAL', 'PERCENTAGE', 'NUMERIC', 'DESCRIPTIVE')

    Returns:
        Valor normalizado
    """
    if not raw_value:
        return 'SIN DATO'

    # V6.3.19 FIX CRÍTICO: Si tipo_valor es DESCRIPTIVE, NO normalizar
    # Preservar texto completo para biomarcadores descriptivos (ej: HER2 con score)
    # Solo limpiar espacios, sin convertir a mayúsculas ni normalizar valores
    import re
    if value_type == 'DESCRIPTIVE':
        value_clean = raw_value.strip()
        # Reemplazar \n, \r, \t con espacio
        value_clean = re.sub(r'[\n\r\t]+', ' ', value_clean)
        # Reemplazar espacios múltiples con uno solo
        value_clean = re.sub(r'\s+', ' ', value_clean)
        value_clean = value_clean.strip()

        # V6.3.61 FIX IHQ250074: Limpieza de valores mal capturados de HER2
        # Problema: Patrón general captura "/NEU (SCORE 0)" en lugar del valor correcto
        # Solución: Detectar y corregir patrones erróneos

        # Caso 1: Valor empieza con "/NEU" o "NEU" - error de captura del patrón general
        if re.match(r'^/?NEU\s*', value_clean, re.IGNORECASE):
            # Extraer el score si existe
            score_match = re.search(r'\(SCORE\s*(\d+\+?)\)', value_clean, re.IGNORECASE)
            if score_match:
                score = score_match.group(1)
                # Score 0 = NEGATIVO, Score 3+ = POSITIVO, Score 1+ o 2+ = valor correspondiente
                if score == '0':
                    return "NEGATIVO (Score 0)"
                elif score == '3+' or score == '3':
                    return "POSITIVO (Score 3+)"
                else:
                    return f"NEGATIVO (Score {score})"

        # Caso 2: "No hay marcación de las células tumorales (Score X)" → "NEGATIVO (Score X)"
        patrones_negativo_her2 = [
            r'no hay marcaci[oó]n',
            r'sin marcaci[oó]n',
            r'ausencia de marcaci[oó]n',
        ]
        for patron in patrones_negativo_her2:
            if re.search(patron, value_clean, re.IGNORECASE):
                # Extraer el score si existe
                score_match = re.search(r'\(Score\s*(\d+\+?)\)', value_clean, re.IGNORECASE)
                if score_match:
                    return f"NEGATIVO (Score {score_match.group(1)})"
                return "NEGATIVO"

        # V6.3.74 FIX IHQ250102: Detectar cuando solo hay especificación de anticuerpo sin resultado real
        # Caso 3: "PATHWAY anti-HER-2/Neu (4B5)" → solo anticuerpo, NO hay resultado de HER2
        # Indicadores de especificación de anticuerpo sin resultado:
        # - "PATHWAY" al inicio (nombre comercial del anticuerpo)
        # - "anti-HER" (descripción del anticuerpo)
        # - "Rabbit Monoclonal" (tipo de anticuerpo)
        # - "VENTANA Ref." (referencia del fabricante)
        # - NO tiene palabras clave de resultado: negativo, positivo, score, equivoco
        patrones_solo_anticuerpo = [
            r'^PATHWAY\s+anti',           # Inicia con "PATHWAY anti-..."
            r'^CONFIRM\s+anti',           # Inicia con "CONFIRM anti-..."
            r'Rabbit\s+Monoclonal',       # Contiene tipo de anticuerpo
            r'VENTANA\s+Ref\.',           # Contiene referencia del fabricante
        ]
        # Verificar si es solo especificación de anticuerpo
        es_solo_anticuerpo = False
        for patron_anticuerpo in patrones_solo_anticuerpo:
            if re.search(patron_anticuerpo, value_clean, re.IGNORECASE):
                es_solo_anticuerpo = True
                break

        if es_solo_anticuerpo:
            # Verificar que NO contiene resultado real (negativo, positivo, score, equivoco)
            tiene_resultado = re.search(r'(?i)negativ|positiv|score\s*\d|equi?v[oí]', value_clean)
            if not tiene_resultado:
                # Es solo especificación de anticuerpo, NO hay resultado de HER2
                return "NO MENCIONADO"

        # V6.3.32 FIX IHQ250031: DESCRIPTIVE puede tener normalización específica
        # Ejemplo: "EQUÍVOCO (SCORE 2)" → "EQUIVOCO ( Score 2+)" para HER2
        # V6.4.65 FIX IHQ250204: Extraer estado base antes de buscar en normalización
        # "Negativo (score 0)" → buscar "negativo" en diccionario → aplicar normalización
        if specific_normalization:
            value_lower = value_clean.lower()
            # Primero buscar coincidencia exacta
            if value_lower in specific_normalization:
                return specific_normalization[value_lower]

            # V6.4.67 FIX IHQ250204: CORREGIDO - Preservar formato de score si ya existe
            # PROBLEMA v6.4.65: Reemplazaba "Negativo (score 0)" con "NEGATIVO (0)", perdía "SCORE"
            # SOLUCIÓN: Detectar si tiene "(score X)" y preservar formato completo
            # Solo usar diccionario si NO tiene score explícito

            # PASO 1: Detectar si valor tiene score en paréntesis
            score_match = re.search(r'\(\s*score\s+(\d+\+?)\s*\)', value_lower)

            if score_match:
                # Tiene score - Preservar formato completo (NO usar diccionario)
                score_num = score_match.group(1)
                # Normalizar solo el estado (negativo/positivo/equivoco)
                for key_base in ['negativo', 'positivo', 'equivoco', 'equívoco']:
                    if value_lower.startswith(key_base):
                        estado_normalizado = key_base.upper().replace('Í', 'I')
                        # Preservar formato: "NEGATIVO (SCORE 0)" o "POSITIVO (SCORE 3+)"
                        return f"{estado_normalizado} (SCORE {score_num.upper()})"
                # Si no encontró estado conocido, normalizar valor completo a mayúsculas
                # Convertir "score" a "SCORE" manteniendo estructura
                return re.sub(r'\(\s*score\s+', '(SCORE ', value_clean, flags=re.IGNORECASE).upper()

            # PASO 2: Si NO tiene score, usar normalización del diccionario (comportamiento original)
            for key_base in ['negativo', 'positivo', 'equivoco', 'equívoco']:
                if value_lower.startswith(key_base) and key_base in specific_normalization:
                    # Aplicar normalización del estado base (agrega score por defecto)
                    return specific_normalization[key_base]

        # V6.3.77 FIX IHQ250116: Normalización obligatoria para Score 2+ (EQUIVOCO)
        if re.search(r'2\+|(?:score\s+de\s+2\+)', value_clean, re.IGNORECASE):
            return "EQUIVOCO (Score 2+)"

        return value_clean

    # V6.1.7: LIMPIEZA COMPLETA - Eliminar \n, \r, \t y espacios múltiples
    value_clean = raw_value.strip()
    # Reemplazar \n, \r, \t con espacio
    value_clean = re.sub(r'[\n\r\t]+', ' ', value_clean)
    # Reemplazar espacios múltiples con uno solo
    value_clean = re.sub(r'\s+', ' ', value_clean)
    value_clean = value_clean.strip().upper()

    # V6.4.28 FIX IHQ250163: P53 "EN MOSAICO (PATRÓN SALVAJE)" → "POSITIVO (patrón salvaje - mosaico)"
    # DEBE IR ANTES de la lógica que agrega prefijo POSITIVO (línea 6624-6629)
    # Patrón salvaje/wild type = no mutado = expresión normal de p53
    # Formato estándar: POSITIVO/NEGATIVO + (descripción)
    if re.search(r'EN\s+MOSAICO\s*\([^)]*(?:PATR[OÓ]N\s+)?(?:SALVAJE|WILD\s*TYPE)', value_clean):
        return 'POSITIVO (patrón salvaje - mosaico)'

    # V6.3.77 FIX IHQ250116: Si tiene descriptores (intensidad, patrón, etc.), asegurar prefijo POSITIVO
    # Se aplica a receptores hormonales y otros marcadores con descripción de intensidad
    if re.search(r'\b(?:INTENSIDAD|PATR[OÓ]N|MARCACI[OÓ]N|NUCLEAR)\b', value_clean):
         if not re.search(r'\b(?:NEGATIVO|AUSENCIA|SIN)\b', value_clean):
             if not value_clean.startswith('POSITIVO'):
                 # Limpiar comas o puntos finales antes de envolver
                 value_clean = value_clean.strip(',. ')
                 return f"POSITIVO ({value_clean})"

    # V6.2.2: FIX IHQ251015 - CRÍTICO: Frases completas "receptores de X y Y con marcación/positividad"
    # Formato: "receptores de estrógeno y progesterona con marcación" → "POSITIVO"
    # Formato: "con positividad para receptores de Estrógenos y progesterona" → "POSITIVO"
    # Formato: "Y PROGESTERONA CON MARCACIÓN" (fragmento capturado incorrectamente antes) → "POSITIVO"
    if re.search(r'RECEPTORES\s+DE\s+ESTR[OÓ]GENO[S]?\s+Y\s+PROGESTERONA', value_clean):
        if re.search(r'MARCACI[OÓ]N|POSITIVIDAD', value_clean):
            return 'POSITIVO'
    # Fragmento incorrecto capturado: "Y PROGESTERONA CON MARCACIÓN"
    if re.search(r'^Y\s+PROGESTERONA\s+CON\s+MARCACI[OÓ]N', value_clean):
        return 'POSITIVO'

    # V6.1.7: ESTANDARIZACIÓN NARRATIVA - Convertir formatos largos a POSITIVO/NEGATIVO + contexto
    # FORMATO: "POSITIVO/NEGATIVO" en mayúsculas + contexto en minúsculas entre paréntesis

    # Patrón 1: "NO ES CONTRIBUTIVA" / "NO CONTRIBUTIVA" → "NEGATIVO (no contributiva)"
    if re.search(r'^NO\s+ES\s+CONTRIBUTIV[AO]$', value_clean):
        return 'NEGATIVO (no contributiva)'
    if re.search(r'^NO\s+CONTRIBUTIV[AO]$', value_clean):
        return 'NEGATIVO (no contributiva)'

    # Patrón 2: "AUSENCIA DE EXPRESION PARA [BIOMARCADOR] (MUTADO)" → "NEGATIVO (mutado)"
    if re.search(r'^AUSENCIA\s+DE\s+EXPRESI[OÓ]N', value_clean):
        if 'MUTADO' in value_clean:
            return 'NEGATIVO (mutado)'
        return 'NEGATIVO (ausencia de expresión)'

    # Patrón 3: "LA EXPRESION PARA [BIOMARCADOR] ES POSITIVA (MUTADO)" → "POSITIVO (mutado)"
    # Patrón 4: "EXPRESION POSITIVA (MUTADO)" → "POSITIVO (mutado)"
    if re.search(r'EXPRESI[OÓ]N.*POSITIV[AO]', value_clean):
        if 'MUTADO' in value_clean:
            return 'POSITIVO (mutado)'
        return 'POSITIVO'

    # Patrón 5: "POSITIVO (MUTADO)" → "POSITIVO (mutado)"
    if re.search(r'^POSITIV[AO]\s*\(MUTADO\)$', value_clean):
        return 'POSITIVO (mutado)'

    # Patrón 6: "NEGATIVO (MUTADO)" → "NEGATIVO (mutado)"
    if re.search(r'^NEGATIV[AO]\s*\(MUTADO\)$', value_clean):
        return 'NEGATIVO (mutado)'

    # Patrón 6.5: V6.X.X - P53 "TIENE EXPRESIÓN EN MOSAICO (NO MUTADO)" → "NEGATIVO (no mutado - expresión en mosaico)"
    # IHQ250002: P53 con patrón de expresión en mosaico indica proteína funcional (no mutada)
    if re.search(r'TIENE\s+EXPRESI[OÓ]N\s+EN\s+MOSAICO', value_clean):
        if 'NO MUTADO' in value_clean:
            return 'NEGATIVO (no mutado - expresión en mosaico)'
        return 'NEGATIVO (expresión en mosaico)'

    # Patrón 6.6: V6.3.21 - FIX IHQ250019: "MOSAICO (NORMAL)" para receptores hormonales
    # DEBE IR ANTES del Patrón 6.7 (expresión en mosaico genérico)
    # En receptores de estrógenos/progesterona, "mosaico (normal)" indica distribución normal POSITIVA
    # Contexto: células epiteliales con expresión en mosaico (normal) = POSITIVO
    if re.search(r'MOSAICO\s*\(NORMAL\)', value_clean):
        return 'POSITIVO (mosaico normal)'
    if re.search(r'EN\s+MOSAICO\s*\(NORMAL\)', value_clean):
        return 'POSITIVO (mosaico normal)'

    # Patrón 6.7A: V6.4.28 FIX IHQ250163 - "EN MOSAICO (PATRÓN SALVAJE)" → "POSITIVO (patrón salvaje - mosaico)"
    # Formato específico: "en mosaico (patrón salvaje/wild type)" capturado por patrón línea 899
    # Patrón salvaje = wild type = no mutado = expresión normal de p53
    # Formato estándar: POSITIVO/NEGATIVO + (descripción)
    if re.search(r'EN\s+MOSAICO\s*\([^)]*(?:PATR[OÓ]N\s+)?(?:SALVAJE|WILD\s*TYPE)', value_clean):
        return 'POSITIVO (patrón salvaje - mosaico)'

    # Patrón 6.7: Variantes adicionales de expresión en mosaico (GENÉRICO - debe ir DESPUÉS del específico)
    if re.search(r'EXPRESI[OÓ]N\s+EN\s+MOSAICO', value_clean):
        if 'NO MUTADO' in value_clean or 'WILD TYPE' in value_clean:
            return 'NEGATIVO (no mutado - expresión en mosaico)'
        return 'NEGATIVO (expresión en mosaico)'

    # Patrón 6.8: V6.3.84 FIX IHQ250111 - "POSITIVIDAD EN MOSAICO" (RE/PR) → POSITIVO
    # Diferente de "expresión en mosaico" de p53 que suele ser wild type/normal
    # Para RE/PR, cualquier mención de positividad, aun en mosaico, es relevante.
    if re.search(r'POSITIVIDAD\s+(?:EN\s+)?MOSAICO', value_clean):
        return 'POSITIVO (mosaico)'

    # Patrón 7: "MARCACION POSITIVA PARA [BIOMARCADOR]" → "POSITIVO"
    if re.search(r'^MARCACI[OÓ]N\s+POSITIV[AO]', value_clean):
        return 'POSITIVO'

    # Patrón 7B: V6.3.44 FIX IHQ250037 - "PRESENTAN EXPRESIÓN PARA [BIOMARCADOR]" → "POSITIVO"
    # Cuando dice "expresión para X" sin calificativo negativo, implica POSITIVO (hay expresión)
    if re.search(r'(?:PRESENTAN?\s+)?EXPRESI[OÓ]N\s+PARA', value_clean):
        if not re.search(r'AUSENCIA|SIN|NO\s+HAY|NEGATIV', value_clean):
            return 'POSITIVO'

    # Patrón 7C: V6.3.52 FIX IHQ250060 - "POSITIVIDAD NUCLEAR FUERTE Y DIFUSO EN EL 100%..." → "POSITIVO"
    # Formato: "POSITIVIDAD [adjetivos] EN EL [X]% DE LAS CÉLULAS" → POSITIVO
    # Si hay porcentaje, ignorarlo (el porcentaje es contexto, no el valor)
    if re.search(r'^POSITIVIDAD\s+(?:NUCLEAR\s+)?(?:FUERTE|DÉBIL|MODERADA|DIFUSA?|INTENSA?)', value_clean):
        return 'POSITIVO'

    # Patrón 8: "SIENDO NEGATIVA PARA [BIOMARCADOR]" → "NEGATIVO"
    if re.search(r'^SIENDO\s+NEGATIV[AO]', value_clean):
        return 'NEGATIVO'

    # V6.2.15: PATRONES MARCADORES MMR (MLH1, MSH2, MSH6, PMS2)
    # Patrón: "EXPRESIÓN NUCLEAR INTACTA" → "POSITIVO (expresión nuclear intacta)"
    # Patrón: "PÉRDIDA DE EXPRESIÓN" → "NEGATIVO (pérdida de expresión)"
    # V6.3.41 FIX IHQ250035: Aceptar variante "INTACT" (inglés sin 'a' final)
    if re.search(r'^EXPRESI[OÓ]N\s+NUCLEAR\s+INTACT[A]?$', value_clean):
        return 'POSITIVO (expresión nuclear intacta)'
    if re.search(r'^P[ÉE]RDIDA\s+DE\s+EXPRESI[OÓ]N$', value_clean):
        return 'NEGATIVO (pérdida de expresión)'

    # V6.3.62 FIX IHQ250077: MMR con texto largo que incluye "pérdida de la expresión nuclear"
    # Formato: "PRESENTA MARCACIÓN CITOPLASMÁTICA CON PÉRDIDA DE LA EXPRESIÓN NUCLEAR" → "NEGATIVO (pérdida de expresión nuclear)"
    # Lo importante para MMR es la EXPRESIÓN NUCLEAR (no citoplasmática)
    if re.search(r'P[ÉE]RDIDA\s+DE\s+LA\s+EXPRESI[OÓ]N\s+NUCLEAR', value_clean):
        return 'NEGATIVO (pérdida de expresión nuclear)'

    # V6.3.62 FIX IHQ250077: "PÉRDIDA DE EXPRESIÓN" en cualquier parte del texto (no solo al inicio)
    if re.search(r'P[ÉE]RDIDA\s+DE\s+(?:LA\s+)?EXPRESI[OÓ]N', value_clean):
        return 'NEGATIVO (pérdida de expresión)'

    # V6.2.15: PATRONES RECEPTORES HORMONALES (ER, PR)
    # Patrón: "INMUNOREACTIVIDAD MODERADA Y FUERTE A RECEPTORES DE ESTROGENO" → "POSITIVO (inmunoreactividad moderada y fuerte)"
    # Patrón: "INMUNOREACTIVIDAD DÉBIL A RECEPTORES..." → "POSITIVO (inmunoreactividad débil)"
    inmuno_match = re.search(r'INMUNOR?R?EACTIVIDAD\s+((?:MODERADA(?:\s+Y\s+FUERTE)?)|FUERTE|D[ÉE]BIL|INTENSA)\s+(?:PARA|A)\s+(?:LOS\s+)?RECEPTORES?\s+DE\s+(?:ESTR[ÓO]GENO[S]?|PROGESTERONA)', value_clean)
    if inmuno_match:
        calificador = inmuno_match.group(1).lower()
        return f'POSITIVO (inmunoreactividad {calificador})'

    # V6.3.45: FIX IHQ250039 - "MARCACIÓN DIFUSA DE FUERTE A MODERADA PARA RECEPTORES DE ESTRÓGENOS" → POSITIVO
    # Patrón para intensidad compuesta con "marcación difusa de X a Y"
    marcacion_match = re.search(r'MARCACI[ÓO]N\s+(DIFUSA|D[ÉE]BIL|FUERTE|MODERADA)(?:\s+DE\s+)?(FUERTE|D[ÉE]BIL|MODERADA)?(?:\s*A\s*)?(FUERTE|D[ÉE]BIL|MODERADA)?\s+PARA\s+RECEPTORES?\s+DE\s+ESTR[ÓO]GENO[S]?', value_clean)
    if marcacion_match:
        intensidades = [g for g in marcacion_match.groups() if g]
        if intensidades:
            calificador = ' a '.join([i.lower() for i in intensidades])
            return f'POSITIVO (marcación {calificador})'
        return 'POSITIVO'

    # V6.1.8: PATRONES ESPECÍFICOS DE CASOS HEMATOLÓGICOS (IHQ250992)
    # Patrón 9: "EXPRESIÓN DE [BIOMARCADOR]" → "POSITIVO"
    # Ejemplos: "EXPRESIÓN DE CD38", "EXPRESIÓN DE CD38 Y CD138"
    if re.search(r'^EXPRESI[OÓ]N\s+DE\s+', value_clean):
        return 'POSITIVO'

    # Patrón 10: "EXPRESIÓN ABERRANTE PARA [BIOMARCADOR]" → "POSITIVO (aberrante)"
    if re.search(r'EXPRESI[OÓ]N\s+ABERRANTE', value_clean):
        return 'POSITIVO (aberrante)'

    # Patrón 11: "RESTRICCIÓN DE CADENAS LIVIANAS [KAPPA/LAMBDA]" → "POSITIVO (restricción)"
    if re.search(r'RESTRICCI[OÓ]N\s+DE\s+CADENAS', value_clean):
        # Detectar si menciona KAPPA o LAMBDA
        if 'KAPPA' in value_clean:
            return 'POSITIVO (restricción kappa)'
        elif 'LAMBDA' in value_clean:
            return 'POSITIVO (restricción lambda)'
        else:
            return 'POSITIVO (restricción)'

    # Patrón 12: "EXPRESIÓN DÉBIL PARA [BIOMARCADOR]" → "POSITIVO (débil)"
    if re.search(r'EXPRESI[OÓ]N\s+D[ÉE]BIL', value_clean):
        return 'POSITIVO (débil)'

    # Patrón 13: "CON EXPRESIÓN DE [BIOMARCADOR]" → "POSITIVO"
    if re.search(r'^CON\s+EXPRESI[OÓ]N\s+DE', value_clean):
        return 'POSITIVO'

    # V6.2.4: Patrón 16: "ERITROIDE (GLYCOPHORIN" → "POSITIVO" (IHQ251014)
    if re.search(r'ERITROIDE\s*\(\s*GLYCOPHORIN', value_clean):
        return 'POSITIVO'
    if re.search(r'ERITROIDE\s*\(\s*GLICOFORINA', value_clean):
        return 'POSITIVO'

    # V6.2.4: Patrón 14: "LINEA MIELOIDE (CD15" → "POSITIVO" (IHQ251014)
    if re.search(r'LINEA\s+MIELOIDE\s*\(\s*CD\s*15', value_clean):
        return 'POSITIVO'
    if re.search(r'L[ÍI]NEA\s+MIELOIDE', value_clean):
        return 'POSITIVO'

    # V6.2.4: Patrón 15: "MEGACARIOCITOS (CD61" → "POSITIVO" (IHQ251014)
    if re.search(r'MEGACARIOCITOS?\s*\(\s*CD\s*61', value_clean):
        return 'POSITIVO'

    # V6.3.47 FIX IHQ250043: Patrones NeuN → POSITIVO
    # "TINCIÓN DE NEUN", "INMUNORREACTIVOS CON NEUN" indican presencia del marcador
    if re.search(r'TINCI[ÓO]N\s+DE\s+NEUN', value_clean):
        return 'POSITIVO'
    if re.search(r'INMUNORREACTIV[OA]S?\s+(?:CON\s+)?(?:EL\s+)?NEUN', value_clean):
        return 'POSITIVO'

    # V6.3.47 FIX IHQ250047: Ki-67 "tinción usual (basal)" → NEGATIVO
    if re.search(r'KI[^\w]*67.*TINCI[ÓO]N\s+USUAL\s*\(BASAL\)', value_clean):
        return 'NEGATIVO (tinción basal)'

    # V6.0.13: NUEVO - Símbolo "+" al final → POSITIVO (IHQ250989: "CD20+", "CD38+")
    if value_clean.endswith('+'):
        return 'POSITIVO'
    # V6.2.4: FIX CD56- → NEGATIVO - Detectar "CD56-", "CD34-" (IHQ251014)
    # Si termina en "-" y NO es un rango numérico (ej: "10-20")
    if value_clean.endswith('-'):
        # Rechazar rangos como "10-20" pero aceptar "CD56-"
        if not re.search(r'^\d+\s*-$', value_clean):  # No termina en "número-"
            return 'NEGATIVO'

    # V6.0.5: NUEVO - Detectar texto narrativo contaminado y normalizar
    # Ej: "POSITIVAS PARA CKAE1E3, CK7 Y CAM 5.2..." → "POSITIVO"
    if len(value_clean) > 20:  # Si es muy largo, probablemente sea narrativo
        # Buscar patrones narrativos de positividad
        if re.search(r'POSITIVAS?\s+PARA', value_clean):
            return 'POSITIVO'
        if re.search(r'NEGATIVAS?\s+PARA', value_clean):
            return 'NEGATIVO'
        # V6.0.12: NUEVO - "sin marcación para..." → NEGATIVO (IHQ250988)
        if re.search(r'SIN\s+MARCACI[ÓO]N\s+PARA', value_clean):
            return 'NEGATIVO'
        # V6.0.12: NUEVO - "sobreexpresión de..." → POSITIVO (IHQ250988)
        # V6.4.32: FIX IHQ250167 - EXCLUIR "sin sobreexpresión" (debe ser NEGATIVO)
        if re.search(r'SOBREEXPRESI[ÓO]N\s+DE', value_clean):
            # Verificar que NO sea "sin sobreexpresión" o "sin expresión"
            if not re.search(r'(?:^|[^A-Z])SIN\s+(?:SOBREEXPRESI[ÓO]N|EXPRESI[ÓO]N)', value_clean):
                return 'POSITIVO (SOBREEXPRESIÓN)'
        # Si contiene múltiples biomarcadores (comas y "Y"), es narrativo
        if ',' in value_clean and ' Y ' in value_clean:
            # Probablemente sea lista narrativa, marcar como POSITIVO por defecto
            return 'POSITIVO'

    # Intentar normalización específica primero
    if value_clean.lower() in specific_normalization:
        return specific_normalization[value_clean.lower()]

    # Intentar normalización global
    if value_clean.lower() in GLOBAL_VALUE_NORMALIZATION:
        return GLOBAL_VALUE_NORMALIZATION[value_clean.lower()]


    # V6.3.57 FIX IHQ250066: CRÍTICO - Detectar "positivo en espesor" para KI67 ANTES de extraer números
    # El texto "KI 67 ES POSITIVO EN TODO EL ESPESOR" contiene "67" del nombre del biomarcador
    # NO debe extraerse como porcentaje - indica Ki-67 positivo en todo el espesor epitelial
    if re.search(r'KI\s*[-]?\s*67.*POSITIVO\s+EN\s+(?:TODO\s+)?(?:EL\s+)?ESPESOR', value_clean):
        return 'POSITIVO'

    # V6.3.59 FIX IHQ250071: Detectar "menos del X%" o "es bajo (menos del X%)" para Ki-67
    # El texto "Ki-67 es bajo (menos del 10%)" debe retornar "<10%"
    menos_match = re.search(r'MENOS\s+DEL\s+(\d{1,3})\s*%', value_clean)
    if menos_match:
        return f"<{menos_match.group(1)}%"
    # V6.3.59: También manejar "menor del X%" y "menor al X%"
    menor_match = re.search(r'MENOR\s+(?:DEL|AL)\s+(\d{1,3})\s*%', value_clean)
    if menor_match:
        return f"<{menor_match.group(1)}%"

    # Si es porcentaje, asegurar que tenga el símbolo %
    if value_type == 'PERCENTAGE' or value_type == 'NUMERIC':
        # V6.3.36 FIX IHQ250029: Detectar prefijo < o > ANTES de normalizar
        prefix = ''
        if '<' in value_clean or '&LT;' in value_clean.upper():
            prefix = '<'
        elif '>' in value_clean or '&GT;' in value_clean.upper():
            prefix = '>'

        # V5.3.1: NUEVO - Manejar rangos (ej: "51-60")
        range_match = re.search(r'(\d{1,3})-(\d{1,3})', value_clean)
        if range_match:
            # Es un rango, conservarlo completo
            range_str = f"{range_match.group(1)}-{range_match.group(2)}"
            if value_type == 'PERCENTAGE' and '%' not in raw_value:
                return f"{prefix}{range_str}%"
            return f"{prefix}{range_str}"

        # Extraer solo números (caso sin rango)
        number_match = re.search(r'(\d+)', value_clean)
        if number_match:
            number = number_match.group(1)
            # Agregar % si es porcentaje y no lo tiene
            if value_type == 'PERCENTAGE' and '%' not in raw_value:
                return f"{prefix}{number}%"
            # V6.3.36: Asegurar que el prefijo se preserva
            return f"{prefix}{number}%" if value_type == 'PERCENTAGE' else f"{prefix}{number}"

    # Retornar valor limpio si no hay normalización disponible
    return value_clean


def get_biomarker_summary(biomarkers: Dict[str, str]) -> str:
    """Genera un resumen texto de los biomarcadores encontrados

    Args:
        biomarkers: Diccionario de biomarcadores extraídos

    Returns:
        String con resumen legible
    """
    if not biomarkers:
        return "No se encontraron biomarcadores"

    summary_parts = []
    for name, value in biomarkers.items():
        summary_parts.append(f"{name}: {value}")

    return " | ".join(summary_parts)


def validate_biomarker_value(biomarker_name: str, value: str) -> bool:
    """Valida si un valor es válido para un biomarcador

    Args:
        biomarker_name: Nombre del biomarcador
        value: Valor a validar

    Returns:
        True si el valor es válido
    """
    definition = get_biomarker_info(biomarker_name)
    if not definition:
        return False

    valores_posibles = definition.get('valores_posibles', [])

    # Si valores_posibles es una lista, verificar que esté en la lista
    if isinstance(valores_posibles, list):
        return value in valores_posibles or value.replace('%', '') in [str(v) for v in valores_posibles]

    # Si es un tipo (PERCENTAGE, NUMERIC), validar según el tipo
    if valores_posibles in ['PERCENTAGE', 'NUMERIC']:
        return bool(re.match(r'\d+%?', value))

    return True


