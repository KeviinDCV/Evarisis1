    # V6.3.79 FIX IHQ250107: NUEVO - Patrón para "incluyó los siguientes marcadores: X, Y, Z... ninguno... no valorables"
    # Ej: "panel de inmunohistoquímica que incluyó los siguientes marcadores: CKAE1/AE3, CK7... Sin embargo, ninguno... no son valorables"
    panel_no_valorable_pattern = r'(?i)(?:panel.*?)?inclu[yí][oó]\s+los\s+siguientes\s+marcadores\s*:\s*([A-Za-z0-9\s,./\-]+?)\s*\.\s*Sin\s+embargo.*?(?:ninguno|no).*?(?:no\s+son\s+valorables|no\s+valorables)'
    for match in re.finditer(panel_no_valorable_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.3.5] 'No son valorables' detectada: '{lista_biomarkers_raw}'")

        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # Separar por comas, "y", y "Y"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+[yY]\s+', lista_biomarkers_raw)

        logging.info(f"🔍 Biomarcadores no valorables separados: {biomarcadores_encontrados}")

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw:
                continue

            # Normalizar nombre del biomarcador
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                # V6.3.5: 'NO VALORABLE' tiene prioridad sobre 'NO MENCIONADO' o 'N/A'
                valor_actual = results.get(normalized_name, '')
                if normalized_name not in results or valor_actual in ['NO MENCIONADO', 'N/A', '']:
                    results[normalized_name] = 'NO VALORABLE'
                    logging.info(f"✅ [no valorables] Extraído: '{bio_raw}' → {normalized_name} = NO VALORABLE")

    # V6.4.35 FIX IHQ250172: NUEVO - Patrones para formatos narrativos de tinción/expresión
    # Ej: "hay inmunotinción para células mioepiteliales con p63 y Calponina" → P63 POSITIVO, CALPONINA POSITIVO
    # Ej: "tinción de manera heterógenea para CK 5/6" → CK5_6 POSITIVO
    # Ej: "expresión de receptores de estrógenos" → RECEPTOR_ESTROGENOS POSITIVO
    # V6.4.79 FIX IHQ250210: Extendido para capturar "marcación" además de "inmunotinción"
    # Ej: "se observa marcación para células mioepiteliales con calponina, p63 y CK5/6 positivo" → CALPONINA/P63/CK5_6 POSITIVO

    # Patrón 1: "inmunotinción/marcación [contexto] con [lista] positivo/negativo"
    inmunotincion_con_pattern = r'(?i)(?:se\s+observa\s+)?(?:hay\s+)?(?:inmunotinci[óo]n|marcaci[óo]n)\s+(?:para\s+)?(?:células?\s+)?(?:\w+\s+)?(?:con|para)\s+([A-Za-z0-9\s,yY/-]+?)\s+(positiv[ao]s?|negativ[ao]s?)(?:\s|,|\.|\s*$)'
    for match in re.finditer(inmunotincion_con_pattern, text):
        lista_biomarkers_raw = match.group(1).strip()
        estado_raw = match.group(2)
        estado = 'POSITIVO' if 'positiv' in estado_raw.lower() else 'NEGATIVO'

        logging.info(f"🔍 [V6.4.79 marcación con lista] Detectado: '{lista_biomarkers_raw}' → Estado: {estado}")

        # Separar por "y" y comas
        biomarcadores_encontrados = re.split(r'\s+y\s+|,\s*', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip()
            if not bio_raw or len(bio_raw) < 2:
                continue

            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = estado
                logging.info(f"✅ [V6.4.79 marcación con lista] Extraído: '{bio_raw}' → {normalized_name} = {estado}")

    # Patrón 2: "tinción [de manera adjetivo] para BIOMARCADOR"
    tincion_para_pattern = r'(?i)tinci[óo]n\s+(?:de\s+manera\s+)?(?:\w+\s+)?para\s+([A-Za-z0-9\s/-]+?)(?=\s+y\s+|\s*,|\s*\.|$)'
    for match in re.finditer(tincion_para_pattern, text):
        bio_raw = match.group(1).strip()

        # Excluir contextos anatómicos (no son biomarcadores)
        if re.search(r'(?i)células?|tejido|epitelio', bio_raw):
            continue

        logging.info(f"🔍 [V6.4.35 tinción para] Detectado: '{bio_raw}' → Estado: POSITIVO")

        normalized_name = normalize_biomarker_name(bio_raw)
        if normalized_name and normalized_name not in results:
            results[normalized_name] = 'POSITIVO'
            logging.info(f"✅ [V6.4.35 tinción para] Extraído: '{bio_raw}' → {normalized_name} = POSITIVO")

    # Patrón 3: "expresión de [receptores de] BIOMARCADOR [en patrón/con intensidad]"
    expresion_de_pattern = r'(?i)expresi[óo]n\s+de\s+(?:receptores?\s+de\s+)?([A-Za-z0-9\s/-]+?)(?=\s+en\s+patrón|\s+con\s+intensidad|\s+\(|,|\.|$)'
    for match in re.finditer(expresion_de_pattern, text):
        bio_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.4.35 expresión de] Detectado: '{bio_raw}' → Estado: POSITIVO")

        normalized_name = normalize_biomarker_name(bio_raw)
        if normalized_name and normalized_name not in results:
            results[normalized_name] = 'POSITIVO'
            logging.info(f"✅ [V6.4.35 expresión de] Extraído: '{bio_raw}' → {normalized_name} = POSITIVO")

    # V6.0.12.1: FIX - Patrón para "marcación positiva/negativa para: lista, de, biomarcadores" (IHQ250991)
    # V6.0.17: MEJORADO - Captura multilínea incluyendo "R.\nEstrogenos" (IHQ250994)
    # V6.3.76 FIX IHQ250105: Agregado ", Con" y "Linfocitos" como terminadores
    # Ej: "marcación negativa para CD 20, Con marcación positiva para..."
    # Ej: "Negativo para CD 34, CD 23, CD 99 Linfocitos T..."
    logging.info("🔍 [V6.0.17] Ejecutando extract_narrative_biomarkers con soporte para R. Estrogenos")
    # Captura hasta palabras clave que indican fin de lista
    # V6.5.76 FIX IHQ250277: Límite de 500 caracteres para prevenir catastrophic backtracking en listas largas
    marcacion_list_pattern = r'(?i)(?:presentan\s+)?marcaci[óo]n\s+(positiva|negativa)\s+para[:\s]+(.{1,500}?)(?=,\s*Con\s+marcaci[oó]n|\s+Linfocitos|\s+además|\.\s*(?:En|A\d+\.|Negativ)|\.\s+[A-Z]|$)'
    for match in re.finditer(marcacion_list_pattern, text, re.DOTALL):
        estado = 'POSITIVO' if 'positiva' in match.group(1).lower() else 'NEGATIVO'
        lista_biomarkers_raw = match.group(2).strip()
        
        logging.info(f"🔍 Lista detectada: '{lista_biomarkers_raw}' → Estado: {estado}")
        
        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)
        
        # V6.0.12.1 FIX: Separar por comas Y "y", pero NO por "/" 
        # "/" se usa para variantes del MISMO biomarcador (EBERP4/Ep-CAM son el mismo: BER_EP4)
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+y\s+', lista_biomarkers_raw)
        
        logging.info(f"🔍 Biomarcadores separados: {biomarcadores_encontrados}")
        
        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw:
                continue
            
            # V6.0.12.1: Si contiene "/" (variantes del mismo biomarcador), tomar solo la primera parte
            # Ej: "EBERP4/Ep-CAM" → "EBERP4", "p63 p40" → "p63 p40" (sin cambios)
            if '/' in bio_raw:
                bio_raw_original = bio_raw
                bio_raw = bio_raw.split('/')[0].strip()
                logging.info(f"🔍 Split por '/': '{bio_raw_original}' → '{bio_raw}'")

            # V6.0.17: Limpiar texto descriptivo antes de normalizar (IHQ250994)
            # Ej: "P16 de forma parcheada" → "P16", "P53 de expresión usual (Wild Type)" → "P53"
            bio_raw = re.sub(r'\s+de\s+(forma|expresi[óo]n)\s+\w+.*', '', bio_raw, flags=re.IGNORECASE).strip()

            # V6.4.65 FIX IHQ250203: Capturar calificador entre paréntesis ANTES de eliminarlos
            # Ej: "p16 ( en bloque )" → nombre="p16", calificador="en bloque"
            calificador_match = re.search(r'([A-Za-z0-9\-/]+)\s*\(\s*(.+?)\s*\)', bio_raw, re.IGNORECASE)
            calificador_individual = None
            if calificador_match:
                bio_raw = calificador_match.group(1).strip()  # Extraer solo el nombre
                calificador_individual = calificador_match.group(2).strip()  # Guardar el calificador
            else:
                # Si no hay calificador entre paréntesis, limpiar paréntesis normalmente
                bio_raw = re.sub(r'\s*\([^)]+\).*', '', bio_raw).strip()

            # Normalizar nombre del biomarcador
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                valor_anterior = results.get(normalized_name, '')
                # V6.3.76 FIX IHQ250105: NEGATIVO explícito sobrescribe POSITIVO de listas genéricas
                # Razón: "marcación negativa para X" es más confiable que "marcadores: X, Y, Z"
                debe_sobrescribir = (
                    normalized_name not in results or
                    (estado == 'NEGATIVO' and valor_anterior == 'POSITIVO')
                )
                if debe_sobrescribir:
                    # V6.4.65: Aplicar calificador individual si existe
                    valor_final = estado
                    if calificador_individual:
                        valor_final = f"{estado} ({calificador_individual})"
                    results[normalized_name] = valor_final
                    if valor_anterior:
                        logging.info(f"✅ [extract_narrative] SOBRESCRITO: '{bio_raw}' → {normalized_name} = {estado} (antes: {valor_anterior})")
                    else:
                        logging.info(f"✅ [extract_narrative] Extraído: '{bio_raw}' → {normalized_name} = {estado}")
                else:
                    logging.info(f"⚠️ [extract_narrative] YA existe: '{bio_raw}' → {normalized_name} = {valor_anterior}")
            else:
                logging.warning(f"❌ [extract_narrative] NO normalizado: '{bio_raw}'")

    # V6.3.64 FIX IHQ250083: "marcación positiva y difusa para TTF1, Napsina A"
    # V6.4.36 FIX IHQ250174: AMPLIADO para incluir "tinción positiva" (no solo "marcación")
    # V6.4.39 FIX IHQ250175: AMPLIADO para "tinción nuclear/citoplasmática [intensidad] para"
    # V6.4.86 FIX IHQ250216: AMPLIADO para "inmunorreactividad positiva fuerte y difusa para [LISTA]"
    # V6.5.28 FIX IHQ250237: TERMINADOR mejorado - detener antes de " y es negativo/positivo"
    # Formato: [marcación|tinción|inmunorreactividad] [nuclear/citoplasmática] [positiva] [y] [adjetivos] para [lista]
    # Ej: "tinción positiva fuerte y difusa para CKAE1/AE3, PAX8, p16 en bloque y WT1"
    # Ej: "tinción nuclear fuerte y difusa para p53 (mutado-sobre-expresado)"
    # Ej: "inmunorreactividad positiva fuerte y difusa para PAX 8, WT1, p53, receptores de estrógenos"
    # IMPORTANTE: Detiene captura antes de cambio de contexto ("y es negativo/positivo para X")
    # V6.5.76 FIX IHQ250277: Límite de 400 caracteres para prevenir catastrophic backtracking
    marcacion_difusa_pattern = r'(?i)(?:marcaci[óo]n|tinci[óo]n|inmunorreactividad)(?:\s+(?:nuclear|citoplasm[aá]tica))?\s+(?:positiva?\s+)?(?:y\s+)?(?:difusa|fuerte|moderada|d[eé]bil)(?:\s+y\s+(?:difusa|fuerte|moderada|d[eé]bil))?\s+para\s+([^.]{1,400}?)(?:,?\s+y\s+es\s+(?:negativo|positivo)|\s+con\s+sobre-expresi[óo]n|\.?\s+Son\s+negativas|\.\s+[A-Z]|\.\s*$|$)'
    for match in re.finditer(marcacion_difusa_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()
        match_completo = match.group(0)
        logging.info(f"🔍 [V6.4.86 marcación/tinción/inmunorreactividad] MATCH COMPLETO: '{match_completo[:200]}'")
        logging.info(f"🔍 [V6.4.86 marcación/tinción/inmunorreactividad [nuclear] [positiva] difusa] Lista detectada: '{lista_biomarkers_raw}'")

        # Separar por comas y "y"
        biomarcadores_encontrados = re.split(r'[,]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.,')

            # V6.4.39 FIX IHQ250175: Extraer calificadores entre paréntesis antes de limpiar
            # Ej: "p53 (mutado-sobre-expresado)" → nombre: "p53", calificador: "MUTADO"
            calificador = ''
            bio_sin_calificador = bio_raw

            match_calificador = re.search(r'\(([^)]+)\)', bio_raw)
            if match_calificador:
                calificador_raw = match_calificador.group(1).strip()
                # Normalizar calificadores comunes
                if 'mutad' in calificador_raw.lower() or 'sobre-expresad' in calificador_raw.lower():
                    calificador = 'MUTADO'
                elif 'wild' in calificador_raw.lower() or 'salvaje' in calificador_raw.lower():
                    calificador = 'WILD TYPE'
                else:
                    calificador = calificador_raw.upper()
                # Remover paréntesis para normalizar nombre
                bio_sin_calificador = re.sub(r'\s*\([^)]+\)', '', bio_raw).strip()

            # V6.4.36: Limpiar calificadores de patrón (ej: "p16 en bloque" → "p16", "WT1 heterogéneo débil" → "WT1")
            bio_sin_calificador = re.sub(r'\s+(?:en\s+bloque|heterog[eé]ne[ao]\s+d[eé]bil|homog[eé]ne[ao]|difuso|focal).*$', '', bio_sin_calificador, flags=re.IGNORECASE).strip()

            if not bio_sin_calificador or len(bio_sin_calificador) < 2:
                continue
            normalized_name = normalize_biomarker_name(bio_sin_calificador)
            if normalized_name:
                # V6.4.36: SIEMPRE sobrescribir (este patrón es ALTA CONFIANZA, más que "Son negativas para")
                # V6.4.39: Ampliado para incluir locación (nuclear/citoplasmática) opcional + calificadores
                valor_anterior = results.get(normalized_name, '')
                if calificador:
                    results[normalized_name] = f'POSITIVO ({calificador})'
                else:
                    results[normalized_name] = 'POSITIVO'
                logging.info(f"✅ [V6.4.86 marcación/tinción/inmunorreactividad] Extraído: '{bio_raw}' → {normalized_name} = {results[normalized_name]} (prev: {valor_anterior})")

    # V6.4.86 FIX IHQ250216: "y focal para receptor de progesterona" (continuación de lista narrativa)
    # Formato: "y [focal|difusa|fuerte|débil] para [biomarcador]"
    # Contexto: Después de una lista principal, aparece un biomarcador adicional con intensidad diferente
    # Ej: "...receptores de estrógenos y focal para receptor de progesterona (tinción nuclear débil)"
    focal_continuation_pattern = r'(?i)y\s+(focal|difusa|fuerte|d[eé]bil|moderada)\s+para\s+([A-Za-z\sóáéí]+(?:\s+de\s+[A-Za-z]+)?)\s*(?:\([^)]+\))?'
    for match in re.finditer(focal_continuation_pattern, text):
        intensidad = match.group(1).strip().upper()
        bio_raw = match.group(2).strip().rstrip('.,')

        # Normalizar (ej: "receptor de progesterona" → "RP")
        normalized_name = normalize_biomarker_name(bio_raw)
        if normalized_name:
            valor_anterior = results.get(normalized_name, '')
            # Mapear intensidad a valor
            if 'FOCAL' in intensidad or 'DÉBIL' in intensidad or 'DEBIL' in intensidad:
                results[normalized_name] = 'POSITIVO FOCAL'
            else:
                results[normalized_name] = 'POSITIVO'
            logging.info(f"✅ [V6.4.86 y focal para] Extraído: '{bio_raw}' → {normalized_name} = {results[normalized_name]} (prev: {valor_anterior})")

    # V6.3.64 FIX IHQ250083: "Positividad focal para CK7"
    # Formato: Positividad [focal/fuerte/etc] para [biomarcador]
    positividad_focal_pattern = r'(?i)positividad\s+(focal|fuerte|moderada|d[eé]bil|difusa)\s+para\s+([A-Za-z0-9\s\-/]+?)(?=\.\s|,|\s+Negativo|\s+y\s+|$)'
    for match in re.finditer(positividad_focal_pattern, text, re.DOTALL):
        intensidad = match.group(1).strip().upper()
        bio_raw = match.group(2).strip().rstrip('.,')
