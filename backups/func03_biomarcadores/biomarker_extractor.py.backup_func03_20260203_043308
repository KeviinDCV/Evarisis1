        r'linfocitos\s+positivos\s+para\s+([A-Z0-9]+\s+y\s+[A-Z0-9]+)',
        # V6.4.89 FIX IHQ250218: COMENTADO - Causa contaminación en linfomas de células B
        # Patrón: "Linfocitos T acompañantes CD3, CD5" - captura CD3+ de células NO tumorales
        # Problema: En linfomas B, linfocitos T acompañantes son células normales (no tumorales)
        # Ejemplo IHQ250218: "Hay linfocitos T acompañantes CD3+, BCL2+" → CD3 NO debe extraerse
        # TODO: Restaurar con filtro de contexto si causa regresión en otros casos
        # r'[Ll]infocitos\s+T?\s*acompa[ñn]antes\s+([A-Z0-9]+(?:,\s+[A-Z0-9]+)+)',
        # Patrón: "positividad fuerte para CD23, débil para CD10 y BCL6" - captura CD23
        r'positividad\s+fuerte\s+para\s+([A-Z0-9]+)(?:,\s+d[eé]bil)',
        # Patrón complementario: "débil para CD10 y BCL6" - captura CD10 y BCL6
        r'd[eé]bil\s+para\s+([A-Z0-9]+\s+y\s+[A-Z0-9]+)',
        # V6.3.47 FIX IHQ250047: Patrón más específico para evitar capturar "para tinción con los marcadores: p16 y Ki 67"
        # Requiere contexto de positividad: "positivo para", "positividad para", "expresan"
        # V6.4.5 FIX IHQ250125: Permitir espacios en nombres (CD 20) y lista más larga
        r'(?i)(?:positiv[oa]s?|positividad|expresan|muestran)\s+(?:para|con)?\s*([A-Z0-9\s]+(?:\s+y\s+[A-Z0-9\s]+)+)(?:\s|\.|\,)',

        # V6.5.12 FIX IHQ250235: PRIORIDAD MÁXIMA - "No se observan células inmunorreactivas para [lista]"
        # V6.5.13 FIX IHQ250235: Cuantificador greedy (+) para capturar lista completa
        # Formato: "No se observan células inmunorreactivas para desmina, myogenina y MyoD1."
        # → DESMINA=NEGATIVO, MYOGENINA=NEGATIVO, MYOD1=NEGATIVO
        # DEBE IR ANTES del patrón genérico "no se observa" para capturar el formato completo
        # Cambios v6.5.13: +? → + (greedy), \.? → \. (punto obligatorio)
        r'(?i)No\s+se\s+observan?\s+c[eé]lulas\s+inmunorreactivas\s+para\s+([A-Za-z0-9\s,./\-\(\)+yYeÉóÓ\n]+)\.',

        # V6.5.18 FIX IHQ250237: PRIORIDAD MÁXIMA - "es negativo para [lista]"
        # V6.5.19 FIX: Terminador corregido para capturar lista completa con " y "
        # Formato: "es positivo focal para CKAE1/E3 y es negativo para GLYPICAN 3, AFP y CD 30"
        # → GLYPICAN3=NEGATIVO, AFP=NEGATIVO, CD30=NEGATIVO
        # DEBE IR ANTES del patrón genérico para capturar correctamente el contexto "es"
        # Terminador: solo punto o fin de texto (NO " y " que es parte de la lista)
        r'(?i)(?:es|son)\s+negativ[ao]s?\s+para\s+([A-Za-z0-9\s,./\-\(\)+yYeÉóÓ\n]+)(?:\.|\s*$)',

        # V6.4.3 FIX IHQ250120: Patrón para listas negativas "negativos para X, Y y Z"
        r'(?:negativ[ao]s?|no\s+se\s+observa|no\s+se\s+detecta)\s+(?:para|con)?\s*([A-Z0-9\s,./\-\(\)+yYeÉóÓ\n]+?)(?:\s|\.|$)',

        # Patrones originales mejorados
        # Patrón: "linfocitos positivos para X..." - genérico
        r'linfocitos\s+(?:positivos|T|B)\s+para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ\n]+?)\s+ubicados',
        r'linfocitos\s+(?:positivos|T|B)\s+para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ\n]+?)(?:\s+y\s+[A-Z0-9]+)*\s+ubicados',
        # Patrón: "Presentan linfocitos positivos para X" - greedy para capturar toda la lista
        r'[Pp]resentan\s+linfocitos\s+positivos\s+para\s+([A-Z0-9\s,yY]+?)(?:\s+ubicados|\s+y\s+[A-Z])',
        # Patrón: "positividad fuerte/débil para CD23" - captura intensidades
        r'positividad\s+(?:fuerte|d[eé]bil|moderada)\s+para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ\n]+?)(?=\s+y\s+|\.|\,)',
        # Patrón: "Marcación difusa/débil para MUM1/CD138" - POSITIVOS
        r'[Mm]arcaci[óo]n\s+(?:difusa|d[eé]bil|fuerte|moderada|esporadica|focal)\s+para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ\n]+?)(?=\s+y\s+|\.|\,)',
        r'[Mm]arcaci[óo]n\s+(?:d[eé]bil|difusa)\s+y\s+esporadica.*?para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ\n]+?)(?=\s+y\s+|\.|\,)',
        # V6.3.45: FIX IHQ250039 - Patrón: "marcación difusa de fuerte a moderada para receptores de estrógenos"
        # Captura variaciones con intensidad compuesta: "difusa de X a Y para biomarcador"
        r'[Mm]arcaci[óo]n\s+(?:difusa|d[eé]bil|fuerte|moderada)\s+(?:de\s+)?(?:fuerte|d[eé]bil|moderada)?\s*(?:a\s+)?(?:fuerte|d[eé]bil|moderada)?\s+para\s+([A-Za-z0-9\s,./\-\(\)yYeÉóÓ\n]+?)(?=\s+en\s+las|\s+y\s+|\.|\,)',
        # Patrón: "con marcación BCL2 positivos" - orden invertido
        r'con\s+marcaci[óo]n\s+([A-Z0-9]+)\s+positivos',
        # Patrón: "células plasmáticas positivas para CD38"
        r'c[eé]lulas\s+(?:plasm[aá]ticas|neoplásicas|tumorales)\s+positivas\s+para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ\n]+?)(?=\s+y\s+|\.|\,)',

        # Patrones originales (mantener sin cambios)
        r'(?:son\s+)?positivas?\s+para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ\n]+?)\s+y\s+c[eé]lulas',
        # V6.4.1: Agregado '+' a los caracteres permitidos para CD 20 +, etc.
        # V6.4.2: Mejorado lookahead negativo para incluir "siendo negativo" (IHQ250119)
        # V6.4.5 FIX IHQ250123: Soporte para masculino "negativos" y "siendo negativos"
        # MEJORADO: No truncar en "y [biomarcador]", solo en "y células" o punto.
        # V6.4.5 FIX IHQ250131: Agregar "son negativas" al lookahead negativo
        # V6.4.5 FIX IHQ250131: Agregar "son negativas" al terminador (lookahead positivo)
        r'(?:son\s+)?positivas?\s+para\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)(?=\s+y\s+c[eé]lulas|\.|$|,\s*(?:son|siendo)?\s*negativ[ao]s?)',
        # V6.1.5: Nuevo patrón "Hay positividad para celulas mioepiteliales X y Y" (IHQ251007)
        r'(?:Hay|hay)\s+positividad\s+para\s+(?:celulas|células)\s+(?:mioepiteliales\s+)?((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)(?=\.|$)',
        r'expresan\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)\s+y\s+c[eé]lulas',
        r'expresan\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)(?=\s+y\s+c[eé]lulas|\.|$)',
        r'muestran\s+positividad\s+para\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)(?=\s+y\s+c[eé]lulas|\.|$)',
        r'con\s+marcaci[óo]n\s+positiva\s+para\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)\s+y\s+c[eé]lulas',
        r'con\s+marcaci[óo]n\s+positiva\s+para\s+((?:(?!siendo\s+negativ[oa]s?|son\s+negativ[oa]s?|y\s+es\s+negativ[oa]s?|y\s+negativ[oa]s?|,\s*negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)(?=\s+y\s+c[eé]lulas|\.|$|,\s*(?:son|siendo)?\s*negativ[ao]s?)',
        # V6.4.3 FIX IHQ250120: Patrón para listas que terminan en "son negativas"
        r'((?:(?!son\s+positiv[oa]s?|son\s+negativ[oa]s?)[\w\s,./\-\(\)+yYeÉóÓ\n])+?)\s+son\s+negativ[oa]s?',
    ]

    for patron in patrones_narrativo:
        matches = re.finditer(patron, texto_microscopica, re.IGNORECASE)

        for match in matches:
            # V6.5.46 FIX IHQ250247: Manejo especial para "Negativa para mioepitelio ([lista]) y [biomarcador]"
            # Formato: "Negativa para mioepitelio (CK5-6 y P63) y Sinaptofisina"
            # → CK5_6=NEGATIVO, P63=NEGATIVO, SINAPTOFISINA=NEGATIVO
            match_full = match.group(0).upper()
            if 'NEGATIV' in match_full and ('MIOEPITELIO' in match_full or 'MIOEPITELIAL' in match_full):
                # Patrón "Negativa para mioepitelio" detectado
                lista_en_parentesis = match.group(1) if match.groups() else ""
                biomarcador_despues = match.group(2) if len(match.groups()) > 1 and match.group(2) else ""

                logging.info(f"🔍 [V6.5.46 MIOEPITELIO] Patrón detectado: lista='{lista_en_parentesis}', después='{biomarcador_despues}'")

                # Procesar biomarcadores dentro del paréntesis
                for bio_raw in re.split(r'[,\s]+y\s+|\s+y\s+|,\s*', lista_en_parentesis):
                    bio_raw = bio_raw.strip()
                    if bio_raw and len(bio_raw) > 1:
                        bio_norm = normalize_biomarker_name(bio_raw)
                        if bio_norm and bio_norm in BIOMARKER_DEFINITIONS:
                            bio_def = BIOMARKER_DEFINITIONS.get(bio_norm, {})
                            tipo_valor = bio_def.get('tipo_valor', 'QUALITATIVE')

                            if tipo_valor == 'QUALITATIVE':
                                columna = f"IHQ_{bio_norm}_ESTADO"
                            else:
                                columna = f"IHQ_{bio_norm}"

                            # V6.5.47 FIX IHQ250247: SOBRESCRIBIR SIEMPRE con NEGATIVO (mioepitelio = negativo)
                            # No importa si ya existe valor previo, mioepitelio es contexto negativo EXPLÍCITO
                            resultados[columna] = 'NEGATIVO'
                            # V6.5.50 FIX IHQ250247: Crear AMBAS columnas (con y sin _ESTADO) siempre
                            if tipo_valor == 'QUALITATIVE':
                                columna_alt = f"IHQ_{bio_norm}"
                                resultados[columna_alt] = 'NEGATIVO'  # Eliminar condición "if in resultados"
                            logging.info(f"   ✅ [MIOEPITELIO] {bio_raw} → {columna} = NEGATIVO (SOBRESCRITO)")

                # Procesar biomarcador después de "y" si existe
                if biomarcador_despues:
                    for bio_raw in re.split(r'[,\s]+y\s+|\s+y\s+|,\s*', biomarcador_despues):
                        bio_raw = bio_raw.strip()
                        # V6.5.47: Limpiar texto capturado de basura (líneas extra, "Anticuerpos:", etc)
                        # Problema: patrón captura "Sinaptofisina\nAnticuerpos" → solo queremos "Sinaptofisina"
                        if '\n' in bio_raw:
                            bio_raw = bio_raw.split('\n')[0].strip()  # Tomar solo primera línea
                        # Detener si encuentra palabras clave que NO son biomarcadores
                        if any(palabra in bio_raw.upper() for palabra in ['ANTICUERPOS', 'CONFIRM', 'VENTANA', 'REF.', 'RECEPTOR (']):
                            break  # Detener procesamiento, ya no son biomarcadores válidos

                        if bio_raw and len(bio_raw) > 1:
                            bio_norm = normalize_biomarker_name(bio_raw)
                            if bio_norm and bio_norm in BIOMARKER_DEFINITIONS:
                                bio_def = BIOMARKER_DEFINITIONS.get(bio_norm, {})
                                tipo_valor = bio_def.get('tipo_valor', 'QUALITATIVE')

                                if tipo_valor == 'QUALITATIVE':
                                    columna = f"IHQ_{bio_norm}_ESTADO"
                                else:
                                    columna = f"IHQ_{bio_norm}"

                                # V6.5.47 FIX IHQ250247: SOBRESCRIBIR SIEMPRE con NEGATIVO
                                resultados[columna] = 'NEGATIVO'
                                # V6.5.50 FIX IHQ250247: Crear AMBAS columnas (con y sin _ESTADO) siempre
                                if tipo_valor == 'QUALITATIVE':
                                    columna_alt = f"IHQ_{bio_norm}"
                                    resultados[columna_alt] = 'NEGATIVO'  # Eliminar condición "if in resultados"
                                logging.info(f"   ✅ [MIOEPITELIO] {bio_raw} → {columna} = NEGATIVO (SOBRESCRITO)")

                # Continuar con siguiente match (no procesar este match en los patrones generales)
                continue

            # V6.4.46 FIX IHQ250184: FILTRO - Excluir contextos de "estudios solicitados" (descripción macroscópica)
            # Problema: "se procesa estudio...para marcación con CA19-9, HER2, TTF-1" se marcaba como POSITIVO
            # Solución: Detectar contexto previo (100 caracteres antes) y descartar si es lista de estudios a realizar
            contexto_previo = texto_microscopica[max(0, match.start() - 100):match.start()].upper()
            contextos_excluidos = [
                'SE PROCESA ESTUDIO',
                'SE ORDENAN MARCADORES',
                'PARA MARCACIÓN CON',
                'PARA MARCACION CON',
                'PARA TINCIÓN CON',  # V6.5.17 FIX IHQ250237
                'PARA TINCION CON',  # V6.5.17 FIX IHQ250237
                'ESTUDIO DE INMUNOHISTOQUÍMICA PARA MARCACIÓN',
                'ESTUDIO DE INMUNOHISTOQUIMICA PARA MARCACION',
                'SE SOLICITAN ESTUDIOS',
                'ESTUDIOS SOLICITADOS'
            ]
            if any(contexto in contexto_previo for contexto in contextos_excluidos):
                # Saltar este match: es una lista de estudios solicitados, no resultados
                continue

            # V6.5.42 FIX IHQ250242: Filtro para patrón genérico que captura demasiado
            # Descartar matches del patrón genérico que contengan texto positivo antes de "son negativos"
            # Problema: Patrón genérico capturaba "CKAE1E3 y p40 positivos...vimentina, PAX8...son negativos"
            # Solución: Si el match contiene "positivo" o "positivos" antes de la lista, descartarlo
            match_full = match.group(0).upper()
            lista_capturada = match.group(1) if match.groups() else ""
            if 'POSITIVO' in lista_capturada.upper():
                # Match del patrón genérico que capturó texto con "positivo" → descartar
                logging.info(f"⚠️ [V6.5.42] Patrón genérico descartado (contiene 'positivo'): '{lista_capturada[:80]}...'")
                continue

            # V6.5.41 FIX IHQ250242: Manejo especial para "Los demás marcadores [lista] son negativos"
            # Este patrón indica valores de MAIN DIAGNOSIS que deben sobrescribir valores previos de regiones secundarias
            # Formato: "Los demás marcadores p40, vimentina, PAX 8 y receptor de estrógenos son negativos"
            # → p40=NEGATIVO (SOBRESCRIBE p40=POSITIVO de región exocervical)
            if ('LOS DEM' in match_full or 'LAS DEM' in match_full) and 'SON NEGATIV' in match_full:
                # Patrón "Los demás marcadores... son negativos" detectado
                lista_negativos = match.group(1).strip()
                logging.info(f"🔍 [V6.5.41] 'Los demás marcadores' detected: '{lista_negativos}'")

                # Procesar lista de NEGATIVOS con SOBRESCRITURA ABSOLUTA
                for bio_negativo in re.split(r'[,\s]+y\s+|\s+y\s+|,\s*', lista_negativos):
                    bio_negativo = bio_negativo.strip()
                    if bio_negativo:
                        bio_norm = normalize_biomarker_name(bio_negativo)
                        logging.info(f"   Bio: '{bio_negativo}' → Normalized: '{bio_norm}' | In DEFS: {bio_norm in BIOMARKER_DEFINITIONS if bio_norm else False}")
                        if bio_norm and bio_norm in BIOMARKER_DEFINITIONS:
                            # V6.5.41: Usar formato correcto de columna (algunos tienen _ESTADO)
                            # Obtener definición del biomarcador
                            bio_def = BIOMARKER_DEFINITIONS.get(bio_norm, {})
                            tipo_valor = bio_def.get('tipo_valor', 'QUALITATIVE')

                            # V6.5.41: Construir nombre de columna correcto
                            if tipo_valor == 'QUALITATIVE':
                                columna = f"IHQ_{bio_norm}_ESTADO"
                            else:
                                columna = f"IHQ_{bio_norm}"

                            logging.info(f"   ✅ SOBRESCRIBIENDO: {columna} = NEGATIVO")
                            resultados[columna] = 'NEGATIVO'  # SOBRESCRIBIR siempre (prioridad main diagnosis)

                # Continuar con el siguiente match (ya procesamos este)
                continue

            # V6.5.20 FIX IHQ250237: Manejo especial para patrón de contexto mixto (2 grupos: POSITIVOS y NEGATIVOS)
            # Formato: "es positivo focal para X y es negativo para Y, Z, W"
            # Grupo 1: Lista de biomarcadores POSITIVOS
            # Grupo 2: Lista de biomarcadores NEGATIVOS
            if len(match.groups()) >= 2 and 'POSITIV' in match_full and 'NEGATIV' in match_full:
                # Patrón mixto detectado - procesar ambos grupos por separado
                lista_positivos = match.group(1).strip()
                lista_negativos = match.group(2).strip()

                # Procesar lista de POSITIVOS (grupo 1)
                # V6.5.22 FIX: Sobrescribir SIEMPRE (sin verificar if columna not in) - patrón mixto tiene prioridad absoluta
                for bio_positivo in re.split(r'[,\s]+y\s+|\s+y\s+|,\s*', lista_positivos):
                    bio_positivo = bio_positivo.strip()
                    if bio_positivo:
                        bio_norm = normalize_biomarker_name(bio_positivo)
                        if bio_norm and bio_norm in BIOMARKER_DEFINITIONS:
                            columna = f"IHQ_{bio_norm}"
                            resultados[columna] = 'POSITIVO'  # SOBRESCRIBIR siempre

                # Procesar lista de NEGATIVOS (grupo 2)
                # V6.5.22 FIX: Sobrescribir SIEMPRE (sin verificar if columna not in) - patrón mixto tiene prioridad absoluta
                for bio_negativo in re.split(r'[,\s]+y\s+|\s+y\s+|,\s*', lista_negativos):
                    bio_negativo = bio_negativo.strip()
                    if bio_negativo:
                        bio_norm = normalize_biomarker_name(bio_negativo)
                        if bio_norm and bio_norm in BIOMARKER_DEFINITIONS:
                            columna = f"IHQ_{bio_norm}"
                            resultados[columna] = 'NEGATIVO'  # SOBRESCRIBIR siempre

                # Continuar con el siguiente match (ya procesamos este)
                continue

            # V6.3.77 FIX IHQ250116: Manejar múltiples grupos si el patrón tiene intensidad
            if len(match.groups()) >= 2:
                # Si el patrón mismo tiene un indicador negativo
                # V6.5.13 FIX IHQ250235: Agregado "NO SE OBSERVA" para "No se observan células inmunorreactivas"
                # V6.5.57 FIX IHQ250254: Agregado "SIN MARCACION" para "Sin marcación positiva para"
                if 'NO SE DETECTA' in match_full or 'NEGATIV' in match_full or 'NO SE OBSERVA' in match_full or 'SIN MARCACION' in match_full or 'SIN MARCACIÓN' in match_full:
                    intensidad_raw = None
                    lista_texto = match.group(2).strip()
                    estado_defecto = 'NEGATIVO'
                else:
                    # El grupo 1 es intensidad, el grupo 2 es la lista
                    intensidad_raw = match.group(1).strip().upper()
                    lista_texto = match.group(2).strip()
                    estado_defecto = 'POSITIVO'
            else:
                intensidad_raw = None
                lista_texto = match.group(1).strip()
                # V6.4.3 FIX IHQ250120: Detectar estado negativo en patrón de un solo grupo (ej: son negativas)
                # V6.5.13 FIX IHQ250235: Agregado "NO SE OBSERVA" para "No se observan células inmunorreactivas"
                # V6.5.57 FIX IHQ250254: Agregado "SIN MARCACION" para "Sin marcación positiva para"
                match_full = match.group(0).upper()
                if 'NO SE DETECTA' in match_full or 'NEGATIV' in match_full or 'NO SE OBSERVA' in match_full or 'SIN MARCACION' in match_full or 'SIN MARCACIÓN' in match_full:
                    estado_defecto = 'NEGATIVO'
                else:
                    estado_defecto = 'POSITIVO'

            # V6.5.80 FIX IHQ250270: Detectar "HETEROGÉNEA" y asignar estado especial
            # Formato: "positividad heterogénea para X, Y, Z" → X=POSITIVO HETEROGÉNEO, Y=POSITIVO HETEROGÉNEO, Z=POSITIVO HETEROGÉNEO
            # CRÍTICO: "heterogénea" indica expresión variable/parcial pero positiva
            if 'HETEROG' in match_full and estado_defecto == 'POSITIVO':
                estado_defecto = 'POSITIVO HETEROGÉNEO'

            # V6.4.65 FIX IHQ250203: Pre-procesar calificadores individuales por biomarcador
            # Problema: "p16 ( en bloque ) y p63" asignaba "(bloque)" a ambos biomarcadores
            # Solución: Extraer calificadores específicos ANTES de separar la lista

            # Detectar calificadores individuales: "BIOMARCADOR ( calificador )"
            # Patrón: nombre seguido de paréntesis con contenido
            # V6.5.60 FIX IHQ250254: Agregado \s para capturar nombres con espacios (SALL 4, PAX 8)
            calificadores_individuales = {}
            patron_calificador = r'([A-Za-z0-9\-/\s]+?)\s*\(\s*(.+?)\s*\)'
            for match_calif in re.finditer(patron_calificador, lista_texto, re.IGNORECASE):
                biomarcador_raw = match_calif.group(1).strip()
                calificador_texto = match_calif.group(2).strip()
                # Normalizar nombre del biomarcador
                bio_norm = normalize_biomarker_name(biomarcador_raw)
                if bio_norm:
                    # Guardar calificador específico para este biomarcador
                    calificadores_individuales[bio_norm] = calificador_texto

            # Limpiar calificadores entre paréntesis de la lista para parsing normal
            lista_texto_clean = re.sub(r'\(\s*[^)]+\s*\)', '', lista_texto)
            lista_texto = lista_texto_clean.strip()

            # V6.3.85 FIX IHQ250111: Detectar contexto de valor especial GLOBAL (aplicable a todos)
            # Si dice "positividad en mosaico", el valor debe reflejarlo
            match_full = match.group(0).upper()
            special_value_global = None
            if estado_defecto == 'NEGATIVO':
                special_value_global = 'NEGATIVO'
            elif 'MOSAICO' in match_full:
                special_value_global = 'POSITIVO (mosaico)'
            # V6.3.87 FIX IHQ250112: "positivo en todo el espesor del epitelio"
            elif 'TODO EL ESPESOR' in match_full:
                special_value_global = 'POSITIVO (todo el espesor)'

            # V6.4.65: No usar special_value global para "BLOQUE" - ahora se maneja individualmente
            special_value = special_value_global
            
            # V6.3.88 FIX IHQ250113: Captura de intensidad/patrón (fuerte, difuso, focal)
            # Solo si no se ha asignado un valor especial más específico (como bloque/mosaico)
            if not special_value:
                descriptors = []
                # V6.3.77 FIX IHQ250116: Usar intensidad capturada del regex si existe
                if intensidad_raw:
                    if 'FOCAL' in intensidad_raw: descriptors.append('focal')
                    elif 'MAYORITARIA' in intensidad_raw: descriptors.append('mayoritaria')
                    elif 'FUERTE' in intensidad_raw: descriptors.append('fuerte')
                    elif 'DIFUSA' in intensidad_raw: descriptors.append('difusa')
                
                # Solo buscar en match_full si no se ha detectado en intensidad_raw
                if not descriptors:
                    if 'FUERTE' in match_full or 'INTENSA' in match_full:
                        descriptors.append('fuerte')
                    if 'DIFUSA' in match_full:
                        descriptors.append('difusa')
                    if 'FOCAL' in match_full:
                        descriptors.append('focal')
                    if 'MODERADA' in match_full:
                        descriptors.append('moderada')
                
                if descriptors:
                    special_value = f"POSITIVO ({' y '.join(descriptors)})"

            # V6.0.5: Usar parser inteligente para procesar la lista
            biomarcadores_dict = parse_narrative_biomarker_list(lista_texto, biomarker_definitions, default_state=estado_defecto, debug_mode=debug_mode)

            # V6.4.65 FIX IHQ250203: Agregar biomarcadores con calificadores individuales
            for col, valor in biomarcadores_dict.items():
                # Primero verificar si hay un calificador GLOBAL (aplica a todos)
                if special_value:
                    valor = special_value
                else:
                    # V6.4.65: Verificar si este biomarcador específico tiene un calificador individual
                    # Extraer nombre normalizado de la columna (ej: "IHQ_P16_ESTADO" -> "P16")
                    bio_name = col.replace('IHQ_', '').replace('_ESTADO', '')
                    if bio_name in calificadores_individuales:
                        calificador = calificadores_individuales[bio_name]
                        # Aplicar calificador solo a este biomarcador
                        if valor in ['POSITIVO', 'NEGATIVO']:
                            valor = f"{valor} ({calificador})"

                # V6.4.65 FIX IHQ250203: SOBRESCRIBIR valores genéricos con calificadores individuales
                # Si este biomarcador tiene calificador individual, SIEMPRE sobrescribir
                # (incluso si ya existe un valor genérico "POSITIVO" sin calificador)
                bio_name = col.replace('IHQ_', '').replace('_ESTADO', '')
                if bio_name in calificadores_individuales:
                    # Este biomarcador tiene calificador específico → SOBRESCRIBIR siempre
                    resultados[col] = valor
                elif col not in resultados:
                    # No tiene calificador individual → solo agregar si no existe
                    resultados[col] = valor

    return resultados


def parse_narrative_biomarker_list(biomarker_text: str, biomarker_definitions: Dict[str, Any] = None, default_state: str = 'POSITIVO', debug_mode: bool = False) -> Dict[str, str]:
    """Parsea una lista narrativa de biomarcadores y retorna diccionario con valores.

    Versión: 6.0.6 - Agregado default_state para evitar sobrescrituras incorrectas

    Ejemplos de entrada:
    - "CKAE1E3, CK7 Y CAM 5.2"
    - "GFAP, S100 y SOX10"
    - "HER2, Ki-67 y Receptor de Estrógenos"

    Args:
        biomarker_text: Texto con lista de biomarcadores (ej: "CKAE1E3, CK7 Y CAM 5.2")
        biomarker_definitions: Diccionario con definiciones de biomarcadores (BIOMARKER_DEFINITIONS)

    Returns:
        Dict con claves IHQ_* y valores "POSITIVO"

    Ejemplo:
        Input: "CKAE1E3, CK7 Y CAM 5.2"
        Output: {'IHQ_CKAE1AE3': 'POSITIVO', 'IHQ_CK7': 'POSITIVO', 'IHQ_CAM5': 'POSITIVO'}
    """
    if not biomarker_text:
        return {}

    if biomarker_definitions is None:
        biomarker_definitions = BIOMARKER_DEFINITIONS

    # Normalizar texto: quitar saltos de línea, múltiples espacios
    text_clean = ' '.join(biomarker_text.split())
    text_clean = text_clean.upper()

    # V6.5.11 FIX IHQ250232: Limpiar calificadores de tipo de marcación
    # "p63 y citoplasmática de CK34BETA12" → "p63 y CK34BETA12"
    # Eliminar "[tipo] de" antes de biomarcadores
    text_clean = re.sub(r'\s+(?:NUCLEAR|CITOPLASM[AÁ]TICA|MEMBRANAL|DIFUSA|FOCAL)\s+DE\s+', ' ', text_clean)

    # V6.2.7: FIX IHQ251026 - Separar biomarcadores pegados sin coma
    # Ej: "CK7 CAM 5.2" → "CK7, CAM 5.2"
    # Patrón: [A-Z]+\d+ seguido de espacio y otro [A-Z]+ (sin número intermedio)
    # Excepciones: No separar "5.2", "5/6" (parte del nombre del biomarcador)
    text_clean = re.sub(r'([A-Z]+\d+)\s+([A-Z]{2,}(?:\s+\d))', r'\1, \2', text_clean)

    # V6.3.94: Romper por comas, punto y coma, y "ni"
    # V6.3.77: Agregar "NI " como separador
    # V6.4.2 FIX IHQ250119: Manejar "siendo negativo para" como separador que cambia el estado
    text_clean = re.sub(r'\bNI\s+(?:DE\s+)?', ', ', text_clean)
    text_clean = re.sub(r'\bSIENDO\s+NEGATIV[OA]\s+PARA\b', ', NEGATIVO PARA ', text_clean)
    raw_segments = re.split(r'[,;]\s*', text_clean)
    
    parts = []
    # V6.3.94 FIX IHQ250115: Detectar si el segmento completo termina en estado negativo (ej: "A y B negativos")

    # Si es así, evitaremos romper por 'y' para preservar la relación
    for segment in raw_segments:
        segment_upper = segment.upper()
        # Si termina en NEGATIVO/POSITIVO, no romper por "Y" si son marcadores
        prevenir_split_y = False
        if re.search(r'\s+(?:NEGATIVO|NEGATIVA|POSITIVO|POSITIVA|POSITIVAS)\s*$', segment_upper):
             prevenir_split_y = True
             
        # Solo romper por "y"/"e"/"ni" si lo que sigue parece un marcador conocido (o variante)
        # Esto evita romper "fuerte y difusa"
        # Buscamos " Y ", " E ", " NI ", " NI DE " rodeados de espacios
        y_split_pattern = r'\s+(?:Y|E|NI(?:\s+DE)?)\s+'
        sub_segments = []
        
        last_idx = 0
        for m in re.finditer(y_split_pattern, segment):
            if prevenir_split_y: continue # V6.3.94
            text_after = segment[m.end():].strip()
            # Si el texto tras el 'y'/'ni' empieza con algo que parece un marcador
            # O si el texto previo termina en algo que parece un marcador
            is_new_marker = False
            # V6.3.77: Heurística más simple para 'y' en listas de biomarcadores
            if re.search(r'^[A-Z]{1,10}\s?\d?\d?', text_after) or re.search(r'^[Rr]eceptor', text_after, re.IGNORECASE):
                is_new_marker = True
            else:
                for marker_id, def_val in biomarker_definitions.items():
                    keywords = [marker_id.upper()] + [n.upper() for n in def_val.get('nombres_alternativos', [])]
                    for kw in keywords:
                        if re.search(rf'^{re.escape(kw)}\b', text_after, re.IGNORECASE):
                            is_new_marker = True
                            break
                    if is_new_marker: break
            
            if is_new_marker:
                sub_segments.append(segment[last_idx:m.start()].strip())
                last_idx = m.end()
        
        sub_segments.append(segment[last_idx:].strip())
        parts.extend(sub_segments)
    
    # Limpiar cada parte y normalizar
    biomarkers_found = []
    for part in parts:
        part = part.strip()
        # V6.4.3 FIX IHQ250120: Limpiar ruido típico de introducciones de lista (ej: "Las inmunotinciones con todos los marcadores descritos (SOX-10")
        # V6.4.5: Limpiar prefijos adicionales como ". LOS MARCADORES"
        part = re.sub(r'^(?:\.*?\s*)?(?:LAS\s+INMUNOTINCIONES|LOS\s+MARCADORES|DE\s+MANERA|LOS\s+MARCADORES)\s+.*?\s*\(', '', part, flags=re.IGNORECASE)
        part = re.sub(r'^(?:\.*?\s*)?(?:LOS\s+MARCADORES|MARCADORES|EL\s+INDICE\s+DE\s+PROLIFERACION)\s+', '', part, flags=re.IGNORECASE)
        # Quitar puntos iniciales/residuales
        part = re.sub(r'^[.\s:]+', '', part).strip()
        # V6.5.56 FIX IHQ250254: Preservar paréntesis con calificadores (focal, difuso, etc.)
        # Quitar paréntesis al inicio/fin solamente si no envuelven un score HER2 O calificador
        # Calificadores comunes: (focal), (difuso), (difusa), (fuerte), (débil), (moderado), (intensa)
        preservar_parentesis = False
        if re.search(r'\((?:focal|difuso|difusa|fuerte|d[eé]bil|moderado|moderada|intensa|leve)\)', part, re.IGNORECASE):
            preservar_parentesis = True

        if part.startswith('(') and not re.match(r'^\([0-3]\+?\)', part) and not preservar_parentesis:
            part = part[1:].strip()
        if part.endswith(')') and not re.search(r'\([0-3]\+?\)$', part) and not preservar_parentesis:
            part = part[:-1].strip()
        if part:
            biomarkers_found.append(part)
    
    if debug_mode:
        logging.info(f"🔍 [parse_narrative_biomarker_list] Partes identificadas: {biomarkers_found}")

    # Mapear biomarcadores usando un escaneo de palabras clave (V6.3.94)
    result = {}
    for part in biomarkers_found:
        part_upper = part.upper()
        
        # 1. Detectar el estado base de esta parte
        # Si la parte contiene "negativo", etc., el estado base es NEGATIVO
        estado_base = default_state
        # V6.3.94 FIX IHQ250115: Evitar que "y es negativo para" afecte a marcadores ANTES de esa frase
        # Si detectamos "Y ES NEGATIVO PARA", dividimos la parte
        if ' Y ES NEGATIVO PARA ' in part_upper:
            # Procesar lo de antes como POSITIVO y lo de después como NEGATIVO
            sub_parts_mixed = part_upper.split(' Y ES NEGATIVO PARA ')
            # Procesar sub_parts_mixed[0] con estado POSITIVO
            # Procesar sub_parts_mixed[1] con estado NEGATIVO
            # Para simplificar, transformamos la parte actual en una que procesaremos recursivamente o por partes
            # Pero como estamos dentro del loop de 'parts', mejor ajustamos el estado dinámicamente
            pass 

        if re.search(r'\b(?:NEGATIVO|NEGATIVA|NO\s+SE\s+OBSERVA|EXPRESI[ÓO]N\s+PERDIDA|NO\s+SE\s+DETECTA)\b', part_upper):
             # Solo si no es el caso mixto complejo
             if ' Y ES NEGATIVO PARA ' not in part_upper:
                estado_base = 'NEGATIVO'
            
        # 2. Buscar TODOS los marcadores conocidos dentro de esta parte
        marcodores_en_parte = []

        # V6.4.47 FIX IHQ250185: Limpiar calificadores ANTES de normalizar
        # "p53 sobre expresado" → "p53" (calificador: sobreexpresado)
        # "receptor de estrógenos" → ya tiene alias en ER definition
        # "PAX 8" → "PAX8" (quitar espacio interno)
        part_limpio = part
        calificador_detectado = None

        # Detectar y extraer calificadores comunes
        # V6.5.09 FIX IHQ250231: Agregado "con tinción [baja|alta|media]"
        # V6.5.56 FIX IHQ250254: Agregado calificadores entre paréntesis: (focal), (difuso), etc.
        calificadores_pattern = r'\b(sobre\s+expresado|sobreexpresado|mutado|mutada|wild\s+type|salvaje|con\s+tinci[óo]n\s+(?:baja|alta|media))\b|\((?:focal|difuso|difusa|fuerte|d[eé]bil|moderado|moderada|intensa|leve)\)'
        match_calificador = re.search(calificadores_pattern, part, re.IGNORECASE)
        if match_calificador:
            calificador_detectado = match_calificador.group(0).upper()  # V6.5.56: Capturar grupo 0 (puede ser grupo 1 O paréntesis)
            # Remover calificador del nombre para normalización
            part_limpio = re.sub(calificadores_pattern, '', part, flags=re.IGNORECASE).strip()

        # Primero probar match exacto (vía normalize_biomarker_name)
        col_directa = normalize_biomarker_name(part_limpio)
        if col_directa:
            col_id = col_directa if col_directa.startswith('IHQ_') else f'IHQ_{col_directa}'

            # V6.5.39 FIX IHQ250242: Ki-67 removido de patrones narrativos para preservar porcentaje
            # Ki-67 tiene tipo_valor='PERCENTAGE' y debe capturar "80%" completo desde extract_single_biomarker()
            # Los patrones narrativos solo capturan "positivo" → se normaliza a "POSITIVO" perdiendo el porcentaje
            # Solución: Dejar que extract_single_biomarker() maneje Ki-67 exclusivamente
            # (Similar a HER2 removido en v6.3.20 para preservar score)
            if 'KI67' in col_id or 'KI-67' in col_id:
                continue  # Saltar Ki-67, se maneja en extract_single_biomarker()

            # V6.4.47: Aplicar calificador detectado si existe (ej: "p53 sobre expresado")
            estado_local = estado_base
            if calificador_detectado:
                estado_local = f'{estado_base} ({calificador_detectado})'
            # V6.4.9: Default scores for HER2 if missing context (solo si no hay calificador explícito)
            elif 'HER2' in col_id:
                if estado_base == 'NEGATIVO': estado_local = 'NEGATIVO (0)'
                elif estado_base == 'POSITIVO': estado_local = 'POSITIVO (3+)'
                elif estado_base == 'EQUIVOCO': estado_local = 'EQUIVOCO (2+)'

            marcodores_en_parte.append((col_id, estado_local))
        else:
            # Escaneo dinámico por nombres alternativos
            for m_id, m_def in biomarker_definitions.items():
                nombres = [m_id] + m_def.get('nombres_alternativos', [])
                for nombre in nombres:
                    # Buscar el nombre como palabra completa (escapando caracteres especiales como /)
                    # V6.3.77: Mejor manejo de nombres con /
                    nombre_esc = re.escape(nombre.upper())
                    if '/' in nombre_esc:
                        # Si tiene slash, no usamos \b inicial porque / no es word char
                        # Pero el nombre suele empezar con letra (CK)
                        pattern_nombre = rf'{nombre_esc}\b'
                    else:
                        pattern_nombre = rf'\b{nombre_esc}\b'
                    
                    if re.search(pattern_nombre, part_upper):
                        col_id = m_id if m_id.startswith('IHQ_') else f'IHQ_{m_id}'

                        # V6.5.39 FIX IHQ250242: Ki-67 removido de patrones narrativos para preservar porcentaje
                        # (Similar a HER2 removido en v6.3.20)
                        if 'KI67' in col_id or 'KI-67' in col_id:
                            continue  # Saltar Ki-67, se maneja en extract_single_biomarker()

                        # V6.4.5 FIX IHQ250133: Detección de valores específicos locales (equívoco, salvaje, mutado)
                        # Inicializar con el estado por defecto de la lista/parte
                        estado_local = default_state
                        
                        # V6.4.7: Detectar score real si existe (ej: "HER2 negativo (1+)")
                        match_score = re.search(r'\(\s*([0-3]\+?)\s*\)', part_upper)
                        score_suffix = f" ({match_score.group(1)})" if match_score and 'HER2' in col_id else ""

                        # Buscar en la parte del texto correspondiente a este biomarcador
                        if 'EQUÍVOCO' in part_upper or 'EQUIVOCO' in part_upper:
                            # Solo si es HER2 o similar (HER2 es el caso principal de equívoco)
                            if 'HER2' in col_id:
                                estado_local = f'EQUIVOCO{score_suffix if score_suffix else " (2+)"}'
                            else:
                                estado_local = 'EQUIVOCO'
                        elif 'SALVAJE' in part_upper or 'WILD TYPE' in part_upper:
                            # Típico de p53
                            # V6.4.28: Detectar si incluye "en mosaico" para formato completo
                            # Formato estándar: POSITIVO + (descripción)
                            if 'EN MOSAICO' in part_upper or 'MOSAICO' in part_upper:
                                estado_local = 'POSITIVO (patrón salvaje - mosaico)'
                            else:
                                estado_local = 'POSITIVO (PATRÓN SALVAJE)'
                        elif 'MUTADO' in part_upper and 'NO' not in part_upper:
                            estado_local = 'POSITIVO (MUTADA)'
                        elif 'NEGATIV' in part_upper or 'NO SE OBSERVA' in part_upper:
                            # V6.4.9: Default score (0) for HER2 if missing
                            if 'HER2' in col_id and not score_suffix:
                                estado_local = 'NEGATIVO (0)'
                            else:
                                estado_local = f'NEGATIVO{score_suffix}'
                        else:
                            # V6.4.47: Aplicar calificador detectado si existe (ej: "p53 sobre expresado")
                            if calificador_detectado:
                                estado_local = f'{default_state} ({calificador_detectado})'
                            # V6.4.7: Aplicar score al estado por defecto si existe (ej: "HER2 positivo (3+)")
                            # V6.4.9: Default score (3+) for HER2 if missing and state is POSITIVO
                            elif 'HER2' in col_id and not score_suffix and default_state == 'POSITIVO':
                                estado_local = 'POSITIVO (3+)'
                            else:
                                estado_local = f'{default_state}{score_suffix}'
                        
                        marcodores_en_parte.append((col_id, estado_local))
                        break # Encontrado este marcador, pasar al siguiente marker_id
        
        # 3. Agregar resultados encontrados
        for cid, est in marcodores_en_parte:
            # V6.3.47: Manejar sufijo _ESTADO para P16/P40
            if cid in ['IHQ_P16', 'IHQ_P40']:
                cid = f'{cid}_ESTADO'
            # V6.3.94: Solo guardar si no está ya o si el nuevo valor es más específico (NEGATIVO gana en conflictos de lista)
            if cid not in result or est == 'NEGATIVO':
                result[cid] = est

    return result


