    # 4. Extraer y procesar
    #
    # VENTAJAS:
    # - Sin cuantificadores anidados
    # - Complejidad O(n) lineal garantizada
    # - Más robusto y predecible
    # - Funciona incluso con listas de 40+ biomarcadores (caso IHQ250277)

    # Buscar todas las posiciones donde aparece "negativos"
    for match in re.finditer(r'\bnegativos\b', text_preprocessed, re.IGNORECASE):
        end_pos = match.start()

        # Retroceder máximo 400 caracteres buscando el inicio de la lista
        start_pos = max(0, end_pos - 400)
        fragmento = text_preprocessed[start_pos:end_pos]

        # Buscar el último punto o inicio de texto (marca inicio de oración)
        ultimo_punto = fragmento.rfind('.')
        if ultimo_punto != -1:
            fragmento = fragmento[ultimo_punto + 1:]

        fragmento = fragmento.strip()

        # Validar que sea una lista (tiene al menos una coma)
        if ',' not in fragmento:
            continue

        # Validar que empiece con letra (no con puntuación rara)
        if not fragmento or not fragmento[0].isalpha():
            continue

        # Extraer la lista completa
        lista_completa = fragmento

        # Normalizar: quitar saltos de línea, normalizar espacios
        lista_completa = re.sub(r'\s+', ' ', lista_completa)
        # Separar por comas y "y"
        lista_completa = re.sub(r'\s+y\s+', ', ', lista_completa)
        lista_completa = re.sub(r'\s*,\s*', ', ', lista_completa)
        markers = [m.strip() for m in lista_completa.split(',') if m.strip()]

        for marker in markers:
            normalized_name = normalize_biomarker_name(marker)
            if normalized_name:
                # V6.4.9: Default score (0) for HER2 if missing
                results[normalized_name] = 'NEGATIVO (0)' if normalized_name == 'HER2' else 'NEGATIVO'
                logging.info(f"✅ [Lista negativos V6.5.77] Extraído: '{marker}' → {normalized_name} = {results[normalized_name]}")

    # V6.X.X: NUEVOS patrones para formato descriptivo tipo IHQ251005
    # Patrón 6: "[lista]: [descripción cualitativa]" - Formato de linfomas/inmunofenotipo
    # Ej: "CD20 y CD3: distribución en patrón reactivo"
    # Ej: "BCL2 y BCL6: expresión en patrón reactivo folicular"
    # Ej: "CD38: células plasmáticas policlonales"
    # Ej: "IgG: células plasmáticas positivas"
    # Detecta términos que indican positividad/reactividad
    # Actualizado: Termina en punto o en otro biomarcador con dos puntos
    # V6.3.36 FIX IHQ250031: Excluir HER2 - tiene tipo DESCRIPTIVE y lógica especial en extract_single_biomarker
    descriptive_pattern = r'(?i)([A-Z][A-Za-z0-9\-]+(?:\s+y\s+[A-Z][A-Za-z0-9\-]+)*):\s*([^.]+?)(?=\.\s*[A-Z][A-Za-z0-9\-]+:|\.(?:\s|$)|$)'

    for match in re.finditer(descriptive_pattern, text):
        biomarcadores_raw = match.group(1).strip()
        descripcion = match.group(2).strip().lower()

        # V6.3.36 FIX IHQ250031: Excluir HER2 del patrón descriptivo
        # HER2 tiene tipo_valor='DESCRIPTIVE' y debe manejarse exclusivamente por extract_single_biomarker
        # para preservar el valor completo con score (ej: "EQUIVOCO ( Score 2+)")
        if re.search(r'(?i)^HER\s*-?\s*2$', biomarcadores_raw):
            continue

        # V6.3.42 FIX IHQ250035: Excluir marcadores MMR (tienen patrones específicos en ADVANCED_BIOMARKER_PATTERNS)
        # El extractor narrativo captura demasiado contexto y causa falsos negativos por palabras como "pérdida"
        if re.search(r'(?i)^(MLH1|MSH2|MSH6|PMS2)$', biomarcadores_raw):
            continue

        # Determinar estado basado en palabras clave en la descripción
        estado = None
        if any(keyword in descripcion for keyword in ['positiv', 'reactiv', 'expresión', 'distribuci', 'marcaci', 'células']):
            # Verificar si hay negación - V6.3.3 FIX IHQ250006: Agregar "pérdida" como negación
            if any(neg in descripcion for neg in ['no se', 'ausencia', 'negativ', 'sin expresión', 'pérdida', 'perdida']):
                estado = 'NEGATIVO'
            else:
                estado = 'POSITIVO'

        if estado:
            # Separar biomarcadores si hay "y"
            biomarcadores_lista = [b.strip() for b in re.split(r'\s+y\s+', biomarcadores_raw)]

            for bio_raw in biomarcadores_lista:
                normalized_name = normalize_biomarker_name(bio_raw)
                if normalized_name and normalized_name not in results:
                    # V6.4.9: Default scores for HER2 if missing
                    final_estado = estado
                    if normalized_name == 'HER2':
                        final_estado = 'NEGATIVO (0)' if estado == 'NEGATIVO' else 'POSITIVO (3+)'
                    
                    results[normalized_name] = final_estado
                    logging.info(f"✅ [Descriptivo] Extraído: '{bio_raw}' → {normalized_name} = {estado} ('{descripcion[:50]}...')")

    # ═══════════════════════════════════════════════════════════════════════════════
    # V6.3.77 FIX IHQ250105: PASE FINAL - Patrones explícitos NEGATIVO sobrescriben TODO
    # ═══════════════════════════════════════════════════════════════════════════════
    # Este bloque se ejecuta AL FINAL para garantizar que indicadores explícitos
    # de NEGATIVO tengan la última palabra sobre cualquier extracción anterior.
    #
    # Problema: Patrones genéricos extraen de listas como "tinción con: CD20, CD79..."
    # y marcan todo como POSITIVO. Luego patrones NEGATIVO intentan corregir pero
    # pueden ejecutarse antes o el valor ya fue sobrescrito.
    #
    # Solución: Ejecutar patrones NEGATIVO explícitos AL FINAL con sobrescritura forzada.
    # ═══════════════════════════════════════════════════════════════════════════════

    # Patrón 1: "marcación negativa/negativo para X, Y, Z"
    # V6.4.12 FIX IHQ250149: Captura "negativo" (masculino) además de "negativa" (femenino)
    # Ej: "con marcación negativo para MDM2, CDK4, DESMINA, AML" (error de concordancia en informe)
    final_marcacion_neg = re.findall(
        r'(?i)marcaci[óo]n\s+negativ[ao]\s+para\s+([A-Za-z0-9\s,\-/]+?)(?=,\s*[Ee]s\s+[Pp]ositiv|\s+es\s+Positiv|,\s*Con\s+marcaci[oó]n|\s+Linfocitos|\.\s|$)',
        text
    )
    for match in final_marcacion_neg:
        # Separar por comas
        biomarkers = re.split(r'\s*,\s*', match.strip())
        for bio in biomarkers:
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized:
                    valor_anterior = results.get(normalized, 'NO EXISTÍA')
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"🔴 [PASE FINAL v6.3.77] FORZANDO: {normalized} = NEGATIVO (era: {valor_anterior}) desde 'marcación negativa para'")

    # Patrón 2: "Negativo para X, Y, Z" (al inicio de oración o después de punto)
    final_negativo_para = re.findall(
        r'(?i)(?:^|\.\s*)Negativo\s+para\s+([A-Za-z0-9\s,\-]+?)(?=\s+Linfocitos|\s+células|\s+acompañantes|\.\s|,\s+diagn[oó]stico|$)',
        text
    )
    for match in final_negativo_para:
        # Separar por comas
        biomarkers = re.split(r'\s*,\s*', match.strip())
        for bio in biomarkers:
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized:
                    valor_anterior = results.get(normalized, 'NO EXISTÍA')
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"🔴 [PASE FINAL v6.3.77] FORZANDO: {normalized} = NEGATIVO (era: {valor_anterior}) desde 'Negativo para'")

    # Patrón 3: "tienen marcación negativa para X" (contexto narrativo completo)
    final_tienen_neg = re.findall(
        r'(?i)tienen\s+marcaci[óo]n\s+negativa\s+para\s+([A-Za-z0-9\s,\-]+?)(?=,\s*Con|\.\s|$)',
        text
    )
    for match in final_tienen_neg:
        biomarkers = re.split(r'\s*,\s*', match.strip())
        for bio in biomarkers:
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized:
                    valor_anterior = results.get(normalized, 'NO EXISTÍA')
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"🔴 [PASE FINAL v6.3.77] FORZANDO: {normalized} = NEGATIVO (era: {valor_anterior}) desde 'tienen marcación negativa'")

    # V6.4.23 PASE FINAL (PRIORIDAD MÁXIMA): FIX IHQ250162 - Patrón "No presentan expresión para [lista]" → NEGATIVO
    # Ej: "No presentan expresión para calretinina, desmina, SMA, EMA, progesterona, CD34, GFAP, p53"
    # CRÍTICO: Este patrón se ejecuta AL FINAL para sobrescribir valores incorrectos capturados por patrones anteriores
    # Motivo: Patrón "positivas de manera focal para" puede capturar incorrectamente biomarcadores de frase siguiente
    no_presentan_expresion_pattern = r'(?i)No\s+presentan?\s+expresi[óo]n\s+para\s+([A-Za-z0-9\s,./\-yY]+?)(?:\.\s|\.$|$)'
    for match in re.finditer(no_presentan_expresion_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.4.23 PASE FINAL - No presentan expresión] Lista detectada: '{lista_biomarkers_raw}'")

        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # Separar por comas Y "y"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw:
                continue

            # Normalizar nombre del biomarcador (maneja typos como CKE1E3 → CKAE1E3)
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                # FORZAR NEGATIVO - sobrescribe SIEMPRE valores anteriores (incluso "POSITIVO (focal)" incorrecto)
                valor_anterior = results.get(normalized_name, 'NO EXISTÍA')
                results[normalized_name] = 'NEGATIVO (0)' if normalized_name == 'HER2' else 'NEGATIVO'
                logging.info(f"🔴 [PASE FINAL v6.4.23] FORZANDO: {normalized_name} = NEGATIVO (era: {valor_anterior}) desde 'No presentan expresión'")

    # V6.4.89 FIX IHQ250218: POST-PROCESAMIENTO - Eliminar CD3/BCL2 si provienen de "linfocitos T acompañantes"
    # Problema: Linfomas B tienen linfocitos T acompañantes (células normales, NO tumorales)
    # Formato OCR: "Hay linfocitos T acompañantes CD3+, BCL2+" → CD3/BCL2 NO deben reportarse
    # Solución: Si detectamos el patrón de células acompañantes Y tenemos CD3/BCL2 extraídos, eliminarlos
    # Nota: Buscar tanto 'CD3' como 'IHQ_CD3' porque depende de la fuente de extracción
    if 'CD3' in results or 'IHQ_CD3' in results or 'BCL2' in results or 'IHQ_BCL2' in results:
        # Buscar patrón de células acompañantes en el texto
        acompanantes_pattern = r'(?i)(?:hay\s+)?linfocitos?\s+T\s+acompa[ñn]antes\s+(?:CD\s*3|BCL\s*2)'
        if re.search(acompanantes_pattern, text):
            # Eliminar CD3 (en cualquiera de sus formas)
            if 'CD3' in results:
                valor_removido = results.pop('CD3')
                logging.info(f"⚠️ [V6.4.89 POST-FILTRO] CD3 removido: '{valor_removido}' (contexto: linfocitos T acompañantes, NO resultado tumoral)")
            if 'IHQ_CD3' in results:
                valor_removido = results.pop('IHQ_CD3')
                logging.info(f"⚠️ [V6.4.89 POST-FILTRO] IHQ_CD3 removido: '{valor_removido}' (contexto: linfocitos T acompañantes, NO resultado tumoral)")
            # Eliminar BCL2 (en cualquiera de sus formas)
            if 'BCL2' in results:
                valor_removido = results.pop('BCL2')
                logging.info(f"⚠️ [V6.4.89 POST-FILTRO] BCL2 removido: '{valor_removido}' (contexto: linfocitos T acompañantes, NO resultado tumoral)")
            if 'IHQ_BCL2' in results:
                valor_removido = results.pop('IHQ_BCL2')
                logging.info(f"⚠️ [V6.4.89 POST-FILTRO] IHQ_BCL2 removido: '{valor_removido}' (contexto: linfocitos T acompañantes, NO resultado tumoral)")

    return results


def post_process_biomarker_list_with_modifiers(biomarker_text: str) -> Dict[str, str]:
    """
    Procesa lista narrativa de biomarcadores, detectando modificadores individuales.

    V6.0.6: Agregada para IHQ250983 - manejo de listas con modificadores.

    Ejemplos:
    - "CKAE1AE3, S100, PAX8 y p40 heterogéneo"
      -> {'CKAE1AE3': 'POSITIVO', 'S100': 'POSITIVO', 'PAX8': 'POSITIVO', 'P40': 'POSITIVO HETEROGÉNEO'}
    - "CK7, CK20 focal y TTF-1 difuso"
      -> {'CK7': 'POSITIVO', 'CK20': 'POSITIVO FOCAL', 'TTF1': 'POSITIVO DIFUSO'}

    Args:
        biomarker_text: Texto con lista (ej: "CKAE1AE3, S100, PAX8 y p40 heterogéneo")

    Returns:
        Dict con biomarcadores y valores con modificadores
    """
    if not biomarker_text:
        return {}

    result = {}

    # Limpiar texto
    text_clean = biomarker_text.strip()

    # Dividir por comas y "y"/"e"
    # Usar regex para preservar modificadores
    parts = re.split(r',\s*|\s+y\s+|\s+e\s+', text_clean, flags=re.IGNORECASE)

    for part in parts:
        part = part.strip()
        # V6.0.10: Limpiar caracteres especiales iniciales (comas, puntos, punto y coma)
        part = part.lstrip(',.;')
        part = part.strip()
        if not part:
            continue

        # Detectar modificador al final (heterogéneo, focal, difuso)
        modifier_match = re.search(r'^(.+?)\s+(heterog[eé]neo|focal|difuso)$', part, re.IGNORECASE)

        if modifier_match:
            # Tiene modificador
            biomarker_raw = modifier_match.group(1).strip()
            modifier = modifier_match.group(2).strip().upper()

            # Normalizar modificador
            if modifier in ['HETEROGÉNEO', 'HETEROGENEO']:
                modifier = 'HETEROGÉNEO'

            normalized_name = normalize_biomarker_name(biomarker_raw)
            if normalized_name:
                result[normalized_name] = f'POSITIVO {modifier}'
        else:
            # Sin modificador, solo positivo
            normalized_name = normalize_biomarker_name(part)
            if normalized_name:
                result[normalized_name] = 'POSITIVO'

    return result


