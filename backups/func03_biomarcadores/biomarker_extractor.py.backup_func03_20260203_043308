    # Captura biomarcadores en formato compacto SIN requerir "inmunofenotipo" como prefijo
    # V6.4.72 FIX IHQ250205: Agregar verificación de contexto para excluir microambiente/estudios solicitados
    compact_general_pattern = r'(?<![a-zA-Z])([A-Za-z]{2,}[0-9]*(?:[a-zA-Z])?)\s*([+-])(?=[\s,.\)]|$)'
    for match in re.finditer(compact_general_pattern, text):
        bio_name = match.group(1).strip()
        signo = match.group(2)

        # V6.4.72 FIX IHQ250205: Mostrar contexto para debugging
        start_pos = match.start()
        context_start = max(0, start_pos - 80)
        context_end = min(len(text), match.end() + 80)
        context = text[context_start:context_end]

        # Verificar que sea un biomarcador reconocido antes de incluirlo
        normalized_name = normalize_biomarker_name(bio_name)
        if normalized_name and normalized_name not in results:
            # V6.4.72 FIX IHQ250205: Verificar contexto igual que V6.3.56 Parentético
            # Excluir si está en microambiente/tejido normal/estudios solicitados
            context_lower = context.lower()
            exclude_keywords = [
                'microambiente', 'micro ambiente', 'micro-ambiente',
                'linfocitos t maduros', 'linfocitos t normales',
                'linfocitos t acompañantes', 'linfocitos t reactivos',
                'población acompañante', 'poblacion acompañante',
                'componente inflamatorio', 'infiltrado inflamatorio',
                'tejido normal', 'tejido no tumoral',
                'células normales', 'celulas normales',
                'acompañante está compuesto', 'acompañante esta compuesto',
                'estudios solicitados', 'para los siguientes marcadores',
                'se realizan cortes', 'se realizan estudios'
            ]

            if any(keyword in context_lower for keyword in exclude_keywords):
                logging.warning(f"⚠️ [V6.3.51 EXCLUIDO v6.4.72] '{bio_name}{signo}' en contexto de microambiente/estudios solicitados")
                logging.warning(f"⚠️ [V6.3.51 CONTEXTO] ...{context[:150]}...")
                continue

            estado = 'POSITIVO' if signo == '+' else 'NEGATIVO'
            results[normalized_name] = estado
            logging.info(f"✅ [V6.3.51 compacto general] Extraído: '{bio_name}{signo}' → {normalized_name} = {estado}")
            # DEBUG: Mostrar contexto para CD4 y CD7 específicamente
            if normalized_name in ['CD4', 'CD7']:
                logging.info(f"🔍 [V6.3.51 CONTEXTO {normalized_name}] ...{context}...")

    # V6.3.51 FIX IHQ250055: NUEVO - Patrón para "expresión no concluyente para [lista]"
    # Ej: "con expresión no concluyente para CD4+" → CD4 NO CONCLUYENTE
    no_concluyente_pattern = r'(?i)expresi[óo]n\s+no\s+concluyente\s+para\s+([A-Za-z0-9\s,+\-]+?)(?=\s+y\s+(?:ausencia|presencia)|\.|\s*$)'
    for match in re.finditer(no_concluyente_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.3.51 no concluyente] Detectado: '{lista_biomarkers_raw}'")

        # Limpiar y separar biomarcadores
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.').rstrip('+').rstrip('-')
            if not bio_raw:
                continue

            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                # V6.3.51: NO CONCLUYENTE tiene prioridad ALTA sobre POSITIVO del patrón compacto
                # Porque el texto explícitamente dice "no concluyente"
                valor_actual = results.get(normalized_name, '')
                if normalized_name not in results or valor_actual in ['NO MENCIONADO', 'N/A', '', 'POSITIVO']:
                    results[normalized_name] = 'NO CONCLUYENTE'
                    logging.info(f"✅ [no concluyente] Extraído: '{bio_raw}' → {normalized_name} = NO CONCLUYENTE (sobreescribe: {valor_actual})")

    # V6.3.51 FIX IHQ250055: MEJORADO - Patrón para "ausencia de expresión para [lista]"
    # Complementa el patrón existente de "pérdida de expresión" con mejor parsing
    # Ej: "ausencia de expresión para CD1 a, ALK y S100" → CD1A NEGATIVO, ALK NEGATIVO, S100 NEGATIVO
    ausencia_expresion_pattern = r'(?i)ausencia\s+de\s+expresi[óo]n\s+para\s+([A-Za-z0-9\s,.\-]+?)(?=\.\s*[A-Z]|\.\s*$|$)'
    for match in re.finditer(ausencia_expresion_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.3.51 ausencia expresión] Detectado: '{lista_biomarkers_raw}'")

        # Limpiar y separar biomarcadores
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            # Limpiar espacios en nombres como "CD1 a" → "CD1a"
            bio_raw = re.sub(r'\s+([a-zA-Z])$', r'\1', bio_raw)
            if not bio_raw:
                continue

            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"✅ [ausencia expresión] Extraído: '{bio_raw}' → {normalized_name} = NEGATIVO")

    # V6.0.22: NUEVO - Patrón para "Sin marcación para [lista]" (IHQ251009)
    # Ej: "Sin marcación para CD30, CICLINA, CMYC"
    # Captura listas de biomarcadores NEGATIVOS en casos de linfomas
    sin_marcacion_pattern = r'(?i)Sin\s+marcaci[óo]n\s+para\s+([A-Z0-9\s,./\-\(\)yYeÉóÓ]+?)(?=\.|\s+Ki67|\s+ki67|$)'
    for match in re.finditer(sin_marcacion_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.0.22] 'Sin marcación' detectada: '{lista_biomarkers_raw}' → Estado: NEGATIVO")

        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # V6.3.78 FIX IHQ250106: Separar por comas, "y" Y "ni" (antes faltaba "ni")
        # Ej: "CKAE1/AE3, ni GATA 3" → ['CKAE1/AE3', 'GATA 3']
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+[yYnN][iI]?\s+', lista_biomarkers_raw)

        logging.info(f"🔍 Biomarcadores sin marcación separados: {biomarcadores_encontrados}")

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            # V6.3.78 FIX IHQ250106: Limpiar "ni" residual al inicio
            bio_raw = re.sub(r'^(?:ni|y)\s+', '', bio_raw, flags=re.IGNORECASE)
            if not bio_raw:
                continue

            # Normalizar nombre del biomarcador
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"✅ [sin marcación] Extraído: '{bio_raw}' → {normalized_name} = NEGATIVO")

    # V6.4.34 FIX IHQ250170: NUEVO - Patrón para "no se reconocen [anatomía], BIOMARCADOR1, BIOMARCADOR2... negativos/positivos"
    # Ej: "En la muestra evaluada no se reconocen meninges, EMA, AE1/AE3, progesterona negativos"
    # Captura biomarcadores en lista compacta con estado compartido al final
    # IMPORTANTE: Excluye términos anatómicos (meninges, tejido, etc.) y solo procesa biomarcadores
    no_reconocen_shared_pattern = r'(?i)no\s+se\s+reconocen?\s+([^.]+?)\s+(negativos?|positivos?)(?=\.|,\s+Se\s|$)'
    for match in re.finditer(no_reconocen_shared_pattern, text):
        lista_completa = match.group(1).strip()
        estado_raw = match.group(2).strip().lower()

        # Normalizar estado
        estado = 'NEGATIVO' if 'negativ' in estado_raw else 'POSITIVO'

        logging.info(f"🔍 [V6.4.34 no reconocen] Detectado: '{lista_completa}' → Estado: {estado}")

        # Separar por comas la lista completa
        elementos = re.split(r',\s*', lista_completa)

        # Términos anatómicos que NO son biomarcadores (excluir)
        terminos_anatomicos = ['meninges', 'meninge', 'tejido', 'celulas', 'células', 'epitelio',
                               'estroma', 'parenquima', 'parénquima', 'mucosa', 'submucosa']

        for elemento in elementos:
            elemento = elemento.strip()
            if not elemento:
                continue

            # Verificar si es término anatómico (NO procesar)
            if any(term in elemento.lower() for term in terminos_anatomicos):
                logging.info(f"⏭️ [no reconocen] Ignorando término anatómico: '{elemento}'")
                continue

            # Normalizar y verificar si es biomarcador válido
            normalized_name = normalize_biomarker_name(elemento)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = estado
                logging.info(f"✅ [V6.4.34 no reconocen] Extraído: '{elemento}' → {normalized_name} = {estado}")

    # V6.2.7: NUEVO - Patrón para "No hay marcación en la muestra para [lista]" (IHQ251026)
    # V6.4.80 FIX IHQ250213: Soportar "ni hay marcación para [lista]" además de "No hay..."
    # Ej: "No hay marcación en la muestra para p40, p16, CD20, BCL2 ni BCL6"
    # Ej: "ni hay marcación para CK7, CK20, CKAE1E3, PAX-8, GATA-3, CDX2, TTF-1"
    # Captura hasta "marcación para" (positiva) que indica cambio de estado
    no_hay_marcacion_pattern = r'(?i)(?:No|ni)\s+hay\s+marcaci[óo]n\s+(?:en\s+la\s+muestra\s+)?para\s+([a-z0-9\s,./\-\(\)yYeÉóÓni]+?)(?=,?\s+marcaci[óo]n\s+para|\.|\s*$)'
    for match in re.finditer(no_hay_marcacion_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.2.7] 'No hay marcación' detectada: '{lista_biomarkers_raw}' → Estado: NEGATIVO")

        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # Separar por comas, "y", y "ni"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+[yYnN][iI]?\s+', lista_biomarkers_raw)

        logging.info(f"🔍 Biomarcadores 'No hay marcación' separados: {biomarcadores_encontrados}")

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw:
                continue

            # Normalizar nombre del biomarcador
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"✅ [No hay marcación] Extraído: '{bio_raw}' → {normalized_name} = NEGATIVO")

    # V6.3.74 FIX IHQ250093: NUEVO - Patrón para "No hay inmunorreactividad para X ni Y"
    # Ej: "No hay inmunorreactividad para IgG4 ni CD38" → IgG4 NEGATIVO, CD38 NEGATIVO
    # Captura listas con "ni" o "y" como separadores
    no_inmunorreactividad_pattern = r'(?i)No\s+hay\s+inmunorreactividad\s+para\s+([A-Za-z0-9\s,./\-\(\)yYnNiI]+?)(?:\.|\s*$)'
    for match in re.finditer(no_inmunorreactividad_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.3.74] 'No hay inmunorreactividad' detectada: '{lista_biomarkers_raw}' → Estado: NEGATIVO")

        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # Separar por comas, "y", y "ni"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+[yYnN][iI]?\s+', lista_biomarkers_raw)

        logging.info(f"🔍 Biomarcadores 'No hay inmunorreactividad' separados: {biomarcadores_encontrados}")

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw or len(bio_raw) < 2:
                continue

            # Normalizar nombre del biomarcador
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                # NEGATIVO sobrescribe valores anteriores (es alta confianza)
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"✅ [No hay inmunorreactividad] Extraído: '{bio_raw}' → {normalized_name} = NEGATIVO")

    # V6.4.41 FIX IHQ250175: NUEVO - Patrón para "No se identifica marcación para X (negativo tipo salvaje)"
    # Ej: "No se identifica marcación para IDH (negativo tipo salvaje)" → IDH NEGATIVO
    # Captura biomarcador con posible calificador entre paréntesis
    no_se_identifica_pattern = r'(?i)No\s+se\s+identifica\s+marcaci[óo]n\s+para\s+([A-Za-z0-9\s,./\-\(\)]+?)(?:\.|\s*$)'
    for match in re.finditer(no_se_identifica_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.4.41] 'No se identifica marcación' detectada: '{lista_biomarkers_raw}' → Estado: NEGATIVO")

        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # Separar por comas, "y", y "ni"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+(?:y|ni)\s+', lista_biomarkers_raw, flags=re.IGNORECASE)

        logging.info(f"🔍 Biomarcadores 'No se identifica marcación' separados: {biomarcadores_encontrados}")

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw or len(bio_raw) < 2:
                continue

            # Remover calificadores entre paréntesis (ej: "IDH (negativo tipo salvaje)" → "IDH")
            bio_sin_calificador = re.sub(r'\s*\([^)]+\)', '', bio_raw).strip()

            # Normalizar nombre del biomarcador
            normalized_name = normalize_biomarker_name(bio_sin_calificador)
            if normalized_name:
                # NEGATIVO sobrescribe valores anteriores (es alta confianza - negación explícita)
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"✅ [No se identifica marcación] Extraído: '{bio_raw}' → {normalized_name} = NEGATIVO")

            # Normalizar nombre del biomarcador
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"✅ [No hay inmunorreactividad] Extraído: '{bio_raw}' → {normalized_name} = NEGATIVO")

    # V6.3.5 FIX IHQ250008: NUEVO - Patrón para "Los marcadores X, Y, Z no son valorables"
    # Ej: "Los marcadores CKAE1E3, PAX-5, CD3... no son valorables por severos defectos de fase preanalítica"
    # Estado: NO VALORABLE (problema técnico, no es que sean negativos)
    no_valorables_pattern = r'(?i)(?:Los\s+)?marcadores?\s+(.+?)\s+no\s+(?:son|es)\s+valorables?'
    for match in re.finditer(no_valorables_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()
        # V6.3.79 FIX IHQ250107: Evitar capturar frases como "mostró una marcación adecuada"
        if re.search(r'(?i)mostr[oó]|marcaci[oó]n|adecuada', lista_biomarkers_raw):
