        normalized_name = normalize_biomarker_name(bio_raw)
        if normalized_name and normalized_name not in results:
            # Mapear intensidad a valor
            if intensidad == 'FOCAL':
                valor = 'POSITIVO FOCAL'
            else:
                valor = 'POSITIVO'
            results[normalized_name] = valor
            logging.info(f"✅ [positividad focal] Extraído: '{bio_raw}' → {normalized_name} = {valor}")

    # V6.5.01 FIX IHQ250228: "con una marcación [intensidad] para [biomarcador]" → POSITIVO
    # Formato: "con una marcación focal para EMA" o "con marcación difusa para X"
    # Interpretación: Biomarcador adicional con intensidad específica = POSITIVO
    # Contexto: Aparece después de lista principal, biomarcador separado con intensidad diferente
    # IMPORTANTE: Este patrón debe ejecutar ANTES de "Son negativas" para NO ser sobrescrito
    con_marcacion_pattern = r'(?i)con\s+(?:una\s+)?marcaci[óo]n\s+(focal|difusa|fuerte|d[eé]bil|moderada)\s+para\s+([A-Za-z0-9\s\-/]+?)(?=\.\s|\s+Son\s+negativas|,\s+|$)'
    for match in re.finditer(con_marcacion_pattern, text, re.DOTALL):
        intensidad = match.group(1).strip().upper()
        bio_raw = match.group(2).strip().rstrip('.,')

        logging.info(f"🔍 [V6.5.01 con marcación] Detectado: '{bio_raw}' intensidad: {intensidad}")

        normalized_name = normalize_biomarker_name(bio_raw)
        if normalized_name:
            # V6.5.01: PRIORIDAD ALTA - SIEMPRE sobrescribir (este patrón es muy específico)
            valor_anterior = results.get(normalized_name, '')
            if intensidad == 'FOCAL':
                results[normalized_name] = 'POSITIVO FOCAL'
            else:
                results[normalized_name] = 'POSITIVO'
            logging.info(f"✅ [con marcación] Extraído: '{bio_raw}' → {normalized_name} = {results[normalized_name]} (prev: {valor_anterior})")

    # V6.3.64 FIX IHQ250083: "Negativo para para CK20 Y GATA 3"
    # V6.3.76 FIX IHQ250105: Agregado "Linfocitos" y palabras no-biomarcador como terminadores
    # V6.4.87 FIX IHQ250217: Separador "y" case-insensitive (captura "y" minúscula y "Y" mayúscula)
    # V6.5.01 FIX IHQ250228: Lookahead mejorado para capturar hasta punto con saltos de línea + NO sobrescribe POSITIVOS
    # Formato: Negativo para [para] [lista] (nota: doble "para" es común en OCR)
    # Ej: "Negativo para CD 34, CD 23, CD 99 Linfocitos T..." → captura "CD 34, CD 23, CD 99"
    # Ej: "Son negativas para CK20, CDX2, TTF-1 y PAX-8" → captura todos incluyendo PAX-8
    # Ej: "Son negativas para...GLIPICAN, GATA 3, TTF-1,\nCEA." → captura todos incluyendo CEA después de \n
    negativo_para_pattern = r'(?i)negativ[oa]s?\s+para\s+(?:para\s+)?([A-Za-z0-9\s,.\-/\n]+?)(?=\s+Linfocitos|\s+células|\s+acompañantes|\.\s*[A-Z]|,\s+diagn[oó]stico|\s*$)'
    for match in re.finditer(negativo_para_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()
        logging.info(f"🔍 [V6.5.01 negativo/negativas para] Lista detectada: '{lista_biomarkers_raw}'")

        # V6.5.01: Limpiar saltos de línea para normalizar la lista
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # V6.4.87 FIX IHQ250217: Separar por "y"/"Y" (case-insensitive) y comas
        biomarcadores_encontrados = re.split(r'\s+[Yy]\s+|[,]\s*', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.,')
            if not bio_raw or len(bio_raw) < 2:
                continue
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                valor_anterior = results.get(normalized_name, '')
                # V6.5.01 FIX IHQ250228: NO sobrescribir POSITIVOS con NEGATIVO
                # Solo sobrescribir si NO existe o si era "NO MENCIONADO"
                if normalized_name not in results:
                    results[normalized_name] = 'NEGATIVO'
                    logging.info(f"✅ [V6.5.01 negativo/negativas para] Extraído: '{bio_raw}' → {normalized_name} = NEGATIVO")
                else:
                    logging.info(f"⏭️ [negativo/negativas] Skipping '{bio_raw}' → {normalized_name} (ya existe: {valor_anterior})")

    # V6.1.4: FIX IHQ251000 - NUEVOS patrones para formato narrativo hepático
    # 1. "marcación usual para [lista]" → POSITIVO
    # 2. "hay marcación positiva de [lista]" → POSITIVO (con "de" en vez de "para")
    # 3. "marcación para [biomarcador]" → POSITIVO (sin palabra positiva/negativa)

    # Patrón 1: "marcación usual para [lista]"
    # Ej: "presenta marcación usual para arginasa y Hepatocito"
    marcacion_usual_pattern = r'(?i)marcaci[óo]n\s+usual\s+para\s+(.+?)(?=,\s+hay|,\s+marcaci[óo]n|\.|$)'
    for match in re.finditer(marcacion_usual_pattern, text, re.DOTALL):
        lista_biomarkers_raw = match.group(1).strip()

        logging.info(f"🔍 [V6.1.4 marcación usual] Lista detectada: '{lista_biomarkers_raw}'")

        # Limpiar saltos de línea y normalizar espacios
        lista_biomarkers_raw = re.sub(r'\s*\n\s*', ' ', lista_biomarkers_raw)

        # Separar por "y" (no por comas en este contexto)
        biomarcadores_encontrados = re.split(r'\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.,')
