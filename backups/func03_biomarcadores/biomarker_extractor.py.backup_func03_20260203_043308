def extract_narrative_biomarkers_list(texto_microscopica: str, biomarker_definitions: dict = None, debug_mode: bool = False) -> Dict[str, str]:
    """Extrae biomarcadores de formato narrativo tipo LISTA en DESCRIPCIÓN MICROSCÓPICA.

    Versión: 6.0.3 - Corrección IHQ250982

    Reconoce patrones como:
    - "son positivas para CKAE1E3, CK7 Y CAM 5.2"
    - "positivas para GFAP, S100 y SOX10"
    - "expresan CK7, CK20 y TTF-1"
    - "muestran positividad para p16 y p40"

    NOTA: Esta función es COMPLEMENTARIA a extract_narrative_biomarkers() existente.
    - extract_narrative_biomarkers(): Patrones complejos tipo "RECEPTOR DE ESTRÓGENOS, positivo focal"
    - extract_narrative_biomarkers_list(): Listas tipo "positivas para X, Y, Z"

    Args:
        texto_microscopica: Texto de la sección DESCRIPCIÓN MICROSCÓPICA
        biomarker_definitions: Definiciones de biomarcadores (BIOMARKER_DEFINITIONS)

    Returns:
        Diccionario con biomarcadores detectados y valor POSITIVO
        Ejemplo: {'IHQ_CK7': 'POSITIVO', 'IHQ_CKAE1_AE3': 'POSITIVO'}

    Ejemplo:
        Input: "son positivas para CKAE1E3, CK7 Y CAM 5.2"
        Output: {'IHQ_CKAE1_AE3': 'POSITIVO', 'IHQ_CK7': 'POSITIVO', 'IHQ_CAM5': 'POSITIVO'}
    """
    if not texto_microscopica:
        return {}

    if biomarker_definitions is None:
        biomarker_definitions = BIOMARKER_DEFINITIONS

    resultados = {}

    # Patrones de formato narrativo tipo LISTA (ordenados por especificidad)
    # V6.0.4 FIX: Cambiado terminador para capturar TODA la lista, no solo el primer elemento
    # V6.0.5 FIX: Cambiado a greedy (+) y terminadores más específicos para capturar "CAM 5.2"
    # V6.0.5.1 FIX: Non-greedy para evitar capturar múltiples listas en una sola captura
    # V6.1.5 FIX IHQ251007: Agregado patrón "Hay positividad para celulas mioepiteliales X y Y"
    # Termina SOLO en: " y células" (con espacio antes de "y"), punto final, o fin de texto
    patrones_narrativo = [
        # V6.5.46 FIX IHQ250247: PRIORIDAD MÁXIMA - "Negativa para mioepitelio ([lista]) y [biomarcador]"
        # Formato: "Negativa para mioepitelio (CK5-6 y P63) y Sinaptofisina"
        # → CK5_6=NEGATIVO, P63=NEGATIVO, SINAPTOFISINA=NEGATIVO
        # CRÍTICO: "mioepitelio" es un contexto celular, los marcadores en paréntesis y después son NEGATIVOS
        # V6.5.76 FIX IHQ250277: Límite de longitud para prevenir catastrophic backtracking
        r'(?i)Negativ[oa]s?\s+para\s+(?:mioepitelio|células?\s+mioepiteliales?)\s+\(([^)]{1,150})\)(?:\s+y\s+([A-Za-z0-9\s,.\-]{1,200}))?',

        # V6.5.42 FIX IHQ250242: PRIORIDAD MÁXIMA - "Los demás marcadores [lista] son negativos"
        # Formato: "Los demás marcadores p40, vimentina, PAX 8 y receptor de estrógenos son negativos"
        # → p40=NEGATIVO, vimentina=NEGATIVO, PAX 8=NEGATIVO, receptor de estrógenos=NEGATIVO
        # CRÍTICO: Este patrón indica que marcadores listados aquí son NEGATIVOS mientras otros mencionados antes son POSITIVOS
        # V6.5.42: Patrón más restrictivo - captura SOLO después de "Los demás marcadores", no antes
        # Terminador: punto, fin de texto, o "Índice" (evita capturar Ki-67 después)
        # V6.5.76 FIX IHQ250277: Límite de longitud para prevenir catastrophic backtracking
        r'(?i)Los?\s+dem[aá]s\s+marcadores?\s+([A-Za-z0-9\s,./\-\(\)+yYeÉóÓáÁíÍúÚñÑ]{1,300}?)\s+son\s+negativ[oa]s?(?:\.|$|\s+[ÍI]ndice)',

        # V6.5.51 FIX IHQ250248: NUEVO - "Los siguientes marcadores son negativos: [lista]"
        # Formato: "Los siguientes marcadores son negativos: GATA3, Mamaglobina, SOX-10, CKAE1E3, desmin, CD34, EMA, p63, E-cadherina."
        # → GATA3=NEGATIVO, Mamaglobina=NEGATIVO, SOX-10=NEGATIVO, etc.
        # CRÍTICO: Lista exhaustiva de biomarcadores negativos (normalmente cuando todos los demás ya se reportaron)
        # Terminador: punto seguido de espacio/fin o fin de texto
        # V6.5.76 FIX IHQ250277: Límite de longitud para prevenir catastrophic backtracking
        r'(?i)Los?\s+siguientes?\s+marcadores?\s+son\s+negativ[oa]s?\s*:\s*([A-Za-z0-9\s,./\-\(\)+yYeÉóÓáÁíÍúÚñÑ]{1,300}?)(?:\.\s|\.?$)',

        # V6.5.57 FIX IHQ250254: NUEVO - "Sin marcación positiva para : [lista]"
        # Formato: "Sin marcación positiva para : DESMINA, WT1, RECEPTORES DE ESTROGENOS."
        # → DESMINA=NEGATIVO, WT1=NEGATIVO, RECEPTOR_ESTROGENOS=NEGATIVO
        # CRÍTICO: Indica ausencia de marcación (negativo) para biomarcadores listados
        # Terminador: punto seguido de espacio/fin o fin de texto
        # V6.5.76 FIX IHQ250277: Límite de longitud para prevenir catastrophic backtracking
        r'(?i)Sin\s+marcaci[óo]n\s+positiva\s+para\s*:\s*([A-Za-z0-9\s,./\-\(\)+yYeÉóÓáÁíÍúÚñÑ]{1,300}?)(?:\.\s|\.?$)',

        # V6.5.61 FIX IHQ250254: PRIORIDAD MÁXIMA - "componente [tipo] positivo para [lista] y el componente"
        # Formato bifásico: "un componente epitelial positivo para CKAE1/AE3, PAX 8, SALL 4 (focal), P53, EMA (focal) y el componente mesenquimal"
        # → CKAE1AE3=POSITIVO, PAX8=POSITIVO, SALL4=POSITIVO (FOCAL), P53=POSITIVO, EMA=POSITIVO (FOCAL)
        # CRÍTICO: Tumor bifásico con dos componentes celulares diferentes
        # Termina en "y el componente" para capturar SOLO la lista del primer componente
        # V6.5.76 FIX IHQ250277: Límite de longitud para prevenir catastrophic backtracking
        r'(?i)(?:un\s+)?componente\s+(?:epitelial|mesenquimal|escamoso|glandular|solid[oa])\s+positiv[oa]s?\s+para\s+([\w\s/.\-+()\n,]{1,400}?)\s+y\s+el\s+componente',

        # V6.4.3: NUEVO - "No hay representación de ... positivas para [lista]" (IHQ250127)
        # Este patrón es NEGATIVO y debe ser procesado con prioridad alta en listas
        r'(?i)no\s+hay\s+representaci[óo]n\s+de\s+[^.]+?positiv[ao]s?\s+para\s+([^.]+)',

        # V6.4.47 FIX IHQ250185: PRIORIDAD MÁXIMA - "son positivas para: [lista]" con DOS PUNTOS
        # V6.5.20 FIX IHQ250237: PRIORIDAD ABSOLUTA - Contexto mixto "positivo para X y es negativo para Y,Z,W"
        # V6.5.21 FIX: Corrección de espaciado - modificador opcional incluye su propio espacio
        # Formato: "es positivo focal para CKAE1/E3 y es negativo para GLYPICAN 3, AFP y CD 30"
        # → Grupo 1 (POSITIVOS): CKAE1/E3=POSITIVO
        # → Grupo 2 (NEGATIVOS): GLYPICAN3=NEGATIVO, AFP=NEGATIVO, CD30=NEGATIVO
        # DEBE IR EN PRIMER LUGAR para capturar contextos mixtos antes que patrones individuales
        # Evita que patrones posteriores interfieran y marquen incorrectamente los biomarcadores
        # Soporta modificadores como "focal", "fuerte", "difuso" en el contexto positivo
        # NOTA: Este patrón tiene 2 grupos de captura, requiere procesamiento especial
        # V6.5.76 FIX IHQ250277: Límites de longitud para prevenir catastrophic backtracking en listas largas
        r'(?i)(?:es|son)\s+positiv[ao]s?\s+(?:(?:focal|difuso|difusa|fuerte|d[eé]bil|moderado|moderada)\s+)?para\s+([A-Za-z0-9\s,./\-\(\)]{1,200}?)\s+y\s+(?:es|son)\s+negativ[ao]s?\s+para\s+([A-Za-z0-9\s,./\-\(\)+yYeÉóÓ\n]{1,500})(?:\.|\s*$)',

        # Formato: "Las células tumorales son positivas para: CK7, CAM 5.2, p53 sobre expresado, receptor de estrógenos y PAX 8"
        # CRÍTICO: Captura biomarcadores con múltiples palabras (receptor de estrógenos, p53 sobre expresado)
        # DEBE ejecutarse ANTES que patrones genéricos para evitar que capturen mal
        # FIX v6.4.48: Cambiado terminador de "\." a "\.\s" para evitar capturar punto interno (CAM 5.2)
        # V6.5.05 FIX IHQ250231: Eliminado "\s+con\s" - causaba truncamiento de "TTF-1 con tinción baja"
        r'(?i)positiv[oa]s?\s+para:\s+(.+?)(?:\.\s|\s+las\s+células\s+tumorales)',

        # V6.5.16 FIX IHQ250238: PRIORIDAD MÁXIMA - "inmunomarcación positiva...para [contexto] ([LISTA])"
        # Formato: "inmunomarcación positiva y difusa para marcador de células basales (p63, CK5/6, CK34 B E12)"
        # → P63=POSITIVO, CK5/6=POSITIVO, CK34 B E12=POSITIVO (todos positivos)
        # Captura lista de biomarcadores dentro de paréntesis después de contexto descriptivo
        # Contexto puede ser: "marcador de células basales", "células mioepiteliales", etc.
        r'(?i)inmunomarcaci[óo]n\s+positiva(?:\s+y\s+(?:difusa|focal|fuerte|d[eé]bil))?\s+para\s+.+?\s+\(([A-Za-z0-9\s,./\-]+?)\)',

        # V6.5.80 FIX IHQ250270: PRIORIDAD MÁXIMA - "positividad heterogénea para [LISTA]"
        # Formato: "Las células tumorales presentan positividad heterogénea para CKAE1AE3, inhibina y calretinina"
        # → CKAE1AE3=POSITIVO HETEROGÉNEO, INHIBINA=POSITIVO HETEROGÉNEO, CALRETININA=POSITIVO HETEROGÉNEO
        # CRÍTICO: "heterogénea" indica expresión variable/parcial pero positiva
        # Termina en punto seguido de espacio/mayúscula (inicio nueva frase) o fin de texto
        # Permite variantes: "positividad heterogénea", "positividad heterogenea" (sin tilde)
        r'(?i)positividad\s+heterog[eé]nea\s+para\s+([A-Za-z0-9\s,./\-yY]+?)(?:\.\s+[A-Z]|\.\s*$|$)',

        # V6.4.47 FIX IHQ250185: PRIORIDAD MÁXIMA - "son negativos para: [lista]" con DOS PUNTOS
        # Formato: "las células tumorales son negativos para: p40, CK 20, vimentina, RCC"
        # FIX v6.4.48: Cambiado terminador para capturar hasta punto seguido de espacio o fin de línea
        r'(?i)negativ[oa]s?\s+para:\s+(.+?)(?:\.\s|$|\s+con\s)',

        # V6.4.48 FIX IHQ250186: PRIORIDAD MÁXIMA - "Bajo la tinción de [BIOMARCADORES] se reconocen linfocitos T acompañantes"
        # Formato: "Bajo la tinción de CD3 Y CD5 se reconocen linfocitos T acompañantes"
        # → CD3=POSITIVO, CD5=POSITIVO (linfocitos T detectados con estos marcadores)
        # CRÍTICO: Biomarcadores aparecen ANTES de "se reconocen linfocitos T", patrón inverso al de línea 7485
        # Nota: OCR puede escribir "lincitos" (error tipográfico común)
        r'(?i)tinci[óo]n\s+de\s+([A-Z0-9\s,yYeE]+?)\s+se\s+reconocen\s+lin[fc]itos?\s+T\s+acompa[ñn]antes',

        # V6.4.49 FIX IHQ250188: PRIORIDAD MÁXIMA - "con positividad para [X] de manera [intensidad] y [patrón]"
        # Formato: "con positividad para Glypican-3 de manera fuerte y difuso"
        # → Glypican-3 = POSITIVO (expresión fuerte y difusa)
        # Captura biomarcador individual con intensidad y patrón descriptivo
        # Termina en coma para capturar solo el primer biomarcador antes de la lista siguiente
        r'(?i)con\s+positividad\s+para\s+([A-Za-z0-9\s\-]+?)\s+de\s+manera\s+(?:fuerte|d[eé]bil|moderada)(?:\s+y\s+(?:difuso|difusa|focal))?,',

        # V6.4.49 FIX IHQ250188: PRIORIDAD MÁXIMA - "con [LISTA] positivo [intensidad]"
        # V6.4.51 FIX: Agregado lookahead negativo (?!positividad) para evitar captura greedy
        # Formato: "con Hepar-1, Arginasa y AFP positivo focal"
        # → Hepar-1=POSITIVO, Arginasa=POSITIVO, AFP=POSITIVO (todos focales)
        # Captura lista de biomarcadores después de "con" con "positivo [intensidad]" al final
        # Permite guiones en nombres (Hepar-1, CD3-5, etc.)
        # CRÍTICO: (?!positividad) evita capturar "con positividad para..." (línea 7509)
        r'(?i)con\s+(?!positividad)([A-Za-z0-9\s,\-yY]+?)\s+positivo\s+(?:focal|difuso|difusa|fuerte|d[eé]bil|moderada)',

        # V6.3.61 FIX IHQ250076: "positivas de manera fuerte y difusa for CK7, PAX-8, Vimentina"
        # Captura lista de biomarcadores después de "positivas de manera [intensidad] para"
