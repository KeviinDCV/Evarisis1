        r'positiv[oa]s?(?:\s+\w+){0,10}\s+para\s+((?:(?!y\s+con\b|con\s+positividad|con\s+marcaci)[\w\s/.\-+()\n]+)+(?:\s+(?:y|e|,)\s+(?:(?!y\s+con\b|con\s+positividad|con\s+marcaci)[\w\s/.\-+()\n]+)+)*)',
        # V6.3.87 FIX IHQ250112: "el ki 67 es positivo en todo el espesor..."
        r'el\s+([\w\s-]+?)\s+es\s+positivo(?:\s+\w+){0,10}',
        
        # V6.3.88 FIX IHQ250113: "marcación en mosaico de estrógenos" (preposición DE)
        r'marcaci[óo]n(?:\s+\w+){1,10}\s+de\s+((?:(?!y\s+con\b|con\s+positividad|con\s+marcaci)[\w\s/.\-])+(?:\s+(?:y|e|,)\s+(?:(?!y\s+con\b|con\s+positividad|con\s+marcaci)[\w\s/.\-])+)*)',
        
        # Patrón: "linfocitos positivos para CD20 y PAX5" - captura lista con "y"
        r'linfocitos\s+positivos\s+para\s+([A-Z0-9]+(?:\s+y\s+[A-Z0-9]+)+)',

        # V6.0.22: Nuevos patrones para casos hematológicos/linfomas (IHQ251009)
