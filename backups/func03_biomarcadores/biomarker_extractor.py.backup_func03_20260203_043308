    # ═══════════════════════════════════════════════════════════════════════
    # V6.0.12: ESTRATEGIA MULTI-BÚSQUEDA SIN CORTAR TEXTO (IHQ250984)
    # ═══════════════════════════════════════════════════════════════════════
    # LECCIÓN APRENDIDA de v6.0.11:
    # - NO cortar el texto (elimina información necesaria en páginas posteriores)
    # - SÍ buscar con patrones específicos que distingan entre:
    #   * Sección técnica: "Anticuerpos: [nombres de reactivos]"
    #   * Sección de resultados: "REPORTE DE BIOMARCADORES: [resultados]"
    #
    # ESTRATEGIA:
    # 1. Buscar primero en secciones específicas (REPORTE, Expresión molecular)
    # 2. Buscar con patrones que filtren contexto técnico
    # 3. Usar texto completo solo como último recurso
    # ═══════════════════════════════════════════════════════════════════════

    results = {}

    # V6.3.74 FIX IHQ250102: MÁXIMA PRIORIDAD - ER/PR con intensidad+porcentaje
    # Buscar PRIMERO en descripción microscópica: "Expresión de receptores de X: Marcación nuclear fuerte y positiva del Y%"
    # Estos valores tienen precedencia sobre cualquier otro método de extracción
    seccion_micro = extraer_seccion(text, r"DESCRIPCI[ÓO]N\s+MICROSC[ÓO]PICA", r"DIAGN[ÓO]STICO|EXPRESI[ÓO]N\s+MOLECULAR|RESPONSABLE")
    if seccion_micro:
        # V6.3.96 FIX IHQ250117: Patrón de intensidad + porcentaje (variante POSITIVO INTENSIDAD ...)
        patron_er_v2 = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+estr[oó]geno[s]?\s*:\s*\n?\s*-\s*(POSITIV[OA]S?|NEGATIV[OA]S?)\s*\(\s*INTENSIDAD\s+(fuerte|moderada|d[eé]bil)\s+EN\s+EL\s+(\d+)\s*%\s+'
        match_er_v2 = re.search(patron_er_v2, seccion_micro)
        if match_er_v2:
            estado = match_er_v2.group(1).upper()
            intensidad = match_er_v2.group(2).upper().replace('É', 'E')
            porcentaje = match_er_v2.group(3)
            results['ER'] = f"{estado} (NUCLEAR {intensidad} {porcentaje}%)"

        # Patrón ER con intensidad + porcentaje original
        patron_er = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+estr[oó]geno[s]?\s*:\s*Marcaci[oó]n\s+nuclear\s+(fuerte|moderada|d[eé]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'
        match_er = re.search(patron_er, seccion_micro)
        if match_er and 'ER' not in results:
            intensidad = match_er.group(1).upper().replace('É', 'E')
            porcentaje = match_er.group(2)
            results['ER'] = f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

        # V6.3.96 FIX IHQ250117: Patrón PR v2
        patron_pr_v2 = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+progesterona\s*:\s*\n?\s*-\s*(POSITIV[OA]S?|NEGATIV[OA]S?)\s*\(\s*INTENSIDAD\s+(fuerte|moderada|d[eé]bil)\s+EN\s+EL\s+(\d+)\s*%\s+'
        match_pr_v2 = re.search(patron_pr_v2, seccion_micro)
        if match_pr_v2:
            estado = match_pr_v2.group(1).upper()
            intensidad = match_pr_v2.group(2).upper().replace('É', 'E')
            porcentaje = match_pr_v2.group(3)
            results['PR'] = f"{estado} (NUCLEAR {intensidad} {porcentaje}%)"

        # Patrón PR con intensidad + porcentaje original
        patron_pr = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+progesterona\s*:\s*Marcaci[oó]n\s+nuclear\s+(fuerte|moderada|d[eé]bil)\s+y\s+positiva\s+del?\s*(\d+)\s*%'
        match_pr = re.search(patron_pr, seccion_micro)
        if match_pr and 'PR' not in results:
            intensidad = match_pr.group(1).upper().replace('É', 'E')
            porcentaje = match_pr.group(2)
            results['PR'] = f"POSITIVO (NUCLEAR {intensidad} {porcentaje}%)"

        # V6.3.96 FIX IHQ250117: Patrón HER2 con dash
        patron_her2_dash = r'(?i)Sobreexpresi[oó]n\s+de\s+oncog[eé]n\s+HER2\s*:\s*\n?\s*-\s*(EQU[ÍI]VOCO|POSITIVO|NEGATIVO)\s*\((?:Score\s+)?(\d+\+?)\)'
        match_her2 = re.search(patron_her2_dash, seccion_micro)
        if match_her2:
            estado = match_her2.group(1).upper().replace('Í', 'I')
            score = match_her2.group(2)
            results['HER2'] = f"{estado} (Score {score})"

        # V6.5.63 FIX IHQ250258: PRIORIDAD ALTA - ER/PR con formato "- NEGATIVO (MENOR AL 1%)"
        # Formato: "Expresión de receptores de estrógeno:\n- NEGATIVO (MENOR AL 1%)."
        # V6.5.64 FIX: Dos puntos `:` opcional (OCR a veces lo omite en progesterona)
        # V6.5.65 FIX: Usar [ \t]* (espacios/tabs) en lugar de \s* para NO consumir \n
        # V6.5.66 FIX: SIEMPRE sobrescribir (sin 'ER/PR not in results') porque este patrón es MÁS ESPECÍFICO
        # V6.5.67 FIX IHQ250258: Paréntesis OPCIONALES - Captura ambos formatos:
        #   - "NEGATIVO (MENOR AL 1%)" (con paréntesis)
        #   - "NEGATIVO MENOR AL 1%" (sin paréntesis - OCR IHQ250258)
        # V6.5.67 FIX IHQ250258: Paréntesis OPCIONALES - Captura ambos formatos:
        #   - "NEGATIVO (MENOR AL 1%)" (con paréntesis)
        #   - "NEGATIVO MENOR AL 1%" (sin paréntesis - OCR IHQ250258)
        # Problema: \s* incluye \n, causando que \n? nunca haga match
        # Normalizar "MENOR AL 1%" → "<1%", "MENOR AL 5%" → "<5%"
        patron_er_menor = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+estr[oó]geno[s]?[ \t]*:?[ \t]*\n?[ \t]*-[ \t]*(NEGATIV[OA]S?|POSITIV[OA]S?)\s*\(?\s*MENOR\s+AL?\s+(\d+)\s*%\s*\)?'
        match_er_menor = re.search(patron_er_menor, seccion_micro)
        if match_er_menor:
            estado = match_er_menor.group(1).upper()
            porcentaje = match_er_menor.group(2)
            results['ER'] = f"{estado} (<{porcentaje}%)"
            logging.info(f"✅ [ER MENOR v6.5.67] Extraído: {results['ER']}")

        patron_pr_menor = r'(?i)expresi[oó]n\s+de\s+receptores?\s+de\s+progesterona[ \t]*:?[ \t]*\n?[ \t]*-[ \t]*(NEGATIV[OA]S?|POSITIV[OA]S?)\s*\(?\s*MENOR\s+AL?\s+(\d+)\s*%\s*\)?'
        match_pr_menor = re.search(patron_pr_menor, seccion_micro)
        if match_pr_menor:
            estado = match_pr_menor.group(1).upper()
            porcentaje = match_pr_menor.group(2)
            results['PR'] = f"{estado} (<{porcentaje}%)"
            logging.info(f"✅ [PR MENOR v6.5.67] Extraído: {results['PR']}")

    # PRIORIDAD 0: Extraer sección "REPORTE DE BIOMARCADORES:" (IHQ250984)
    # Esta sección contiene resultados en formato estructurado con guiones
    biomarker_report_section = None
    match_reporte = re.search(
        r'(?:REPORTE\s+DE\s+BIOMARCADORES?|RESULTADOS?):\s*(.+?)(?=DIAGN[ÓO]STICO|$)',
        text,
        re.IGNORECASE | re.DOTALL
    )
    if match_reporte:
        biomarker_report_section = match_reporte.group(1)

    # v6.0.2: PRIORIDAD 1 - Extraer sección "Expresión molecular" (caso IHQ250981)
    molecular_section = extract_molecular_expression_section(text)

    # v5.3.1: PRIORIDAD 2 - Extraer sección REPORTE (descripción microscópica)
    report_section = extract_report_section(text)

    # V6.4.71 FIX IHQ250205: Filtrar microambiente y macroscópica de TODAS las secciones ANTES de procesar
    # ====================================================================================================
    # El microambiente describe células acompañantes normales que NO deben reportarse
    # La macroscópica contiene estudios SOLICITADOS que NO son resultados
    def filtrar_secciones_no_resultado(texto: str) -> str:
        """Elimina secciones que NO contienen resultados (microambiente, macroscópica)"""
        if not texto:
            logging.info(f"⚠️ [FILTRO v6.4.72] Filtro llamado con texto VACÍO, retornando sin filtrar")
            return texto

        # DEBUG: Mostrar si el texto contiene CD4 o CD7 ANTES del filtro
        tiene_cd4_antes = 'CD4' in texto or 'CD 4' in texto
        tiene_cd7_antes = 'CD7' in texto or 'CD 7' in texto
        if tiene_cd4_antes or tiene_cd7_antes:
            logging.info(f"🟡 [FILTRO v6.4.72 DEBUG] ANTES del filtro: texto contiene CD4={tiene_cd4_antes}, CD7={tiene_cd7_antes}, len={len(texto)}")

        texto_filtrado = texto

        # V6.4.72 FIX IHQ250205: Filtro 1 MEJORADO - Microambiente (células acompañantes normales)
        # Patrón mejorado que captura TODA la oración hasta el punto final (usando .+? con DOTALL)
        # Esto asegura capturar TODO el microambiente incluso con saltos de línea y paréntesis internos
        # V6.5.76 FIX IHQ250277: Límite de 600 caracteres para prevenir catastrophic backtracking
        microambiente_pattern = r'(?i)(?:El\s+)?(?:micro[\s-]?ambiente\s+acompa[ñn]ante|componente\s+inflamatorio|infiltrado\s+inflamatorio|poblaci[oó]n\s+acompa[ñn]ante).{1,600}?\.\s*(?=[A-Z]|$)'
        for match in re.finditer(microambiente_pattern, texto_filtrado, re.DOTALL):
            microambiente_text = match.group(0)
            texto_filtrado = texto_filtrado.replace(microambiente_text, " [MICROAMBIENTE FILTRADO] ")
            logging.info(f"🔵 [FILTRO v6.4.72] Microambiente excluido: {microambiente_text[:100]}...")

        # Filtro 2: Descripción macroscópica (estudios solicitados, NO resultados)
        # Formato: "se realizan cortes... para los siguientes marcadores: CD2, CD3, CD4..."
        macro_pattern = r'(?i)(?:se\s+realiz[ao]n?\s+(?:estudios?|cortes?)[^.]*?para\s+los?\s+siguientes?\s+marcadores?[^.]+\.)'
        for match in re.finditer(macro_pattern, texto_filtrado, re.DOTALL):
            macro_text = match.group(0)
            texto_filtrado = texto_filtrado.replace(macro_text, " [ESTUDIOS SOLICITADOS FILTRADO] ")
            logging.info(f"🔵 [FILTRO v6.4.71] Estudios solicitados (macro) excluidos: {macro_text[:100]}...")

        # V6.4.89 FIX IHQ250218: Filtro adicional para "se realizan niveles histológicos para tinción con: [LISTA]"
        # Formato: "se realizan niveles histológicos para tinción con: Ki67, BCL2, BCL6, CD3, CD5..."
        # Este es un listado de estudios SOLICITADOS, NO de resultados
        macro_tincion_pattern = r'(?i)se\s+realiz[ao]n?\s+niveles?\s+histol[óo]gicos?\s+para\s+tinci[óo]n\s+con:?\s+[^.]+\.'
        for match in re.finditer(macro_tincion_pattern, texto_filtrado, re.DOTALL):
            macro_text = match.group(0)
            texto_filtrado = texto_filtrado.replace(macro_text, " [ESTUDIOS SOLICITADOS FILTRADO] ")
            logging.info(f"🔵 [FILTRO v6.4.89] Estudios solicitados (niveles histológicos) excluidos: {macro_text[:100]}...")

        # DEBUG: Mostrar si el texto contiene CD4 o CD7 DESPUÉS del filtro
        tiene_cd4_despues = ('CD4' in texto_filtrado or 'CD 4' in texto_filtrado) and '[FILTRADO]' not in texto_filtrado
        tiene_cd7_despues = ('CD7' in texto_filtrado or 'CD 7' in texto_filtrado) and '[FILTRADO]' not in texto_filtrado
        if (tiene_cd4_antes or tiene_cd7_antes) and (tiene_cd4_despues or tiene_cd7_despues):
            logging.warning(f"⚠️ [FILTRO DEBUG] DESPUÉS del filtro: CD4 TODAVÍA presente={tiene_cd4_despues}, CD7 TODAVÍA presente={tiene_cd7_despues}")
            logging.warning(f"⚠️ [FILTRO DEBUG] Texto filtrado (primeros 300 chars): {texto_filtrado[:300]}")

        return texto_filtrado

    # Aplicar filtros a todas las secciones
    biomarker_report_section = filtrar_secciones_no_resultado(biomarker_report_section)
    molecular_section = filtrar_secciones_no_resultado(molecular_section)
    report_section = filtrar_secciones_no_resultado(report_section)

    # Definir biomarcadores que deben priorizarse de "Expresión molecular"
    molecular_priority = ['ER', 'PR', 'HER2', 'RECEPTOR_ESTROGENOS', 'RECEPTOR_PROGESTERONA']

    # V6.0.12: NUEVA CASCADA DE BÚSQUEDA (sin cortar texto)
    # Buscar en orden de especificidad: REPORTE > Molecular > report_section > texto completo

    # PRIORIDAD 0: Buscar en "REPORTE DE BIOMARCADORES:" (formato estructurado IHQ250984)
    if biomarker_report_section:
        narrative_results = extract_narrative_biomarkers(biomarker_report_section, debug_mode=debug_mode)
        results.update(narrative_results)
        # V6.2.6: Agregar extracción de listas narrativas (IHQ251026)
        list_results = extract_narrative_biomarkers_list(biomarker_report_section)
        # V6.3.50: FIX IHQ250052 - NO sobrescribir valores ya detectados (ej: "Son negativas para CK 7 y CD 117")
        # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es más específico (tiene calificador individual)
        for key, value in list_results.items():
            valor_anterior = results.get(key, '')
            # Sobrescribir si:
            # 1. No existe valor anterior
            # 2. Valor nuevo tiene paréntesis (calificador) Y valor anterior NO (es más específico)
            if key not in results or ('(' in value and '(' not in valor_anterior):
                results[key] = value

    # PRIORIDAD 1: Buscar en "Expresión molecular" (IHQ250981)
    if molecular_section:
        narrative_results = extract_narrative_biomarkers(molecular_section)
        # Solo actualizar si no encontró antes
        for key, value in narrative_results.items():
            if key not in results:
                results[key] = value
        # V6.2.6: Agregar extracción de listas narrativas (IHQ251026)
        list_results = extract_narrative_biomarkers_list(molecular_section)
        # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es más específico
        for key, value in list_results.items():
            valor_anterior = results.get(key, '')
            if key not in results or ('(' in value and '(' not in valor_anterior):
                results[key] = value

    # PRIORIDAD 2: Buscar en sección REPORTE (descripción microscópica)
    if report_section:
        narrative_results = extract_narrative_biomarkers(report_section, debug_mode=debug_mode)
        for key, value in narrative_results.items():
            if key not in results:
                results[key] = value
        # V6.2.6: Agregar extracción de listas narrativas (IHQ251026)
        list_results = extract_narrative_biomarkers_list(report_section)
        # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es más específico
        for key, value in list_results.items():
            valor_anterior = results.get(key, '')
            if key not in results or ('(' in value and '(' not in valor_anterior):
                results[key] = value

    # PRIORIDAD 3: Buscar en texto completo (SIEMPRE ejecutar para capturar patrones narrativos)
    # V6.3.92 FIX IHQ250114: Filtrar sección MACROSCÓPICA del texto completo para evitar falsos positivos
    # de marcadores solicitados (pedidos) detectados como resultados.
    # V6.4.71: Filtrar también MICROAMBIENTE y estudios solicitados
    text_for_full_search = text
    macro_section = extraer_seccion(text, r"DESCRIPCI[ÓO]N\s+MACROSC[ÓO]PICA", r"DESCRIPCI[ÓO]N\s+MICROSC[ÓO]PICA|DIAGN[ÓO]STICO|EXPRESI[ÓO]N\s+MOLECULAR")
    if macro_section:
        text_for_full_search = text.replace(macro_section, "[MACROSCÓPICA FILTRADA]")
    # Aplicar filtros de microambiente y estudios solicitados
    text_for_full_search = filtrar_secciones_no_resultado(text_for_full_search)

    narrative_results = extract_narrative_biomarkers(text_for_full_search, debug_mode=debug_mode)
    for key, value in narrative_results.items():
        if key not in results:
            results[key] = value
    # V6.2.6: Agregar extracción de listas narrativas (IHQ251026)
    list_results = extract_narrative_biomarkers_list(text_for_full_search, BIOMARKER_DEFINITIONS, debug_mode=debug_mode)
    # V6.4.65 FIX IHQ250203: SOBRESCRIBIR si valor nuevo es más específico
    for key, value in list_results.items():
        valor_anterior = results.get(key, '')
        if key not in results or ('(' in value and '(' not in valor_anterior):
            results[key] = value

    # Procesar cada biomarcador definido en configuración (método original)
    for biomarker_name, definition in BIOMARKER_DEFINITIONS.items():
        # V6.5.47 FIX IHQ250247: ER/PR SIEMPRE se procesan con patrones específicos (para capturar porcentaje)
        # Solo procesar si no fue encontrado por método narrativo (excepto ER/PR/SV40/C4D/CK5_6 que siempre se re-procesan)
        # V6.5.90 FIX IHQ250275: SV40 y C4D siempre reprocesan para capturar resultado real ("encontrándose ambos negativos")
        # V6.5.91 FIX IHQ250276: CK5_6 siempre reprocesa (mismo problema: narrativo captura solicitud "para tinción con CK 5/6", no resultado)
        # Problema: Patrones narrativos capturan mención en descripción macroscópica ("para SV40 y C4d" / "para tinción con CK 5/6") → asumen POSITIVO
        # Solución: Forzar reprocesamiento con patrones específicos que capturan resultado ("encontrándose ambos negativos" / "CK 5/6 negativa para mioepiteliales")
        if biomarker_name not in results or biomarker_name in ['ER', 'PR', 'SV40', 'C4D', 'CK5_6']:
            value = None

            # V6.5.90 DEBUG: Log para SV40 y C4D
            if biomarker_name in ['SV40', 'C4D']:
                logging.info(f"🔍 [V6.5.90 DEBUG] Procesando {biomarker_name}, valor previo: {results.get(biomarker_name, 'NO EXISTE')}")

            # V6.0.12: Cascada de búsqueda específica
            # PRIORIDAD 0: Buscar en "REPORTE DE BIOMARCADORES:"
            if biomarker_report_section:
                value = extract_single_biomarker(biomarker_report_section, biomarker_name, definition)

            # PRIORIDAD 1: Buscar en "Expresión molecular"
            if not value and biomarker_name.upper() in molecular_priority and molecular_section:
                value = extract_single_biomarker(molecular_section, biomarker_name, definition)

            # PRIORIDAD 2: Buscar en sección REPORTE
            if not value and report_section:
                value = extract_single_biomarker(report_section, biomarker_name, definition)

            # PRIORIDAD 3: Buscar en texto completo filtrado (fallback)
            if not value:
                value = extract_single_biomarker(text_for_full_search, biomarker_name, definition)

            # V6.4.19 FIX IHQ250159: NO sobrescribir valores válidos de patrones narrativos
            # Si extract_narrative_biomarkers() ya extrajo POSITIVO/NEGATIVO, no sobrescribir con N/A
            # V6.5.47 FIX IHQ250247: Sobrescribir si nuevo valor tiene más detalle (porcentaje)
            if value:
                valor_anterior = results.get(biomarker_name, '')
                # Detectar si el nuevo valor tiene más información (porcentaje) que el anterior
                tiene_porcentaje_nuevo = '(' in value and '%' in value
                tiene_porcentaje_anterior = '(' in valor_anterior and '%' in valor_anterior

                # V6.5.90 DEBUG: Log para SV40 y C4D
                if biomarker_name in ['SV40', 'C4D']:
                    logging.info(f"🔍 [V6.5.90 DEBUG] {biomarker_name} nuevo valor: {value}, anterior: {valor_anterior}")

                # Sobrescribir si:
                # 1. No existe valor anterior, o
                # 2. Valor anterior es N/A o vacío, o
                # 3. (ER/PR) Nuevo valor tiene porcentaje y el anterior no, o
                # 4. (SV40/C4D/CK5_6) Siempre sobrescribir (v6.5.90+: forzar resultado real sobre mención en macroscópica)
                if biomarker_name not in results or \
                   valor_anterior in ['NO MENCIONADO', 'N/A', ''] or \
                   (biomarker_name in ['ER', 'PR'] and tiene_porcentaje_nuevo and not tiene_porcentaje_anterior) or \
                   biomarker_name in ['SV40', 'C4D', 'CK5_6']:
                    results[biomarker_name] = value
                    # V6.5.90+ DEBUG: Log para SV40, C4D, CK5_6
                    if biomarker_name in ['SV40', 'C4D', 'CK5_6']:
                        logging.info(f"✅ [V6.5.91 DEBUG] {biomarker_name} SOBRESCRITO con {value}")

    # ═══════════════════════════════════════════════════════════════════════════════
    # V6.3.77 FIX IHQ250105: PASE FINAL EN FUNCIÓN PRINCIPAL
    # ═══════════════════════════════════════════════════════════════════════════════
    # Problema: Listas genéricas como "tinción con marcadores: CD20, CD79, CD34..."
    # marcan TODO como POSITIVO. Luego, aunque extract_narrative_biomarkers() detecta
    # NEGATIVO, la lógica "if key not in results" NO sobrescribe.
    #
    # Solución: Buscar patrones explícitos NEGATIVO en texto COMPLETO y sobrescribir.
    # ═══════════════════════════════════════════════════════════════════════════════

    # Patrón 1: "marcación negativa para X"
    final_neg_marcacion = re.findall(
        r'(?i)marcaci[óo]n\s+negativa\s+para\s+([A-Za-z0-9\s,\-]+?)(?=,\s*[Cc]on\s+marcaci[oó]n|\s+Linfocitos|\.\s|$)',
        text
    )
    for match in final_neg_marcacion:
        for bio in re.split(r'\s*,\s*', match.strip()):
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized and results.get(normalized) == 'POSITIVO':
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"🔴 [PASE FINAL extract_biomarkers v6.3.77] {normalized}: POSITIVO → NEGATIVO (marcación negativa)")

    # Patrón 2: "Negativo para X, Y, Z"
    final_neg_para = re.findall(
        r'(?i)(?:^|\.\s*)Negativo\s+para\s+([A-Za-z0-9\s,\-]+?)(?=\s+Linfocitos|\s+células|\s+acompañantes|\.\s|$)',
        text
    )
    for match in final_neg_para:
        for bio in re.split(r'\s*,\s*', match.strip()):
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized and results.get(normalized) == 'POSITIVO':
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"🔴 [PASE FINAL extract_biomarkers v6.3.77] {normalized}: POSITIVO → NEGATIVO (Negativo para)")

    # Patrón 3: "tienen marcación negativa para X"
    final_tienen_neg = re.findall(
        r'(?i)tienen\s+marcaci[óo]n\s+negativa\s+para\s+([A-Za-z0-9\s,\-]+?)(?=,\s*[Cc]on|\.\s|$)',
        text
    )
    for match in final_tienen_neg:
        for bio in re.split(r'\s*,\s*', match.strip()):
            bio = bio.strip()
            if bio:
                normalized = normalize_biomarker_name(bio)
                if normalized and results.get(normalized) == 'POSITIVO':
                    results[normalized] = 'NEGATIVO'
                    logging.info(f"🔴 [PASE FINAL extract_biomarkers v6.3.77] {normalized}: POSITIVO → NEGATIVO (tienen marcación negativa)")

    # Patrón 4: V6.4.30 FIX IHQ250164: "negativa con el X, Y, Z"
    # Formato: "es positiva para CD20, PAX-5 Y BCL-2, y negativa con el CD5, CD10, BCL6, IgD, SOX -11 y Ciclyna D1"
    final_neg_con_el = re.findall(
        r'(?i)negativ[oa]s?\s+con(?:\s+el)?\s+([A-Za-z0-9\s,\-]+?)(?=;|\.|$)',
        text
    )
    for match in final_neg_con_el:
        # Separar por comas y "y"
        for bio in re.split(r'\s*,\s*|\s+y\s+', match.strip()):
            bio = bio.strip()
            # Limpiar "el" al inicio
            bio = re.sub(r'(?i)^el\s+', '', bio)
            if bio and len(bio) > 1:
                normalized = normalize_biomarker_name(bio)
                if normalized:
                    # V6.4.31 FIX IHQ250164: Asignar NEGATIVO sin condición previa (autoridad absoluta)
                    valor_previo = results.get(normalized, 'N/A')
                    results[normalized] = 'NEGATIVO'
                    if valor_previo and valor_previo != 'N/A':
                        logging.info(f"🔴 [PASE FINAL v6.4.31] {normalized}: {valor_previo} → NEGATIVO (negativa con el)")
                    else:
                        logging.info(f"🔴 [PASE FINAL v6.4.31] {normalized} = NEGATIVO (negativa con el)")

    # ═══════════════════════════════════════════════════════════════════════════════
    # V6.5.43 FIX IHQ250242: PASE FINAL "Los demás marcadores... son negativos"
    # ═══════════════════════════════════════════════════════════════════════════════
    # Problema: extract_single_biomarker() sobrescribe valores de main diagnosis con valores de regiones secundarias
    # Ejemplo: P40 POSITIVO (región exocervical) sobrescribe P40 NEGATIVO (main diagnosis endocervical)
    # Solución: PASE FINAL con PRIORIDAD ABSOLUTA para "Los demás marcadores... son negativos"
    # Este patrón se ejecuta AL FINAL y sobrescribe CUALQUIER valor previo
    # ═══════════════════════════════════════════════════════════════════════════════

    final_demas_marcadores = re.finditer(
        r'(?i)Los?\s+dem[aá]s\s+marcadores?\s+([A-Za-z0-9\s,./\-\(\)+yYeÉóÓáÁíÍúÚñÑ]+?)\s+son\s+negativ[oa]s?(?:\.|$|\s+[ÍI]ndice)',
        text
    )

    for match in final_demas_marcadores:
        lista_negativos = match.group(1).strip()
        # Filtrar matches que contengan "positivo" (patrón genérico capturando demasiado)
        if 'POSITIVO' in lista_negativos.upper():
            continue

        logging.info(f"🔴 [PASE FINAL v6.5.43] 'Los demás marcadores' detected: '{lista_negativos[:80]}...'")

        # Procesar lista de NEGATIVOS con SOBRESCRITURA ABSOLUTA
        for bio_negativo in re.split(r'[,\s]+y\s+|\s+y\s+|,\s*', lista_negativos):
            bio_negativo = bio_negativo.strip()
            if bio_negativo:
                normalized = normalize_biomarker_name(bio_negativo)
                if normalized:
                    valor_previo = results.get(normalized, 'N/A')
                    results[normalized] = 'NEGATIVO'
                    if valor_previo and valor_previo != 'N/A' and valor_previo != 'NEGATIVO':
                        logging.info(f"   🔴 SOBRESCRITO: {normalized}: {valor_previo} → NEGATIVO (main diagnosis)")
                    else:
                        logging.info(f"   ✅ Asignado: {normalized} = NEGATIVO")

    # ═══════════════════════════════════════════════════════════════════════════════
    # V6.4.9 FIX IHQ250141: POST-PROCESAMIENTO KAPPA/LAMBDA IMPLÍCITO
    # ═══════════════════════════════════════════════════════════════════════════════
    # Lógica: En casos de neoplasias de células plasmáticas/mieloma múltiple
    # - Si hay RESTRICCIÓN de KAPPA → LAMBDA es implícitamente NEGATIVO
    # - Si hay RESTRICCIÓN de LAMBDA → KAPPA es implícitamente NEGATIVO
    # ═══════════════════════════════════════════════════════════════════════════════

    if 'KAPPA' in results:
        kappa_value = results.get('KAPPA', '')
        # Si KAPPA tiene "restricción" o es POSITIVO → Lambda es NEGATIVO
        if 'restricción' in kappa_value.lower() or kappa_value.upper().startswith('POSITIVO'):
            if 'LAMBDA' not in results:
                results['LAMBDA'] = 'NEGATIVO'
                logging.info(f"✅ [POST-PROCESAMIENTO v6.4.9] LAMBDA = NEGATIVO (implícito por restricción KAPPA)")

    if 'LAMBDA' in results:
        lambda_value = results.get('LAMBDA', '')
        # Si LAMBDA tiene "restricción" o es POSITIVO → Kappa es NEGATIVO
        if 'restricción' in lambda_value.lower() or lambda_value.upper().startswith('POSITIVO'):
            if 'KAPPA' not in results:
                results['KAPPA'] = 'NEGATIVO'
                logging.info(f"✅ [POST-PROCESAMIENTO v6.4.9] KAPPA = NEGATIVO (implícito por restricción LAMBDA)")

    # ═══════════════════════════════════════════════════════════════════════════════
    # V6.4.72 FIX IHQ250205: Asignar "NO MENCIONADO" solo a biomarcadores solicitados
    # ═══════════════════════════════════════════════════════════════════════════════
    # Extraer estudios solicitados del texto
    # V6.5.76 FIX IHQ250277: Límite de 300 caracteres para prevenir catastrophic backtracking
    estudios_pattern = r'(?i)(?:se\s+realiz[ao]n?\s+(?:estudios?|cortes?)[^.]*?para\s+los?\s+siguientes?\s+marcadores?)[:\s]+([^.]{1,300})\.'
    match_estudios = re.search(estudios_pattern, text, re.DOTALL)

    if match_estudios:
        estudios_text = match_estudios.group(1)
        # Separar por comas y normalizar
        biomarcadores_solicitados = re.split(r'[,;]\s*|\s+y\s+', estudios_text)

        for bio_solicitado in biomarcadores_solicitados:
            bio_solicitado = bio_solicitado.strip().rstrip('.')
            if not bio_solicitado or len(bio_solicitado) < 2:
                continue

            # Normalizar nombre
            bio_normalizado = normalize_biomarker_name(bio_solicitado)

            # Si está en BIOMARKER_DEFINITIONS pero NO en results, asignar "NO MENCIONADO"
            if bio_normalizado and bio_normalizado in BIOMARKER_DEFINITIONS and bio_normalizado not in results:
                results[bio_normalizado] = 'NO MENCIONADO'
                logging.info(f"ℹ️ [V6.4.72] {bio_normalizado} = NO MENCIONADO (solicitado pero no encontrado)")

    # ═══════════════════════════════════════════════════════════════════════════════
    # V6.5.50 FIX IHQ250247: SINCRONIZAR valores IHQ_* → claves sin prefijo
    # ═══════════════════════════════════════════════════════════════════════════════
    # PROBLEMA: extract_narrative_biomarkers_list() crea claves "IHQ_CK5_6" (CORRECTO: NEGATIVO)
    #           pero extract_single_biomarker() crea claves "CK5_6" (INCORRECTO: POSITIVO)
    #           unified_extractor.py usa claves sin prefijo, así que obtiene valores incorrectos
    # SOLUCIÓN: Copiar valores de IHQ_* → claves sin prefijo (cuando IHQ_* tiene valor más confiable)
    # ═══════════════════════════════════════════════════════════════════════════════
    for key in list(results.keys()):
        if key.startswith('IHQ_'):
            # Extraer nombre base del biomarcador (quitar IHQ_ y _ESTADO)
            bio_base = key.replace('IHQ_', '').replace('_ESTADO', '')

            # Si existe clave sin prefijo con valor diferente
            if bio_base in results and results[bio_base] != results[key]:
                valor_sin_prefijo = results[bio_base]
                valor_con_prefijo = results[key]

                # Sobrescribir si valor con prefijo es más confiable:
                # - Si IHQ_* es NEGATIVO y base es POSITIVO → sobrescribir (patrón mioepitelio más específico)
                # - Si IHQ_* tiene detalle extra (paréntesis) → sobrescribir
                if (valor_con_prefijo == 'NEGATIVO' and valor_sin_prefijo == 'POSITIVO') or \
                   ('(' in valor_con_prefijo and '(' not in valor_sin_prefijo):
                    results[bio_base] = valor_con_prefijo
                    logging.info(f"🔄 [V6.5.50 SINCRONIZACIÓN] {bio_base}: {valor_sin_prefijo} → {valor_con_prefijo} (copiado de {key})")

    return results


def extract_narrative_biomarkers(text: str, debug_mode: bool = False) -> Dict[str, str]:
    """Extrae biomarcadores del formato narrativo tipo:
    'células neoplásicas son fuertemente positivas para CK7 y GATA 3 y EMA, negativas para CK20, SOX10 y CDX2'
    Y formatos complejos como 'RECEPTOR DE ESTRÓGENOS, positivo focal'

    V6.3.41: FIX IHQ250035 - HER2 con score en formato narrativo
    V6.2.8: FIX IHQ250011 - Patrón mixto "positivo para X y negativas para Y, Z, W"
    V6.1.1: FIX IHQ250995 - Soporta "pérdida de expresión" y patrones complejos de próstata
    """
    results = {}

    # V6.3.41: FIX IHQ250035 - HER2 debe extraerse COMPLETO con score antes de patrones generales
    # V6.4.67 FIX IHQ250204: Ampliado para capturar "Sobreexpresión de oncogen HER 2"
    # V6.5.47 FIX IHQ250247: Capturar "HER2/neu" (barra diagonal)
    # Formatos soportados:
    #   - "Las células tumorales tienen expresión HER 2 negativo (score 0)"
    #   - "Sobreexpresión de oncogen HER 2: Negativo (score 0)"
    #   - "Sobre expresión del oncogén HER2/neu: Negativo (score 0)"
    # CRÍTICO: Este patrón debe ir PRIMERO para evitar que otros patrones capturen solo "NEGATIVO"
    # V6.4.67: Patrón tolerante a problemas de encoding (expresi�n, oncog�n)
    # Captura valor completo incluyendo paréntesis y se detiene antes de nueva sección
    her2_pattern = r'(?i)(?:c[eé]lulas\s+tumorales\s+tienen\s+)?(?:sobre)?expresi.n\s+(?:de\s+(?:oncog.n\s+)?)?(?:del?\s+)?HER\s*[-/]?\s*2(?:/neu)?\s*:?\s*(.+?(?:\([^)]+\))?)(?=\s+(?:DIAGN|Prueba|-\s*Prueba|\n-|\.)|$)'
    her2_match = re.search(her2_pattern, text)
    if her2_match:
        her2_valor_raw = her2_match.group(1).strip()
        # V6.4.65 FIX IHQ250204: Normalizar HER2 usando su diccionario de normalización
        her2_definition = BIOMARKER_DEFINITIONS.get('HER2', {})
        her2_normalization = her2_definition.get('normalizacion', {})
        her2_valor = normalize_biomarker_value(
            her2_valor_raw,
            her2_normalization,
            her2_definition.get('tipo_valor', 'DESCRIPTIVE')
        )
        results['HER2'] = her2_valor  # V6.4.67: Valor normalizado con SCORE preservado
        logging.info(f"✅ [HER2 narrativo v6.4.67] Extraído: {her2_valor_raw} → {her2_valor}")
    else:
        # V6.4.67 DEBUG: Log cuando NO hace match
        if 'HER' in text.upper() and '2' in text:
            logging.warning(f"⚠️ [HER2 narrativo v6.4.67] Patrón NO hizo match. Texto contiene HER2 pero formato no coincide.")

    # V6.4.44 FIX IHQ250179: PRIORIDAD ALTA - Mucinas (MUC1/MUC2) con formato "inmunorreactiva positiva difusa...para MUCX"
    # Formato: "El epitelio demuestra inmunorreactiva positiva difusa en el epitelio para MUC1 y son negativas para MUC2"
    # CRÍTICO: Debe ejecutarse ANTES de patrones genéricos "negativas para" que podrían capturar incorrectamente
    muc_positivo_pattern = r'(?i)inmunorreactiva?\s+positiva?\s+difusa?[^.]{0,80}?\s+para\s+(muc\s*-?\s*[12])'
    for match in re.finditer(muc_positivo_pattern, text):
        muc_raw = match.group(1).strip()
        normalized_name = normalize_biomarker_name(muc_raw)
        if normalized_name and normalized_name not in results:
            results[normalized_name] = 'POSITIVO DIFUSO'
            logging.info(f"✅ [MUC positivo v6.4.44] '{muc_raw}' → {normalized_name} = POSITIVO DIFUSO")

    # V6.4.44 FIX IHQ250179: PRIORIDAD ALTA - Ki-67 cualitativo sin porcentaje
    # Formato: "el índice de proliferación celular medido con Ki 67 se distribuye uniformemente"
    # CRÍTICO: Debe ejecutarse ANTES de patrones numéricos que capturan "67" del nombre
    ki67_cualitativo_pattern = r'(?i)[ií]ndice\s+de\s+proliferaci[óo]n\s+c[ée]lular\s+medido\s+con\s+ki[^\w]*67\s+se\s+distribuye\s+uniformemente'
    ki67_cualitativo_match = re.search(ki67_cualitativo_pattern, text)
    if ki67_cualitativo_match and 'KI67' not in results:
        results['KI67'] = 'POSITIVO (distribución uniforme)'
        logging.info(f"✅ [Ki-67 cualitativo v6.4.44] Extraído: KI67 = POSITIVO (distribución uniforme)")

    # V6.5.53 FIX IHQ250250: PRIORIDAD ALTA - Ki-67 con formato "la distribución del índice... es a nivel de"
    # Formato: "la distribución del índice de proliferación medido con Ki 67 es a nivel de la capa basal"
    # Captura ubicación de la distribución (basal, superficial, profunda, etc.)
    ki67_distribucion_nivel_pattern = r'(?i)la\s+distribuci[óo]n\s+del\s+[ií]ndice\s+de\s+proliferaci[óo]n\s+medido\s+con\s+ki[^\w]*67\s+es\s+a\s+nivel\s+de\s+(?:la\s+)?(.+?)(?:\s+con\s+un\s+|$|\.)'
    ki67_nivel_match = re.search(ki67_distribucion_nivel_pattern, text)
    if ki67_nivel_match and 'KI67' not in results:
        ubicacion = ki67_nivel_match.group(1).strip()
        results['KI67'] = f'POSITIVO (distribución a nivel de {ubicacion})'
        logging.info(f"✅ [Ki-67 nivel distribución v6.5.53] Extraído: KI67 = {results['KI67']}")

    # V6.5.62 FIX IHQ250255: PRIORIDAD ALTA - Ki-67 cualitativo "es el esperado"
    # Formato: "El índice de proliferación celular Ki67% es el esperado en los folículos linfoides"
    # Descripción cualitativa común en hiperplasias reactivas y linfomas
    # Captura contexto opcional (en folículos, en zona germinal, etc.)
    ki67_esperado_pattern = r'(?i)(?:el\s+)?[ií]ndice\s+de\s+proliferaci[óo]n\s+(?:c[ée]lular\s+)?ki[^\w]*67%?\s+es\s+el\s+esperado(?:\s+en\s+(?:los?\s+)?(.+?))?(?:\s*[,.]|\s+más\s+|$)'
    ki67_esperado_match = re.search(ki67_esperado_pattern, text)
    if ki67_esperado_match and 'KI67' not in results:
        contexto = ki67_esperado_match.group(1)
        if contexto:
            contexto_clean = contexto.strip()
            results['KI67'] = f'ESPERADO ({contexto_clean})'
            logging.info(f"✅ [Ki-67 esperado v6.5.62] Extraído: KI67 = {results['KI67']}")
        else:
            results['KI67'] = 'ESPERADO'
            logging.info(f"✅ [Ki-67 esperado v6.5.62] Extraído: KI67 = ESPERADO")

    # V6.4.91 FIX IHQ250219: PRIORIDAD ALTA - Ki-67 cualitativo con distribución variable
    # Formato: "índice de proliferación celular medido mediante el Ki67 se distribuye predominantemente en el centro"
    # Diferencias vs v6.4.44: "medido mediante" (vs "medido con"), "predominantemente" (vs "uniformemente")
    # Captura cualquier tipo de distribución (uniformemente, predominantemente, focalmente, etc.)
    ki67_distribucion_pattern = r'(?i)[ií]ndice\s+de\s+proliferaci[óo]n\s+c[ée]lular\s+medido\s+(?:con|mediante(?:\s+el)?)\s+ki[^\w]*67\s+se\s+distribuye\s+(\w+)'
    ki67_dist_match = re.search(ki67_distribucion_pattern, text)
    if ki67_dist_match and 'KI67' not in results:
        distribucion = ki67_dist_match.group(1).strip().lower()
        # Mapeo de distribuciones a valores normalizados
        if 'uniforme' in distribucion:
            results['KI67'] = 'POSITIVO (distribución uniforme)'
        elif 'predominante' in distribucion:
            results['KI67'] = 'POSITIVO (distribución predominante)'
        elif 'focal' in distribucion:
            results['KI67'] = 'POSITIVO (distribución focal)'
        elif 'difusa' in distribucion or 'difuso' in distribucion:
            results['KI67'] = 'POSITIVO (distribución difusa)'
        else:
            results['KI67'] = f'POSITIVO (distribución {distribucion})'
        logging.info(f"✅ [Ki-67 distribución v6.4.91] Extraído: KI67 = {results['KI67']}")

    # V6.4.91 FIX IHQ250219: PRIORIDAD ALTA - "No hay expresión para [LISTA]"
    # Formato: "No hay expreisón para HHV-8 ni para LMP-1" (typo OCR común: expreisón con 'i' antes de 's')
    # Captura biomarcadores en lista después de "No hay expresión para" → NEGATIVO
    # Variantes: "ni para", "ni", "y" como separadores
    # Patrón robusto: acepta "expresión", "expresion", "expreisón", "expreison" (typos OCR comunes)
    no_expresion_pattern = r'(?i)no\s+hay\s+expr[ei]+s[ioó]+n\s+para\s+([^.]+)'
    for match in re.finditer(no_expresion_pattern, text):
        lista_raw = match.group(1).strip()
        logging.info(f"🔍 [V6.4.91 No hay expresión] Lista detectada: '{lista_raw}'")

        # Separar por "ni para", "ni", "y", comas
        lista_raw = re.sub(r'\s+ni\s+para\s+', ', ', lista_raw)
        lista_raw = re.sub(r'\s+ni\s+', ', ', lista_raw)
        lista_raw = re.sub(r'\s+y\s+', ', ', lista_raw)
        biomarcadores_lista = re.split(r'[,;]\s*', lista_raw)

        for bio_raw in biomarcadores_lista:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw or len(bio_raw) < 2:
                continue

            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name and normalized_name not in results:
                results[normalized_name] = 'NEGATIVO'
                logging.info(f"✅ [V6.4.91 No hay expresión] '{bio_raw}' → {normalized_name} = NEGATIVO")

    # V6.4.62 FIX IHQ250202: PRIORIDAD MÁXIMA - "Los marcadores [lista] - son negativos/positivos"
    # Formato específico: "Los marcadores napsina y TTF-1 - son negativos."
    # Este patrón ejecuta PRIMERO con máxima prioridad (formato con guion antes del verbo)
    # IMPORTANTE: Posicionado al inicio para que NO sea sobrescrito por patrones genéricos posteriores
    # V6.4.62: FIX regex - [^-]+? solo capturaba "n", cambiado a .+? para capturar toda la lista
    marcadores_con_guion_pattern = r'(?i)Los?\s+marcadores?\s+(.+?)\s+-\s+(?:son|es)\s+(negativos?|positivos?)'
    for match in re.finditer(marcadores_con_guion_pattern, text):
        lista_biomarkers_raw = match.group(1).strip()
        resultado = match.group(2).strip().upper()

        logging.info(f"🔍 [V6.4.61 Los marcadores - son negativos] Lista detectada: '{lista_biomarkers_raw}' → {resultado}")

        # Determinar valor base según resultado
        if 'NEGATIVO' in resultado:
            valor_base = 'NEGATIVO'
        elif 'POSITIVO' in resultado:
            valor_base = 'POSITIVO'
        else:
            continue

        # Separar por comas Y "y"
        biomarcadores_encontrados = re.split(r'[,;]\s*|\s+y\s+', lista_biomarkers_raw)

        for bio_raw in biomarcadores_encontrados:
            bio_raw = bio_raw.strip().rstrip('.')
            if not bio_raw:
                continue

            # Normalizar nombre (maneja TTF-1 → TTF1, napsina → NAPSIN)
            normalized_name = normalize_biomarker_name(bio_raw)
            if normalized_name:
                results[normalized_name] = valor_base
                logging.info(f"✅ [Los marcadores - son {valor_base} v6.4.61 MÁXIMA PRIORIDAD] '{bio_raw}' → {normalized_name} = {valor_base}")

    # V6.4.1: FIX IHQ250115 - Soporta adjetivos como "es de forma difusa positiva para"
    # Y restringe la captura de marcadores positivos para evitar over-greedy sobre "negativo para"
    # V6.3.94 FIX IHQ250115: Soporte para "positivo con" además de "positiva para"
    # V6.4.30 FIX IHQ250164: Soporte para "negativa con el" (agregar "el" opcional después de "con")
    # V6.5.76 FIX IHQ250277: Límites para prevenir catastrophic backtracking en listas largas
    mixto_pattern = r'(?i)(?:es\s+|son\s+)?(?:de\s+forma\s+\w+\s+)?positiv[oa]s?\s+(?:para|con)\s+(?:receptores?\s+(?:hormonales?\s+)?de\s+)?([^.]{1,200}?)\s+y\s+(?:es\s+|son\s+)?negativ[oa]s?\s+(?:para|con(?:\s+el)?)\s+(?:receptores?\s+(?:de\s+)?)?(.{1,300}?)(?:\.|$)'

    for match in re.finditer(mixto_pattern, text, re.DOTALL):
        # Grupo 1: POSITIVOS
        positivos_raw = match.group(1).strip()
