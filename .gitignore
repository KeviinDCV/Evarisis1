# ===================================================================
# .gitignore para Proyecto HUV - Gestor de Oncología
# INCLUYE SOLO: Carpetas esenciales + archivos principales del root
# ===================================================================

# ===============================================
# ENFOQUE: EXCLUIR TODO EXCEPTO LO ESPECIFICADO
# ===============================================

# Excluir todo por defecto
/*

# ===============================================
# CARPETAS PERMITIDAS (INCLUIR EN GIT)
# ===============================================

# Carpetas core del proyecto
!/config/
!/core/
!/data/
!/documentacion/
!/EXCEL/
!/imagenes/
!/pdfs_patologia/

# Carpetas reorganizadas
!/dev_scripts/
!/docs/
!/platform_specific/
!/tests/
!/test/
!/test_integration/
!/documentacion_actualizada/
!/herramientas_ia/
!/ui_helpers/
!/LEGACY/

# ===============================================
# ARCHIVOS DEL ROOT PERMITIDOS (INCLUIR EN GIT)
# ===============================================

# Archivos principales del proyecto
!ui.py
!requirements.txt
!README.md
!REORGANIZATION_GUIDE.md
!COMPILADOR.bat
!iniciar_python.bat
!iniciar_python_mac.sh
!GestorOncologia.spec
!pytest.ini

# Archivos de configuración de Git
!.gitignore
!.gitattributes

# ===============================================
# EXCLUSIONES DENTRO DE CARPETAS PERMITIDAS
# ===============================================

# Dentro de cualquier carpeta, excluir:
**/__pycache__/
**/*.pyc
**/*.pyo

# Archivos temporales y de salida
**/temp_files/
**/temp_output*/
**/*_temp.*
**/*_backup.*
**/test_*.py
**/nul
**/*.bak
**/prueba*/

# Archivos de logs y debugging
**/*.log
**/debug_*
**/*.pyd
**/node_modules/
**/.DS_Store
**/Thumbs.db
**/*.tmp
**/*.temp
**/*.swp
**/*.log

# Entornos virtuales en cualquier ubicación
**/venv/
**/venv*/
**/env/
**/.venv/
**/.env/

# Archivos de build en cualquier ubicación
**/dist/
**/build/

# ===============================================
# EXCLUSIONES ESPECÍFICAS
# ===============================================

# Bases de datos temporales (mantener estructura, no datos)
data/*.db
data/*.sqlite
data/*.sqlite3
data/reportes_ia/*.md
data/auditorias_ia/*.md

# Archivos sensibles en cualquier ubicación
**/*.key
**/*.pem
**/*.p12
**/credentials.json
**/config.ini
**/.env

# ===============================================
# NOTAS DE CONFIGURACIÓN
# ===============================================
# Este .gitignore está configurado para incluir SOLO:
#
# CARPETAS:
# - config/       (configuraciones del proyecto)
# - core/         (módulos principales)
# - data/         (bases de datos y datos del proyecto)
# - documentacion/ (documentación técnica)
# - EXCEL/        (archivos Excel del proyecto)
# - imagenes/     (recursos gráficos)
# - pdfs_patologia/ (archivos PDF médicos)
#
# ARCHIVOS ROOT:
# - ui.py                 (interfaz principal)
# - requirements.txt      (dependencias Python)
# - CHANGELOG.md          (historial de cambios)
# - README.md             (documentación principal)
# - VERSION_INFO_GUIDE.md (guía de versiones)
# - COMPILADOR.bat        (script de compilación)
# - iniciar_python.bat    (script de inicio)
#
# TODO LO DEMÁS SE EXCLUYE AUTOMÁTICAMENTE
# ===============================================